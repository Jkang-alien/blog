        setFilterAndThemeData: function(data) {
            var filterData = [];
            var col = {};
            if(_.isArray(data)) {
                _.each(data, function(column) {
                    if(!(column.filterCategory !== 'CUSTOM_ATTRIBUTE' && column.uiKey === "")) {
                        col = {};
                        col.id = column.uiKey;
                        col.name = column.filterLabel;
                        col.filterKey = column.filterKey;
                        if(column.filterCategory !== 'CUSTOM_ATTRIBUTE'){
                            col.factoryProvided = true;
                        } else{
                            col.factoryProvided = false;
                        }
                        filterData.push(col);
                    }
                });
            }
            this.filterAndThemeData = filterData;
        },

        getFilterAndThemeData: function() {
            var self = this;
            if(!_.isUndefined(self.filterAndThemeData)) {
                return self.filterAndThemeData;
            }
        },

        getSelectedColumns: function() {
            var gridCols = {};
            var gridColumns = this._columns();
            if(_.isObject(gridColumns) && !_.isEmpty(gridColumns)) {
                var availableColumns =  this.getFilterAndThemeData();
                var selectedFields = _.pluck(gridColumns, "field");
                var _temp = [];
                _.each(availableColumns, function(column){
                    if(_.contains(selectedFields, column.id)) {
                        _temp.push(column.filterKey);
                    }
                });
                gridCols.selectedColumns = _temp;

            }
            gridCols.selectedColumns = this.addExtraColumns(gridCols.selectedColumns);
            return gridCols;
        },

        addExtraColumns: function(selectedColumns) {
            var extraColumns = ['ANALYSIS_NAME', 'ANALYSIS_APPLICATIONTYPE', 'ANALYSIS_ARCHIVED', 'ANALYSIS_ACTIVELY_EDITED', 'ANALYSIS_SHARED', 'ANALYSIS_PLUGIN'];
            _.each(extraColumns, function(column) {
