        },

        _fastaContentChanges : function(e) {
            if (e) {
                e.preventDefault();
            }
            this._resetProgress();
            this.primersContent.setNameAndContent(null, this.$el.find('#fasta-content').val());
        },

        _resetProgress : function() {
            this._clearErrors();
            this._uploadProgress(0);
            this.$('.progress')
                .addClass('progress-striped')
                .removeClass('progress-danger').removeClass('progress-success')
                .hide();
        },

        _uploadStart : function() {
            this.$('.progress').show();
        },

        _uploadProgress : function(data) {
            this.$('.progress .bar').css("width", data + '%');
        },

        _uploadComplete : function() {
            this.$('.progress').removeClass('progress-striped');
            this.$('#fasta-file-fileupload').bsFileupload('reset');
        },

        _uploadError : function() {
            this.$('.progress').addClass('progress-danger');
        },

        _uploadSuccess : function() {
            this.$('.progress').addClass('progress-success');
        }
    });

    var PrimersContentUploader = function(primersContent, fileUploadEl, fileInputEl) {
        this.primersContent = primersContent;
        this.fileUploadEl = fileUploadEl;
        this.fileInputEl = fileInputEl;
    };

    PrimersContentUploader.prototype.upload = function() {
        this.fileUploadEl.enhancedFileupload({
            autoUpload: false,
            replaceFileInput: false,
            paramName: 'fileData',
            url: '/ir/secure/api/v40/workflows/upload/primersFasta',
            formData: {
                'X-IonReporter-CSRF-Token': Global.csrfToken
            },
            dataType: 'json',
            progress:  $.proxy(this.progressCb, this),
            done: $.proxy(this.uploadSuccess, this),
            fail: $.proxy(this.uploadError, this),
            always: $.proxy(this.uploadComplete, this)
        });
        this.fileUploadEl.enhancedFileupload('send', {
            fileInput: this.fileInputEl
        });
        
        this.primersContent.trigger('uploadStart');
    };

    PrimersContentUploader.prototype.progressCb = function(e, data) {
        var progress = parseInt(data.loaded / data.total * 100, 10);
        this.primersContent.trigger('uploadProgress', progress);
    };
    
    PrimersContentUploader.prototype.uploadSuccess = function(evt, data) {
        var result = data.result;
        this.primersContent.setNameAndContent(this.fileInputEl.val(), result.fileContent);
        this.primersContent.trigger('uploadSuccess');
    };

    PrimersContentUploader.prototype.uploadError = function(evt, data) {
        var xhr = data.jqXHR;
        this.primersContent.trigger('uploadError');
        var errorPacket = JSON.parse(xhr.responseText);
        this.primersContent.trigger('displayError', errorPacket);
    };

    PrimersContentUploader.prototype.uploadComplete = function() {
        this.primersContent.trigger('uploadComplete');
    };

    return PrimersContentView;
});
