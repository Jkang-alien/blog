define('views/cnvbaseline/cnvBaselineConfirmView',[ 'jquery', 'underscore', 'kendo', 'models/cnvBaseline', 'views/formView', 'hb!templates/cnvbaseline/cnvbaseline-confirm.html', 'views/validationErrorsView']
    .concat('i18n'),
    function($, _, Kendo, CNVBaseline, FormView, template, ValidationErrorsView) {
        

        var CNV_BASELINE_PRESET_URL = '/ir/secure/workflows-presets.html#baseline';

        var ConfirmView = FormView.extend({
            submitButtonSelector: '#save-cnvbaseline',

            initialize : function() {
                this._configureName();
            },

            delegateEvents: function() {
                FormView.prototype.delegateEvents.apply(this, arguments);
                this.listenTo(this.model, 'invalid', this.validationError);
            },

            _configureName: function() {
                if (!this.model.has('name')) {
                    var name = 'CNVBase_';
                    if (this.model.get('type').get('name') === CNVBaseline.prototype.WHOLE_GENOME) {
                        name += 'WholeGenome_';
                    } else {
                        name += this.model.get('targetRegion').get('name') + '_';
                    }
                    name += (Kendo.toString(new Date(), 'g'));

                    this.model.set('name', name.replace(/[^\w_]/g, '_'));
                }
            },

            events : {
                "keyup #cnvbaseline-name, #cnvbaseline-desc" : "changed"
            },

            render : function() {
                this.$el.html(template(this.model.toJSON()));
                this.clearBanner();
                this.bindSubmit();
                this.$('#cnvbaseline-name').focus();
                return this;
            },

            bindSubmit: function() {
                var self = this;
                $('#cnvbaseline-confirm-id').submit(function(event) {
                    event.preventDefault();
                    self.clickSave();
                });
            },

            clickSave: function() {
                $('#save-cnvbaseline').click();
            },

            changed : function(evt) {
                this.clearBanner();
                this.$('.control-group.error').removeClass('error');
                var changed = evt.currentTarget;
                var value = $(changed).val();

                this.model.set(changed.name, value);
                if (this.model.isValid()) { //calling BB.isValid() after set to ensure model is in sync with UI since calling set 
                    this.enableButton(this.submitButtonSelector);
                }
            },
            onSaveSuccess : function() {
                window.location = CNV_BASELINE_PRESET_URL;
            },

            clearBanner: function() {
                $(".alert-error").remove();
            },

            validationError : function(model) {
                this.clearBanner();
                if (model.validationError) {
                    var response = {
                        responseText : JSON.stringify({message: $.t('name.error.content.nospace')})
                    };

                    var container = $('#name_validation_errors');
                    ValidationErrorsView.show(response, container);

                    this.$(".control-group:first").addClass("error");
                    this.disableButton(this.submitButtonSelector);
                }
            }

        });

        return ConfirmView;

    }
);
