                url : '/ir/secure/api/v40/analysis'
            });

            new Analyses().fetch({
                data: {specimenId: specimenId},
                success: function(analyses) {
                    analysisDeferred.resolve(analyses);
                }
            });
            return analysisDeferred;
        }
    });

    return SampleOverviewPageView;
});
