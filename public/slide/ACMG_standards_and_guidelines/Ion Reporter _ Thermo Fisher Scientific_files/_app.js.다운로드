        _updateAllVariantAnnotationFlags : function(checkBoxElementsFromDom, flag) {
            var self = this;
            $.each(checkBoxElementsFromDom, function(index){
                if(typeof( $(checkBoxElementsFromDom[index]).attr('data-variant-comment-id') ) === 'undefined' ) {
                    $(checkBoxElementsFromDom[index]).prop('checked', flag);
                    self._updateVariantAnnotationValue(checkBoxElementsFromDom[index]);
