                if(typeof this.model.get("reportedVariantsSection").selectedAnnotations !== typeof undefined && this.model.get("reportedVariantsSection").selectedAnnotations.length !== 0 && !this.model.get("reportedVariantsSection").isSummaryAnnotations) {
                    selectedAnnotations = this._pushSelectedAnnotations();
                } else {
                    if(typeof this.chevronModel.get("configuration").selectedVariantColumns !== typeof undefined && this.chevronModel.get("configuration").selectedVariantColumns.trim() !== "") {
                        var targetColumns = this.chevronModel.get("configuration").selectedVariantColumns.split(",");
                        _.each(targetColumns, function(gridThemeColumn){
                            _.each(self.chevronModel.get("configuration").analysisReport.reportedVariantsSection.reportedVariants[0].availableAnnotations, function(annotation, i){
                                if(typeof annotation.key.keyName !== typeof undefined){
                                    if(gridThemeColumn.replace(/\./g, '_').toUpperCase() === annotation.key.keyName.replace(/\./g, '_').toUpperCase()){
                                        var obj = {};
                                        obj.label = annotation.key.asDisplayableString || annotation.key.keyName;
                                        obj.key = annotation.key.keyName;
                                        obj.order = i+1;
                                        obj.isSelected = "true";
                                        selectedAnnotations.push(obj);
                                    }
                                }
                            });
                        });
                    } else{
                        selectedAnnotations = this._pushSelectedAnnotations();
                    }

                }
                this.chevronModel.get("configuration").selectedAnnotations = selectedAnnotations;
            }
        },

        _pushSelectedAnnotations: function(){
            var selectedAnnotations = [];
            _.each(this.model.get("reportedVariantsSection").selectedAnnotations, function(annotation, i){
                var obj = {};
                obj.label = annotation.key.asDisplayableString || annotation.key.keyName;
                obj.key = annotation.key.keyName;
                obj.order = i+1;
                obj.isSelected = "true";
                selectedAnnotations.push(obj);
            });
            return selectedAnnotations;
        },

        _getAllReportedVariants: function(){
            if(typeof this.chevronModel.get("configuration").allReportedVariants === typeof undefined){
                var allReportedVariants = [];
                _.each(this.model.get("reportedVariantsSection").reportedVariants, function(reportedVariant) {
                    var row = {};
                    var variants = [];
                    row.classification = reportedVariant.classification;
                    _.each(reportedVariant.availableAnnotations, function(annotation){
                        if(typeof annotation.key.keyName !== typeof undefined){
                            var obj = {};
                            obj.label = annotation.key.asDisplayableString || annotation.key.keyName;
                            obj.key = annotation.key.keyName;
                            obj.values = annotation.values;
                            variants.push(obj);
                        }
                    });
                    row.variants = variants;
                    allReportedVariants.push(row);
                });
                this.chevronModel.get("configuration").allReportedVariants = allReportedVariants;
            }
        },

        _getAvailableAnnotations: function(){
            if(typeof this.chevronModel.get("configuration").availableAnnotations === typeof undefined){
                var self = this;
                var availableAnnotations = [];
                if(typeof this.chevronModel.get("configuration").allReportedVariants[0] !== typeof undefined){
                    _.each(this.chevronModel.get("configuration").allReportedVariants[0].variants, function(reportedVariant){
                        var temp = reportedVariant;
                        temp.isSelected = "false";
                        _.each(self.chevronModel.get("configuration").selectedAnnotations, function(selectedAnnotation){
                            if(selectedAnnotation.key === reportedVariant.key){
                                temp.isSelected = "true";
                            }
                        });
                        availableAnnotations.push(temp);
                    });
                }
                this.chevronModel.get("configuration").availableAnnotations = availableAnnotations;
                this._filterSelectedAnnotations();
            }
        },

        _filterSelectedAnnotations: function(){
            var filteredSelectedAnnotation = [];
            var self = this;
            _.each(this.chevronModel.get("configuration").selectedAnnotations, function(annotation){
                _.each(self.chevronModel.get("configuration").availableAnnotations, function(availableAnnotation){
                    if(availableAnnotation.key.replace(/\./g, '_').toUpperCase() === annotation.key.replace(/\./g, '_').toUpperCase()){
                        filteredSelectedAnnotation.push(annotation);
                    }
                });
            });
            this.chevronModel.get("configuration").selectedAnnotations = filteredSelectedAnnotation;
        },

