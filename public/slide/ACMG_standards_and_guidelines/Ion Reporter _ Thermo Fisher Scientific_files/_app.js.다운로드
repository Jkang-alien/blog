                TemplateView.prototype.delegateEvents.apply(this, arguments);
                this.listenTo(this.fileUpload, 'upload:validationSuccessful', this._onUploadComplete);
                this.listenTo(this.fileUpload, 'upload:validationFailed', this._onValidationFailed);
            },

