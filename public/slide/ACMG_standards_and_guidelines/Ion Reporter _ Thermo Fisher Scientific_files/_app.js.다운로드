        renderReportedVariantGrid: function(){
            var me = this;
            var header = "<thead><tr><th></th><th>Classification</th>";
            var row = "<tbody>";
            var that = this;
            var isHeader = true;
            $(this.chevronModel.get("configuration").allReportedVariants).each(function(){
                var self = this.variants;
                row += "<tr class='"+$.t('finalReport.variantClassification.cssClass.'+this.classification)+"'><td class='variant-classifier'>&nbsp;</td><td>"+ $.t('analysis.variant.classification.'+this.classification)+"</td>";
                $(that.chevronModel.get("configuration").selectedAnnotations).each(function(){
                    var parent = this;
                    var found = false;
                    $(self).each(function(){
                        if(parent.key.replace(/\./g, '_').toUpperCase() === this.key.replace(/\./g, '_').toUpperCase()){
                            if(typeof this.values !== typeof undefined){
                                if(typeof this.values[0] !== typeof undefined && typeof this.values[0].first !== typeof undefined){
                                    var firstSecondValue = this.values[0].first.asDisplayableString;
                                    if(typeof this.values[0].second !== typeof undefined){
                                        firstSecondValue += ' - '+this.values[0].second.asDisplayableString;
                                    }
                                    row +=  "<td>"+firstSecondValue+"</td>";
                                } else if(this.values.length < 2){
                                    if(typeof this.values[0] !== typeof undefined && typeof this.values[0].asDisplayableString !== typeof undefined){
                                        row +=  "<td>"+this.values[0].asDisplayableString+"</td>";
                                    } else{
                                        row+= "<td></td>";
                                    }
                                } else{
                                    if(this.key === "a.gene.combined") {
                                        var genesTemplate = me.subTemplates.variantGenesTemplate({values:this.values, geneDisplayCount: Configuration.getAsInt('report.gene.count.display')});
                                        row += "<td>" + genesTemplate + "</td>";
                                    } else {
                                        var multipleValues = [];
                                        _.each(this.values,function(value){
                                            if(typeof value.asDisplayableString !== typeof undefined){
                                                multipleValues.push(value.asDisplayableString);
                                            }
                                        });
                                        row +=  "<td>"+multipleValues.join(', ')+"</td>";
                                    }
                                }
                            } else{
                                row+= "<td></td>";
                            }
                            found = true;
                        }
                    });
                    if(isHeader){
                        header += "<th>"+parent.label+"</th>";
                    }
                    if(!found){
                        row+= "<td></td>";
                    }
                });
                row += "</tr>";
                isHeader = false;
            });

            row += "</tbody>";
            header += "</tr></thead>";
            $("#final-report-variants-grid").empty().append(header+""+row);
            VariantColumnModalView.close();
        },
        
