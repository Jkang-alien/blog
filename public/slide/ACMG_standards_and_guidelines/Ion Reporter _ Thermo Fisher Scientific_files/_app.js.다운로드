                var copyValue = this._getLocationSearch();
                var isCopy = copyValue.search("copy=true");
                if (isCopy > -1) {
                    this.model.setCopy(true);
                    return true;
                } else {
                    this.model.setCopy(false);
                    return false;
                }
            },

