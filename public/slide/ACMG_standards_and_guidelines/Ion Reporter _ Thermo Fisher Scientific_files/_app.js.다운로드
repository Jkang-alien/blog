            previousFilterChain = this._analysis.getFilterChain();
            if(selectedFilterChain !== undefined && selectedFilterChain !== null) {
                if(selectedFilterChain.get('referenceGenome')) {
                    if(selectedFilterChain.get('referenceGenome').id === undefined ||
                        selectedFilterChain.get('referenceGenome').name === undefined) {
                        selectedFilterChain.get('referenceGenome').id = previousFilterChain.get('referenceGenome').id;
