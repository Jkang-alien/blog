define('views/finalReportTemplate/headerSectionView',[ 'jquery', 'underscore', 'backbone', 'models/finalReportSection',
        'views/finalReportTemplate/finalReportSectionView',
        'views/finalReportTemplate/headerSectionLogoFileUploadView', 'views/common/bannersView',
        'hb!templates/finalReportTemplate/header-section.html' ], 
        function($, _, Backbone, FinalReportSection, FinalReportSectionView, HeaderSectionLogoFileUploadView, BannerView, template) {

    
    var HeaderSectionView = FinalReportSectionView.extend({

        _template: template,

        events : _.extend({}, FinalReportSectionView.prototype.events, {
            'click #uploadCustomLogo' : '_displayUploadHeaderSectionLogo',
            'click #removeCustomLogo' : '_removeLogo'
        }),

        _displayUploadHeaderSectionLogo : function(e) {
            e.preventDefault();
            var self = this;
            HeaderSectionLogoFileUploadView.open(function() {
                self._createBannerViewWithMessage('finalReportTemplate.headersection.logo.file.upload.success').render();
                self._previewLogo();
            }, function() {}, {
                model : self.model
            });

        },

        _createBannerViewWithMessage: function (messageKey) {
            return new BannerView({
                id: 'success-banner',
                container: this.$('#headersectionlogo-upload-success'),
                style: 'success',
                title: $.t(messageKey)
            });
        },
        
        _previewLogo : function() {
            var logo = this.model.get('logo');
            var logoUrl = '/ir/resources/img/no-image.png';
            if (logo) {
                var name = (logo instanceof Backbone.Model) ? logo.get('name') : logo.name;
                var id = (logo instanceof Backbone.Model) ? logo.get('id') : logo.id;
                if(name !== 'remove') {
                    logoUrl = '/ir/secure/api/v40/finalreporttemplates/headersectionlogo/'+ id + '/icon.png';
                }
                this.$('#headersectionlogo-preview-img').attr('src', logoUrl);
            }
        },

        _removeLogo : function() {
            var logo = this.model.get('logo');

            if (logo) {
                if(!this.removeAtSave) {
                    $.ajax({
                        url: '/ir/secure/api/v40/finalreporttemplates/headersectionlogo/remove/' + logo.id + '/icon.png',
                        type: 'DELETE',
                        contentType: 'application/json',
                        async: false
                    });
                    this.model.unset('logo');
                } else {
                    if(logo instanceof Backbone.Model) {
                        logo.set('id',this.options.parent.model.id);
                        logo.set('name','remove');
                    } else {
                        logo.id = this.options.parent.model.id;
                        logo.name = 'remove';
                    }
                }

            }
            this.$('#headersectionlogo-preview-img').attr('src', '/ir/resources/img/no-image.png');
            this._previewLogo();

        },

        render : function() {
            FinalReportSectionView.prototype.render.call(this);
            var logo = this.model.get('logo');
            this.removeAtSave = false;
            if(logo) {
                this.removeAtSave = true;
            }
            this._previewLogo();
        }

    });

    return HeaderSectionView;
});
