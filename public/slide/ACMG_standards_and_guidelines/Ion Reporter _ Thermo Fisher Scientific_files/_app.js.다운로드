            },
            onFilterApplicationCategory: function(filter) {
                if (_.isEmpty(filter)) {
                    this.gridView.clearFilter('applicationCategoryFilter');
                } else {
                    this.gridView.addFilter('applicationCategoryFilter', filter);
                }

            }

        });

