            _json: function (model) {
                var attributes = [];
                attributes.push({
                    name: 'Sample Name',
                    id: 'sampleName',
                    value: model.name,
                    imgUrl: 'sample.png'
                });
                attributes.push({
                    name: 'Relationship',
                    id: 'relationship',
                    value: model.ROLE,
                    imgUrl: 'sample.png'
                });
                model.attributes.forEach(function (attribute) {
                    attributes.push({
                        name: attribute.attribute.name,
                        value: attribute.value,
                        id: attribute.attribute.id,
                        imgUrl: this._getImgUrlForName(attribute.attribute.name)
                    });
                }, this);
                var metadata = model.metadata || {}; // this is null if no metadata is set.
                _.each(metadata, function (value, key) {
                    attributes.push({
                        name: key,
                        value: value,
                        id: this._transformMetadataKeyToId(key) + "_" + model.id,
                        imgUrl: this._getImgUrlForName(key)
                    });
                }, this);

                var json = {
                    attributeRows: [
                        {
                            attributes: []
                        }
                    ]
                };
                for (var i = 0; i < 4 && attributes.length > 0; i++) {
                    _.last(json.attributeRows).attributes.push(attributes.shift());
                    if (i === 3 && attributes.length > 0) {
                        i = 0;
                        json.attributeRows.push({
                            attributes: []
                        });
                    }
                }

                return json;
            },

            _getImgUrlForName: function (name) {
                switch (name.toLowerCase()) {
                case "gender":
                    return 'gender.png';
                case "role":
                case "relationship":
                    return 'annotations.png';
                case "bar code":
                    return 'barcode.png';
                case "chip type":
                case "chip id":
                    return 'three_chip_icon.png';
                case "library preparation":
                    return 'library.png';
                case "device id":
                    return 'pgm.png';
                default:
                    return 'reporter.png';
                }
            },

            _transformMetadataKeyToId: function (key) {
                return key.replace(/[^a-z0-9]/gi, '');
            },

