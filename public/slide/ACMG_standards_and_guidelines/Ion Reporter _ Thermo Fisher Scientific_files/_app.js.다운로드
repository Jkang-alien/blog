            'click #save-auth-btn': '_onSave'
        },

        initialize: function() {
            this.collection = this.model;
        },

        render: function() {
            TemplateView.prototype.render.apply(this, arguments);
            this.model.set('orgExists', true);
            var orgList=[];
            var workflowList=[];
            var access = this.model.get('access');
            if (access === "Revoke") {
                BannerView.show({
                    id: 'warn-banner',
                    container: $('.main-content>.container-fluid'),
                    style: 'warn',
                    static : true,
                    title: $.t('revoke.access.warn')
                });
