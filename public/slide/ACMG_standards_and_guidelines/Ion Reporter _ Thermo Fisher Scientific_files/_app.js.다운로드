            _preferedSections: function (preferedSections) {
                var parent = this.$el.find(".report-sections");
                var availableSections = this.$el.find('.available-sections > li');
                var date = kendo.toString(new Date(), 'MMM dd yyyy hh:mm tt');
                _.each(preferedSections, function (preferedSection) {
                    _.each(availableSections, function (availableSection) {
                        if (preferedSection.section === availableSection.id) {
                            if (preferedSection.data !== undefined && preferedSection.section !== 'comments_section' &&
                                preferedSection.section !== 'header_section' && preferedSection.section !== 'signoff_section') {
                                $(availableSection).find('textarea').text(preferedSection.data);
                            }
                            if (preferedSection.section === 'header_section') {
                                $(availableSection).find('#inputOrgName').text(preferedSection.name);
                                $(availableSection).find('#inputOrgAddress').text(preferedSection.address);
                                $(availableSection).find('#headersectionlogo-preview-img').attr('src', preferedSection.imageSrc);
                                $(availableSection).find('#reported-on').text(date);
                            }
                            if (preferedSection.section === 'signoff_section') {
                                this._addBlankAuthors(preferedSection.data);
                            }
                            parent.append(availableSection);
                        }

                    }, this);
                }, this);
                _.each(parent, function (i) {
                    $(i).find("div.report-widget").addClass("hide");
                    $(i).find("div.report-section").removeClass("hide");
                });

            },

