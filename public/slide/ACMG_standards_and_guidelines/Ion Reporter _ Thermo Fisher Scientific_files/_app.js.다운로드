        _performSelectAllForNotes : function(e) {
            var currentVariantId = $(e.currentTarget).attr('data-variant-id');
            var checkBoxElementsFromDom;
            var self = this;
            if($(e.currentTarget).prop('checked') === true) {
                checkBoxElementsFromDom = $("table").find("[data-variant-id='" + currentVariantId + "']");
                self._updateAllVariantNoteFlags(checkBoxElementsFromDom, true);
