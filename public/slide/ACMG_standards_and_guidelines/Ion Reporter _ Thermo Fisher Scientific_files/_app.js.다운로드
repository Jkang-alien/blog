                        width: '15%',
                        template: function(dataItem) {
                            if(dataItem.shareStatus === 'SHARED') {
                                return '<button type=\"button\" class=\"btn deleteAnalysisBtn\">' +
                                                            '<i class=\"icon-trash\"></i></button>';
                            }
                            return "";
                        }
                    });
