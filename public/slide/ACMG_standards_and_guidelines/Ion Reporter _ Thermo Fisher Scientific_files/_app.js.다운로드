define('views/finalreport/finalReportPreview',[ 'jquery',
         'underscore',
         'backbone',
         'views/finalreport/finalReportPublishModalView',
         'views/loadingView',
         'views/common/bannersView',
         'views/metrics',
         'utils/asyncDownloader',
         'hb!templates/finalreport/finalreport-preview.html']
         .concat(
         'jqFileDownload'
         ),function($,
             _,
             Backbone,
             PublishModalView,
             LoadingView,
             BannerView,
             Metrics,
             AsyncDownloader,
             Template) {
        var FinalReportPreview = Backbone.View.extend({

            _template: Template,

            initialize: function(options) {
                this.chevronModel = options.model;
                this.analysisModel = JSON.stringify(this.chevronModel.get("configuration").analysisReport);
                this.isTFCloudIntegrationEnabled = this.chevronModel.get("configuration").isTFCloudIntegrationEnabled;
                this.startTime = this.chevronModel.get("configuration").startTime;
                var workflow;
                if(typeof this.chevronModel.get("configuration").analysisReport.analysis.workflow !== typeof undefined){
                    workflow = this.chevronModel.get("configuration").analysisReport.analysis.workflow;
                    if(typeof workflow !== typeof undefined){
                        this.workflowApplicationName =  workflow.name;
                        this.workflowApplicationType = workflow.applicationType;
                        this.workflowApplicationVersion = workflow.applicationVersion.name;
                    }
                    this.analysisName = this.chevronModel.get("configuration").analysisReport.analysis.name;
                } else {
                    workflow = this.chevronModel.get("configuration").analysisReport.analysis.get("workflow");
                    if(typeof workflow !== typeof undefined){
                        this.workflowApplicationName =  workflow.get("name");
                        this.workflowApplicationType = workflow.get("applicationType");
                        this.workflowApplicationVersion = workflow.get("applicationVersion").name;
                    }
                    this.analysisName = this.chevronModel.get("configuration").analysisReport.analysis.get("name");
                }

            },

            render: function() {
                $("#saveAsNewTemplateButton").addClass('hide');
                this.$el.html(this._template(this.chevronModel.get('configuration').analysisReport));
                this._setPdfCompatibility();
                if (this.chevronModel.get('configuration').analysisReport.status === "PUBLISHED_AND_LOCKED") {
                    if(this.isPdfObjectSupported){
                        this.$('#finalReportPreviewPdf').attr("data", "data:application/pdf;base64,"+this.chevronModel.get('configuration').fileEncodedValue);
                    } else {
                        this._renderPdfInCanvas(this.chevronModel.get('configuration').fileEncodedValue);
                    }

                } else{
                    $("#confirmPublishModal").removeClass('hide');
                    var loadingView = new LoadingView({
                        bodyKey: 'analysis.report.prepare'
                    });
                    $("html, body").animate({scrollTop: 0}, 500);
                    loadingView.render();
                    var self = this;
                    $.ajax({
                        type: "POST",
                        url: "/ir/secure/preview_configuration",
                        data: this.analysisModel,
                        contentType: 'application/json',
                        success: function(data){
                            if(self.isPdfObjectSupported){
                                $('#finalReportPreviewPdf').attr("data", "data:application/pdf;base64,"+data);
                            } else {
                                self._renderPdfInCanvas(data);
                            }
                            loadingView.hide();
                        },
                        error: function(){
                            loadingView.hide();
                        }
                    });
                }
            },

            _confirmPublishModal: function() {
                PublishModalView.open().confirm(_.bind(this._publishAnalysisReport, this));
            },

            _publishAnalysisReport: function() {
                PublishModalView.close();
                var loadingView = new LoadingView({
                    bodyKey: 'analysis.report.save.in.progress'
                });
                $("html, body").animate({scrollTop: 0}, 500);
                loadingView.render();
                $.ajax({
                    type: "POST",
                    url: "/ir/secure/api/v40/analysis_reports/publish",
                    data: this.analysisModel,
                    contentType: 'application/json',
                    success: function(){
                        $("#confirmPublishModal,.chevrons,#cancel").addClass("hide");
                        $("#previousStep").css("display","none");
                        $("#downloadFinalReport").removeClass("hide");
                        loadingView.hide();
                        new BannerView({
                            id: 'success-banner',
                            container: $('.main-content>.container-fluid'),
                            style: 'success',
                            title: $.t('analysis.report.successful.save')
                        }).render();
                    },
                    error: function(){
                        loadingView.hide();
                    }
                });
                if(this.isTFCloudIntegrationEnabled) {
                    Metrics.metrics("event", "Lock and Publish", this.workflowApplicationName, this.workflowApplicationType, this.workflowApplicationVersion, this.analysisName, "IonReporter > Analyses > Final_Report_Preview", this.startTime);
                }
            },

            _downloadReport: function() {
                var asyncDownloader = new AsyncDownloader();
                asyncDownloader.download("/ir/secure/analysis/finalReport/"+this.chevronModel.get('configuration').analysisReport.analysis.id+"/download", 'sample.auditlog.export.processing');
                if(this.isTFCloudIntegrationEnabled) {
                    Metrics.metrics("event", "Download", this.workflowApplicationName, this.workflowApplicationType, this.workflowApplicationVersion, this.analysisName, "IonReporter > Analyses > Final_Report_Preview", this.startTime);
                }
            },

            _setPdfCompatibility: function(){
                var flag = false;
                var self = this;
                if(navigator.mimeTypes){
                    _.each(navigator.mimeTypes, function(mimes){
                        if(mimes.type === "application/pdf"){
                            self.isPdfObjectSupported = true;
                            flag = true;
                        }
                    });
                }

                if(!flag){
                    this.isPdfObjectSupported = false;
                    this.$("#finalReportPreviewPdf").remove();
                }
            },

            _renderPdfInCanvas: function(pdfData){
                var self = this;
                require(['pdfjs'], function(){
                    if(!_.isUndefined(PDFJS)){
                        PDFJS.disableWorker = true;
                        PDFJS.getDocument({data:atob(pdfData)}).then(function(pdfDoc) {
                                                                                for(var i = 1; i <= pdfDoc.numPages; i++){
                                                                                    pdfDoc.getPage(i).then(self._renderPage);
                                                                                }
                                                                            });
                    }
                });
            },

            _renderPage: function (page) {
                var viewport = page.getViewport(1.5);
                var canvas = document.createElement('canvas');
                var ctx = canvas.getContext('2d');
                var renderContext = {
                    canvasContext: ctx,
                    viewport: viewport
                };

                canvas.height = viewport.height;
                canvas.width = viewport.width;
                $(".final-report-pdf-container").append(canvas).addClass("canvas");
                page.render(renderContext);
            }


        });

        return FinalReportPreview;
    });

