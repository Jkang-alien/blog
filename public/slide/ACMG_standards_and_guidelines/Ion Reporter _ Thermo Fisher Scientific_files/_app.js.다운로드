function ($, _, FormView, template, ErrorsView) {

    

    var PaymentAccountView = FormView.extend({

        submitButtonSelector: '#payment-account-btn-save',

        initialize: function() {
            this.model  = this.paymentAccount = this.options.model && this.options.model || null;
            this.errorsView = new ErrorsView({
                model: this.paymentAccount
            });
        },

        render: function() {
            this.$el.html(template({
            }));

            this.renderSubView(this.errorsView, "#errors");
            this._enableDisableSaveButton();
            return this;
        },

        events: {
            'click #payment-account-btn-cancel': 'cancel',
            'keyup input.payment-account-input': '_enableDisableSaveButton'
        },

        cancel: function() {
            this.$el.modal('hide');
            this.undelegateEvents();
        },

        save: function() {
            this._removeAnyAjaxErrors();
            var username = this.$el.find('input#payment-account-username').val().trim();
            var password = this.$el.find('input#payment-account-password').val().trim();

            this.paymentAccount.set({
                username: username,
                password: password
            });

            this.paymentAccount.save({}, {
                success: _.bind(this.success, this),
                error: _.bind(this.error, this)
            });
        },

        _removeAnyAjaxErrors: function() {
            this.$("#ajaxerror").remove();
        },

        success: function() {
            if (this.options.onComplete && _.isFunction(this.options.onComplete)) {
                this.options.onComplete();
            }
            this.closeDialog();
        },

        error: function(paymentAccount, response) {
            var error = JSON.parse(response.responseText);

            if (error.type === "com.lifetechnologies.iontorrent.ionreporter.payment.services.exceptions.InvalidPaymentCredentialsException") {
                response.status = 400;
            }

            this.errorsView.options.showErrors = response.status === 400;
        },

        closeDialog: function() {
            this.$el.modal('hide');
            this.undelegateEvents();
        },

        _enableDisableSaveButton: function() {
            if (this._isValidPaymentAccount()) {
                this.enableButton(this.submitButtonSelector);
            } else {
                this.disableButton(this.submitButtonSelector);
            }
        },

        _isValidPaymentAccount: function() {
            var username = this.$el.find('input#payment-account-username').val();
            if (!username || !username.trim().length) {
                return false;
            }

            var password = this.$el.find('input#payment-account-password').val();
            if (!password || !password.trim().length) {
                return false;
            }

            return true;
        }

    });

    return PaymentAccountView;
});
