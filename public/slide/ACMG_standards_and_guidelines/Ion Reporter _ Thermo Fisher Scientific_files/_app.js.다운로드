define('views/analysis/sidebarFusionView',[
    'underscore',
    'views/analysis/sidebarPairedView',
    'models/analysis/specimenGroupRelationshipModel',
    'models/sample/attribute',
    'hb!templates/sample/samples-fusion-body.html'
], function(
    _,
    PairedView,
    SpecimenGroupRelationship,
    Attribute,
    FusionTemplate) {
    var AnalysisSamplesFusionPairedView = PairedView.extend({
        _relationshipType: 'DNA_RNA_FUSION',
        _bodyTemplate: FusionTemplate,
        _placeholderText: 'Group Name (Required)',

        _sampleOneRole: 'DNA_FUSION',
        _sampleTwoRole: 'RNA_FUSION',

        _selectionValidations: ['_checkSampleTypeAdded', '_canAddSamples'],
        
        _currentModel: null,

        _addRoleIfNecessary: function(sample, relationship, role) {
            var self = this;
            var members = relationship.get('members').map(function(member) {
                return !member || {
                    id: member.get('specimen').id,
                    role: member.get('role')
                };
            });
            var existingRole = _.findWhere(members, {role: role});
            var existingSample = _.findWhere(members, {id: sample.id});

            if (!existingSample && !existingRole && this._canAddSample(sample, self._workflow, role)) {
                relationship.get('members').push(new SpecimenGroupRelationship({
                    specimen: sample,
                    role: role
                }));
                return true;
            }

            return false;
        },

        _canAddSamples: function(samples) {
            var self = this;
            return _.every(samples, function(sample) {
                return self._canAddSample(sample, self._workflow);
            });
        },

        _canAddSample: function(sample, workflow, role) {

            var cnvSomatic = false;
            if (this._workflow && this._workflow.get('modules')) {
                cnvSomatic = _.some(this._workflow.get('modules').toJSON(), function(module) {
                    return _.some(module.parameters, function(parameter) {
                        if(parameter.key === 'cnv.somatic') {
                            return (parameter.value === "true"?1:0) || parameter.value > 0;
                        }
                    });
                });
            }
            var canAdd = true;
            if (cnvSomatic && (sample.get('attributeValueMap')["Sample Type"] === "DNA" || sample.get('attributeValueMap')["Sample Type"] === "DNA NTC")) {
                canAdd = sample.percentCellularity() || false;
            }

            canAdd = canAdd &&
                     (Attribute.Type.DNA === sample.type() || Attribute.Type.RNA === sample.type() ||
                     Attribute.Type.DNA_NTC === sample.type() || Attribute.Type.RNA_NTC === sample.type());

            if (role) {
                if ('DNA_FUSION' === role) {
                    canAdd = canAdd && (Attribute.Type.DNA === sample.type() || Attribute.Type.DNA_NTC === sample.type());
                } else if ('RNA_FUSION' === role) {
                    canAdd = canAdd && (Attribute.Type.RNA === sample.type() || Attribute.Type.RNA_NTC === sample.type());
                }
            }

            return canAdd;
        },
        
        _checkSampleTypeAdded: function(selectedSamples) {
            var members = this.model.get('members').map(function(member) {
                return member.get('specimen').get('attributeValueMap')["Sample Type"];
            });

            return _.some(selectedSamples, function(sample) {
