        _sortable : function(){
            var adjustment;
            var self = this;
            $("ol.report-sections").sortable({
                group: 'section',
                nested: false,
                exclude: ".report-body li",
                onDrop: function  (item, targetContainer, _super) {
                    self._showBannerIfReportChanged();
                    var classes = $(item).parent().attr('class').split(' ');
                    for (var i in classes) {
                        if (classes[i] === "report-sections") {
                            $(item).find( "div.report-widget" ).addClass("hide");
                            $(item).find( "div.report-section" ).removeClass("hide");
                            $(item).find('.close-section').addClass('hide');
                            $(item).find('.move-section').addClass('hide');
                        }
                    }
                    _super(item, targetContainer);
                },

                onDragStart: function ($item, container, _super) {
                    var offset = $item.offset(),
                    pointer = container.rootGroup.pointer;

                    adjustment = {
                        left: pointer.left - offset.left,
                        top: pointer.top - offset.top
                    };

                    _super($item, container);
                },

                onDrag: function ($item, position) {
                    $item.css({
                        left: position.left - adjustment.left,
                        top: position.top - adjustment.top
                    });
                }
            });
            
            $("ol.available-sections").sortable({
                group: 'section',
                drop: false,
                nested: false,
                onDragStart: function ($item, container, _super) {
                    var offset = $item.offset(),
                    pointer = container.rootGroup.pointer;

                    adjustment = {
                        left: pointer.left - offset.left,
                        top: pointer.top - offset.top
                    };

                    _super($item, container);
                },

                onDrag: function ($item, position) {
                    $item.css({
                        left: position.left - adjustment.left,
                        top: position.top - adjustment.top
                    });
                }
            });
        },

        _getAllReportSections: function(availableSections, modelData){
            availableSections.each(function() {
                var reportSectionDivId = $(this).find("div.report-section").attr('id');
                var reportSectionDivIdInProperCase = reportSectionDivId.charAt(0).toLowerCase() + reportSectionDivId.slice(1);
                modelData.unset(reportSectionDivIdInProperCase);
            });

            return modelData;
        },

        _findCountOfSelectedSections : function() {
            var selectedSections = this.$el.find("ol.report-sections li.section");
            return selectedSections.length;
        },

        _sequenceAndExtractContentFromTemplate: function(selectedSections, modelData){
            var sectionsForNewTemplate = [];
            selectedSections.each(function( index ) {
                var reportSectionDivId = $(this).find("div.report-section").attr('id');
                var reportSectionDivIdInProperCase = reportSectionDivId.charAt(0).toLowerCase() + reportSectionDivId.slice(1);
                modelData.get(reportSectionDivIdInProperCase).template.sequence=index+1;
            });
            var self = this;
            selectedSections.each(function(index){
                var reportSectionDivId = $(this).find("div.report-section").attr('id');
                var reportSectionDivIdInProperCase = reportSectionDivId.charAt(0).toLowerCase() + reportSectionDivId.slice(1);
                sectionsForNewTemplate.push(modelData.get(reportSectionDivIdInProperCase).template);
                sectionsForNewTemplate[index].id=undefined;
                sectionsForNewTemplate[index].included=true;                
                switch(reportSectionDivIdInProperCase){
                case 'commentsSection':
                    sectionsForNewTemplate[index].comment = $('#finalReportComment').val();
                    break;
                case 'disclaimerSection':
                    sectionsForNewTemplate[index].disclaimer = $('#DisclaimerSection textarea').val();
                    break;
                case 'backgroundSection':
                    sectionsForNewTemplate[index].summary = $('#BackgroundSection textarea').val();
                    break;
                case 'headerSection':
                    sectionsForNewTemplate[index].organizationAddress = $('#inputOrgAddress').val();
                    sectionsForNewTemplate[index].organizationName = $('#inputOrgName').val();
                    break;
                case 'signOffSection':
                    sectionsForNewTemplate[index].authors = modelData.get('signOffSection').section.get('authors').toJSON();
                    break;
                case 'reportedVariantsSection':
                    if(typeof self.chevronModel.get("configuration").selectedAnnotations !== typeof undefined){
                        sectionsForNewTemplate[index].selectedVariantColumns = self.chevronModel.get("configuration").selectedAnnotations;
                    }
                    break;
                }
            });

            return sectionsForNewTemplate;
        },
        
        _saveAsNewTemplate : function(){

            var orgNameIsValid = this._validateHeaderSection();
            if(this._findCountOfSelectedSections() !== undefined && this._findCountOfSelectedSections() === 0) {
                $('#error').empty();
                BannerView.show({
                    container: $('#error'),
                    style: 'error',
                    titleKey: 'Please select at least one section before proceeding',
                });
                $('.icon-loader').hide();
            }
            else if(orgNameIsValid === 'inValid'){
                $('#error').empty();
                BannerView.show({
                    container: $('#error'),
                    style: 'error',
                    titleKey: 'Please enter organization name before proceeding',
                });
                $('.icon-loader').hide();
            }
            else {
                var modal = new finalReportSaveAsModalView({
                    model : this.model,
                    el: '#finalReportSaveAsModal'
                });

                var sectionsForNewTemplate = [];               

                var availableSections = this.$el.find("ol.available-sections li.section");
                var modelData = this._getAllReportSections(availableSections, this.model.clone());

                var selectedSections = this.$el.find("ol.report-sections li.section");
                sectionsForNewTemplate = this._sequenceAndExtractContentFromTemplate(selectedSections, modelData);

                modal.render(sectionsForNewTemplate);
            }
        },

