    'hb!templates/grid/grid-column-locked.html', 'hb!templates/grid/grid-column-provided.html',
    'hb!templates/grid/annotationSet/grid-column-status.html'],
    function($, _, kendo, TemplateView, template, lockedColumnTemplate, providedColumnTemplate, gridColumnStatusTemplate) {
        var AnnotationSetDetailView = TemplateView.extend({

            template: template,

            _subTemplates: {
                locked: lockedColumnTemplate,
                provided: providedColumnTemplate,
                status: gridColumnStatusTemplate
            },

            delegateEvents: function() {
                TemplateView.prototype.delegateEvents.apply(this, arguments);
                this.listenTo(this.model, 'refresh', this.refresh);
            },

            undelegateEvents: function() {
                this.stopListening(this.model);
                TemplateView.prototype.undelegateEvents.apply(this, arguments);
            },
            render: function() {
                var self = this;
                var viewModel = _.extend(self._modelToJSON(), {
                    sub: self._subTemplates
                });
                self.$el.html(self.template(viewModel));
            },
            refresh: function() {
                var self = this;
                this.model.fetch({
                    success: function() {
                        self.render();
                    }
                });
            },
            sortNames: function (sources) {
                sources.sort(function (source1, source2) {
                    var s1 = source1.name.toLowerCase();
                    var s2 = source2.name.toLowerCase();
                    return s1.localeCompare(s2);
                });
            },
            _modelToJSON: function() {
                var json = this.model.toJSON();
                return _.defaults(_.extend(json, {
                    isLocked: json.status && json.status === 'LOCKED',
                    revision : json.annotationSetRevisionNumber,
                    creator: json.createdBy && json.createdBy.lastName + ', ' + json.createdBy.firstName,
                    createdOn: json.createdOn && kendo.toString(new Date(Date.parse(json.createdOn)), 'MMM dd yyyy hh:mm tt'),
                    lastModifiedBy : json.lastModifiedBy && json.lastModifiedBy.lastName + ', ' + json.lastModifiedBy.firstName,
                    lastModifiedOn : json.lastModifiedOn && kendo.toString(new Date(Date.parse(json.lastModifiedOn)), 'MMM dd yyyy hh:mm tt')
                }), {
                    name : '',
                    description : '',
                    creator: ''
                });
            }

        });

        return AnnotationSetDetailView;

    }
);
