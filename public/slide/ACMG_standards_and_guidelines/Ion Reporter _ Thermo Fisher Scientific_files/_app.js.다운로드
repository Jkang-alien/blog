define('views/finalreport/authorsView',['jquery',
        'underscore',
        'backbone',
        'hb!templates/finalreport/finalreport-signoff-authors.html'],
    function ($,
              _,
              Backbone,
              template) {
        

        var AuthorsView = Backbone.View.extend({

            _template: template,

            events: {
                'click .icon-arrow-up': '_onMoveAuthorUp',
                'click .icon-arrow-down': '_onMoveAuthorDown',
                'click .icon-remove': '_onDeleteAuthor',
                'keyup input[type=text]': '_onInputChanged'
            },

            delegateEvents: function () {
                Backbone.View.prototype.delegateEvents.apply(this, arguments);
                this.collection.on('add', this.render, this);
                this.collection.on('remove', this.render, this);
            },

            undelegateEvents: function () {
                this.collection.off('remove', this.render, this);
                this.collection.off('add', this.render, this);
                Backbone.View.prototype.undelegateEvents.apply(this, arguments);
            },

            render: function () {
                this.$el.html(this._template({
                    authors: this.collection.toJSON()
                }));
                return this;
            },
            
            _onInputChanged: function(e) {
                e.preventDefault();
                var $target = $(e.currentTarget),
                    index = $target.data('index'),
                    author = this.collection.at(index);
                if (author) {
                    var _property = $target.data('property');
                    var _value = $target.val().trim();
                    author.set(_property, _value);
                }
            },

            _onMoveAuthorUp: function (e) {
                e.preventDefault();
                var index = $(e.currentTarget).data('index'),
                    author = this.collection.at(index);
                if (author) {
                    this.collection.models.splice(index, 1);
                    this.collection.models.splice(Math.max(index - 1, 0), 0, author);
                    this.render();
                }
            },

            _onMoveAuthorDown: function (e) {
                e.preventDefault();
                var index = $(e.currentTarget).data('index'),
                    author = this.collection.at(index);
                if (author) {
                    this.collection.models.splice(index, 1);
                    this.collection.models.splice(index + 1, 0, author);
                    this.render();
                }
            },

            _onDeleteAuthor: function (e) {
                e.preventDefault();
                var index = $(e.currentTarget).data('index');
                this.collection.remove(this.collection.at(index));
            }

        });

        return AuthorsView;
    }
);
