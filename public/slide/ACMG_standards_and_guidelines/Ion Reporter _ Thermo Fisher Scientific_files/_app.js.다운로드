            convertTextToImage: function(text){
                var canvas = document.createElement('canvas');
                $(canvas).attr("id","tempCanvas");
                canvas.width = text.replace(/ /g,'').length * 12;
                canvas.height = 20;
                $("body").append(canvas);
                var ctx = $("#tempCanvas").get(0).getContext('2d');
                ctx.font="14px Arial";
                var itr = 4;//Single write of text in the canvas get a blurred image. Thus writing text multiple times on canvas.
                for(var i=0; i<itr; i++){
                    ctx.fillText(text,0,15);
                }
                var baseString = $("#tempCanvas").get(0).toDataURL("image/png", 1.0);
                $("#tempCanvas").remove();
                return baseString;
            },

            isDoubleByteString: function(text) {
                for (var i = 0, l = text.length; i < l; i++) {
                    if (text.charCodeAt( i ) > 255) { return true; }
                }
                return false;
            },

