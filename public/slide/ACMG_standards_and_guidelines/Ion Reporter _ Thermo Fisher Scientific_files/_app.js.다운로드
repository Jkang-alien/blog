define('views/samples/define/manual/cloudBamFileValidationView',['jquery', 'underscore', 'views/common/baseModalView', 'global', 'events/eventDispatcher', 'hb!templates/upload-bam-specimen-file.html'],
    function($, _, BaseModalView, Global, dispatcher, uploadBamFileTemplate) {

        

        var CloudBamFileValidationView = BaseModalView.extend({

            initialize: function(options) {
                options = options || {};
                this.setSelectedPath = options.setSelectedPath;
                this.checkUrl = '/ir/secure/api/v40/upload/check';
                this.sureUploadSize = 0;
                this.probableUploadSize = 0;
                this.partsLeft = [];
                this.uploaders = [];
            },

            events: {
                'click #removeFile': 'onRemove',
                'click #close': 'onHide',
                'click #cancelFileUpload': 'onHide',
                'click #upload': 'validateFile'
            },

            render: function() {
                BaseModalView.prototype.render.apply(this, arguments);
                this.partSize = parseInt($.t('bam.upload.chunkSize'), 10);

                this.$el.html(uploadBamFileTemplate());
            },

            clearExistingUpload: function() {
                var self = this;
                $.ajax({
                    url: '/ir/secure/api/v40/upload/cancelCurrentUpload',
                    type: 'GET',
                    async: false,
                    success: function() {
                        self.$el.modal('hide');
                    },
                    error: function() {
                        self.$el.modal('hide');
                        dispatcher.trigger('errorCancelingUpload');
                    }
                });
                setTimeout(function() {}, 5000);
            },

            validateFile : function() {
                var self = this;
                $(window).on('beforeunload', function(e) {
                    e.returnValue = "If you leave, your upload will be cancelled";
                    return e.returnValue;
                });
                $(window).on('unload', _.bind(self.clearExistingUpload, this));
                var files = this.$('input[type="file"]');
                this.file = files[0].files[0];
                if(typeof this.file !== typeof undefined) {
                    $.ajax({
                        url: self.checkUrl,
                        method:'GET',
                        dataType:'json',
                        contentType:"application/json; charset=utf-8",
                    }).done(function(data) {
                        if(data.success) {
                            self.$('.btn-file').hide();
                            self.$('#upload').hide();
                            self.$('#removeFile').hide();
                            self.$('#cancelFileUpload').hide();
                            self.$('#progress').show().addClass('progress-striped active');
                            self.upload();
                        } else {
                            this.$('#upload-message').text('Download is in progress. Please try again after sometime.');
                        }
                    });
                } else {
                    this.$('#upload-message').text('Please select a file to upload.');
                }
            },

            updateProgressBar: function() {
                var progress = parseInt(this.probableUploadSize / this.totalSize * 100, 10);
                this.$('#progress .bar').css('width', progress + '%');
            },

            completeMultipartUpload: function() {
                var fileDetails = {"uploadId":null,"irFileId":null,"partETag":[],"fileName":this.file.name,"fileLength":this.file.size};
                $.each(this.uploaders, function(index, element){
                    fileDetails.uploadId = element.uploadId;
                    fileDetails.irFileId = element.irFileId;
                    var etag = element.partETag.etag;
                    fileDetails.partETag.push(etag);
                });
                var self = this;
                $.ajax({
                        url: '/ir/secure/api/v40/upload/bam/cloud/complete',
                        method:'POST',
                        dataType:'json',
                        contentType:"application/json; charset=utf-8",
                        data: JSON.stringify(fileDetails),
                        success: function(data) {
                            self.$('#progress').removeClass('progress-striped active').addClass('progress-success');
                            self.$('#upload-message').text($.t('bam.upload.success'));
                            self.$('#close').show();
                            self.setSelectedPath(_.pluck(data.path, 'name'));
                            self.$('#close').click(function() {
                                self.trigger('confirm');
                            });
                        },
                        error: function() {
                            self.fail();
                        }
                    });
            },

            uploadPart: function(partNum)
            {
                if (partNum > this.numParts) {
                    this.completeMultipartUpload();
                    return;
                }

                var start = (partNum - 1) * this.partSize;
                var end = start + this.partSize;
                if (end > this.totalSize) {
                    end = this.totalSize;
                }
                var length = end - start;
                var curBlobPart = this.file.slice(start, end);
                var url = '/ir/secure/api/v40/upload/bam/cloud/start/upload'+'/'+partNum+'/'+this.file.name;
                var data = new FormData();
                data.append('file', curBlobPart);
                data.append('uploadId', this.sendBackData.uploadId);
                data.append('irFileId', this.sendBackData.irFileId);
                var self = this;
                $.ajax({
                    url :  url,
                    type: 'POST',
                    data: data,
                    contentType: false,
                    processData: false,
                    success: function(data) {
                        self.sureUploadSize = length;
                        self.probableUploadSize = self.probableUploadSize + self.sureUploadSize;
                        self.updateProgressBar();
                        self.uploaders.push(data);
                        self.uploadPart(partNum + 1);
                    },
                    error: function() {
                        self.fail();
                    }
                });
            },

            startPartitionAndUpload: function() {
                this.updateProgressBar();
                this.numParts = Math.ceil(this.totalSize / this.partSize);
                this.uploadPart(1);
            },

            upload: function() {
                if (window.File && window.FileReader && window.FileList && window.Blob && window.Blob.prototype.slice) {
                    this.totalSize = this.file.size;
                    var self = this;
                    $.ajax({
                        url: '/ir/secure/api/v40/upload/bam/cloud/initiate',
                        method:'POST',
                        dataType:'json',
                        contentType:"application/json; charset=utf-8",
                        data: JSON.stringify({
                            "fileName": self.file.name,
                            "fileType": self.file.type,
                            "fileLength": self.file.size,
                            "lastModifiedDate": self.file.lastModifiedDate
                        }),
                        success: function(data) {
                            self.sendBackData = data;
                            self.startPartitionAndUpload();
                        },
                        error: function() {
                            self.fail();
                        }
                    });
                } else {
                    this.$('#upload-message').text('The File APIs are not fully supported in this browser.');
                }
            },

            onHide: function(e) {
                e.preventDefault();
                this.$el.modal('hide');
                $(window).off('unload');
                $(window).off('beforeunload');
            },

            fail: function() {
                this.$('#progress').removeClass('progress-striped active').addClass('progress-danger');
                this.$('#progress .bar').css('width', '100%');
                this.$('#close').show();
                $(window).off('unload');
                $(window).off('beforeunload');
                return false;
            }
        });

        return CloudBamFileValidationView;
    });
