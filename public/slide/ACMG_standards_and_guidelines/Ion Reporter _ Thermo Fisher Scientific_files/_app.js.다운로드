                    scrollable: false,
                    columns: this._makeColumns()
                });

                this.renderGrid();
                this._enableDisableShareButton();
                return this;
            },

            renderGrid: function() {
                var kendoGrid = this.$el.find("#shareAnalysisGrid").data("kendoGrid");

