                    defaultColumns:this.defaultColumns
                };
            this.AnalysisColumnsSelectView.setElement('#analysis-column-select').render(analysisColumnOptions);
        },

        setCurrentTheme: function (currentTheme) {
            this.currentTheme = currentTheme;
            return this;
        },

        render : function() {

            this.$el.html(template({
                data: this.data,
                annotationClassification: this.annotationClassification,
                empty: !this.currentTheme,
                currentTheme: this.currentTheme
            }));
            return this;
        }
    });
    return GridActionsView;
