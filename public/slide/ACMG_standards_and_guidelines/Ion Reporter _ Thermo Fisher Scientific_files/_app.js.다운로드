        _mergeGridConfig: function(fetchedGridConfig, existingCols) {
            var self = this;
            var newGridConfig = this._applyTemplate(fetchedGridConfig, existingCols);
            var themeData = JSON.parse(fetchedGridConfig.themeData.themeData ? fetchedGridConfig.themeData.themeData : fetchedGridConfig.themeData);
            var dataSource = themeData.dataSource;
            newGridConfig.columns = _.reject(newGridConfig.columns, function (column) {
                _.each(existingCols, function(existingCol){
                    if(!_.isUndefined(existingCol.field) &&
                        !_.isUndefined(column.field) &&
                        (existingCol.field === column.field)){
                        return true;
                    }
                });
            });
            var extraCols = _.chain(existingCols)
                .reject(function(existingCol) {
                    return _.find(newGridConfig.columns, function(column) {
                        return column.field === existingCol.field;
                    });
                })
                .groupBy(function(extraCol) {
                    return _.contains(self._plugin._staticColumns, extraCol.field);
                }).value();

            _.each(extraCols['true'], function(frontCol, index) {
                newGridConfig.columns.splice(index + 1, 0, frontCol);
            });
            _.each(newGridConfig.columns, function(column){
                if(!_.isUndefined(column) && !_.isUndefined(column.field)){
                    if(_.contains(DATE_COLUMNS, column.field) && _.isUndefined(column.template)) {
                        column.template = gridColumnDateTemplate.forField(column.field);
                    } else if(TEMPLATES[column.field]) {
                        column.template = TEMPLATES[column.field];
                    } else if(column.field.indexOf('specimenGroup.specimen.attributeValueMap') === 0 || column.field.indexOf('ATTRIBUTE_CUSTOM') === 0) {
                        column.template = self._fetchTemplate(column);
                    } else if((column.field.indexOf('workflow.') === 0 ||
                        column.field.indexOf('specimenGroup.') === 0 || column.field.indexOf('fullName') > -1 || column.field.indexOf('plugins') === 0) && _.isUndefined(column.template)){
                        if(column.field === 'specimenGroup.specimen.metadata.Run Date') {
                            column.template = gridColumnMetadataDateTemplate.withFilter(function(ctx) {
                                return {'date': new Analysis(ctx.toJSON()).getAttribute(column.field, 1)};
                            });
                        } else {
                            column.template = gridColumnValuesTemplate.withFilter(function(ctx) {
                                return {
                                    names: new Analysis(ctx.toJSON()).getAttribute(column.field,1)
                                };
                            });
                        }
                    }
                }
            });

            this._columns = function() {
                return newGridConfig.columns;
            };

            if(dataSource){
                newGridConfig.dataSource._sort = dataSource._sort;
            }
            return newGridConfig;
        },

        _fetchTemplate: function(column) {
            var columnTemplate;
            columnTemplate = gridColumnValuesTemplate.withFilter(function(ctx) {
                var attrValues = [];
                var attrVal;
                var context = ctx.toJSON();
                if(!_.isUndefined(context.specimenGroup) && _.isArray(context.specimenGroup.members)){
                    _.each(context.specimenGroup.members, function(specimen){
                        _.each(specimen.specimen.attributes, function(attr) {
                            if(attr.attribute.name === column.name && attr.attribute.factoryProvided === column.factoryProvided){
                                attrVal = {};
                                attrVal.name = attr.value;
                                attrValues.push(attrVal);
                            }
                        });
                    });
                }
                var templObj = {};
                templObj.names = attrValues;
                return templObj;
            });
            return columnTemplate;
        },

        _grid: function() {
            return this.$el.data('kendoGrid');
        },

        getState: function() {
            var grid = this._grid();
            return grid && {
                page: grid.dataSource.page(),
                pageSize: grid.dataSource.pageSize(),
                sort: grid.dataSource.sort()
            } || {};
        },

        setState: function(state) {
            var grid = this._grid();
            if (grid) {
                grid.dataSource.query(state);
            }
        },

        _onOpenErrorLog: function(e) {
            var analysisId = $(e.currentTarget).attr('data-id');
            BaseModalView.open($.noop, {id : analysisId}, AnalysisErrorLogFileModalView);
        },

        _onOpenRestoreErrorLog: function(e) {
            var analysisId = $(e.currentTarget).attr('data-id');
            BaseModalView.open($.noop, {id : analysisId}, AnalysisRestoreErrorLogFileModalView);
        },

        _onOpenArchiveErrorLog: function(e) {
            var analysisId = $(e.currentTarget).attr('data-id');
            BaseModalView.open($.noop, {id : analysisId}, AnalysisArchiveErrorLogFileModalView);
        }

    });

    return AnalysisGridView;

});

