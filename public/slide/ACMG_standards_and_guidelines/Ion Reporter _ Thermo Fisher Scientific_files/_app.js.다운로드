                else if(typeof($(e.currentTarget).attr('data-variant-annotation-id') ) === 'undefined') {
                    if($(e.currentTarget).prop('checked') === false) {
                        $($('table').find('.notesTableSelectAll[data-variant-id="' + currentVariantId + '"]')).prop('checked', false);
                    }
                }
            }
        },

        _getPopTitle: function(target){
            return $("#" + target + "_content > div.popTitle").html();
        },

        _getPopContent: function(target){
            return $("#" + target + "_content > div.popContent").html();
        },

        _initializeQuickView: function(){
            var self = this;

            $(".quickview").each(function() {
                var $elem= $(this);
                $elem.popover({
                    html: true,
                    placement: "left",
                    trigger: "hover",
                    title: self._getPopTitle($elem.attr("id")),
                    content: self._getPopContent($elem.attr("id"))
                });
            });

            $(".report-widget").hover(function(){
                $(this).find(".quickview").removeClass("hide");
                $(this).addClass("widget-hover");
            }, function(){
                $(this).find(".quickview").addClass("hide");
                $(this).removeClass("widget-hover");
            });
        },

        _onAddAuthor: function(e) {
            e.preventDefault();
            var authors = this.model.get('signOffSection').section.get('authors'),
              name = this.$('#name-text').val().trim(),
              qualification = this.$('#qualification-text').val().trim();

            if (name.length && qualification.length) {
                authors.add({
                    name : name,
                    qualification : qualification
                });
                this.$('#name-text').val('');
                this.$('#qualification-text').val('');
                this.model.trigger('change');
            }
        },

        _replaceLineBreaks: function (str) {
            return str.replace(/(\r\n|\n|\r)/gm, "<br>");
        },

        _captureTitleContent : function() {
            if(this.model.get('title')){
                this.model.set('title', $('#reportTitleIdentifier').text());
