define('views/analysis/analysisShareModalView',['jquery',
    'i18n',
    'underscore',
    'backbone',
    'kendo',
    'views/formView',
    'models/analysis/sharedAnalysisModel',
    'collections/sharing/sharedWithCollection',
    'views/common/bannersView',
    'hb!templates/grid/grid-column-icon-header.html',
