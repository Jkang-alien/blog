                this.cb()
                .field('variable')
                .headerTemplate(GridColumnHeader({
                    title: 'Variable'
                }))
                .sortable(true)
                .width('45px')
                .build(),
                this.cb()
                .field('joining')
                .headerTemplate(GridColumnHeader({
                    title: 'Joining'
                }))
                .width('45px')
                .sortable(true)
                .build(),
                this.cb()
                .field('cdr_aa')
                .headerTemplate(GridColumnHeader({
                    title: 'CDR3 AA'
                }))
                .sortable(true)
                .width('75px')
                .build(),
                this.cb()
                .field('cdr_nt')
                .headerTemplate(GridColumnHeader({
                    title: 'CDR3 NT'
                }))
                .width('140px')
                .sortable(true)
                .build()
            ];
        },

        _updateDisplayedColumns: function(){
            var samplesList = this.samples;
            var self =this;
            var i =0;
            var col = [].concat(self._deaultColumns(), _.map(samplesList, function(key) {
                var keyName = "frequency" + i;
                i = i + 1;
                var title = key + " Frequency";
                return self.cb()
                .field(keyName)
                .headerTemplate(GridColumnHeader({
                    title: title
                }))
                .sortable(true)
                .width('50px')
                .build();
            }));

            return col;

        },

        _parseResponse: function(response) {
            var page = response,
                self = this;
            page.content = _.map(page.content, function(item) {
                var currentItem = item;
                var i =0;
                _.map(self.samples, function() {
                    var keyName = "frequency" + i;
                    i = i + 1;
                    currentItem[keyName] = currentItem.sampleFrequencyMap[keyName];
                });

                return currentItem;
            });

            return page;
        },

        _onTooltipMouseenter: function(e) {
            var target = $(e.currentTarget),
                offset = target.width()/2,
                left = parseInt($('.tooltip.in').css('left'),10);
            if (target.position().left > 100) {
                $('.tooltip.in').css('left', left - offset + 'px');
            } else {
                $('.tooltip.in').css('left', left + offset + 'px');
            }
        }
    });

    return MultiSampleGridView;
});

