define('views/variants/variantsHeadingView',['jquery',
        'underscore',
        'models/specimen',
        'views/templateView',
        'hb!templates/variants/variants-heading-detailed.html',
        'hb!templates/variants/variants-heading-metagenomics.html',
        'hb!templates/variants/liquidbiopsy-variants-heading-detailed.html'
        ],
        function($,
                _,
                Specimen,
                TemplateView,
                variantsHeadingTemplate,
                variantsHeadingMetagenomicsTemplate,
                variantsHeadingLiquidBiopsyTemplate) {

    

    var VariantsHeadingView = TemplateView.extend({

        _template: variantsHeadingTemplate,

        initialize: function(options) {
            this.analysis = options.analysis;
            this.isDnaRna = (this.analysis.get('applicationType') === 'DNA_RNA');
            this.isDna = (this.analysis.get('applicationType') === 'DNA');
            this.isRna = (this.analysis.get('applicationType') === 'RNA');
            this.isAneuploidy = (this.analysis.get('applicationType') === 'ANEUPLOIDY');
            this.isMetagenomics = (this.analysis.get('applicationType') === 'METAGENOMICS');
            this.isLiquidBiopsy = (this.analysis.get('applicationType') === 'ONCOLOGY_LIQUID_BIOPSY');
            this.sampleId = options.sampleId;

            if(this.analysis.get('brcaAnalysis') && this.analysis.get('brcaAnalysis').sampleFailedCNVQC) {
                this.sampleFailedCNVQC = this.analysis.get('brcaAnalysis').sampleFailedCNVQC.split(":");
            }
            this.metricsUrl = '/ir/secure/api/v40/analysis/' + this.analysis.id + '/qcanalysismetrics';
            this.consensusMetricsUrl = '/ir/secure/api/v40/analysis/' + this.analysis.id + '/consensusmetrics';
            if (this.isDnaRna || this.isDna || this.isRna) {
                this._setCancerType();
            } else if (this.isMetagenomics) {
                this._template = variantsHeadingMetagenomicsTemplate;
            }
        },

        render: function() {
            var self = this;
            var chrMRatio = self.analysis.get('mDNAToAutosomalDNARatio');
            var templateOptions = {
                    name: self.analysis.get('name'),
                    applicationType: self.analysis.get('applicationType'),
                    calledGender: self.analysis.get('calledGender'),
                    mDNAToAutosomalDNARatio: (chrMRatio !== undefined && chrMRatio !== 0) ?
                        chrMRatio.toExponential(2):chrMRatio
                };                
            if (this.cancerType) {
                templateOptions.cancerType = this.cancerType;
            }
            if(this.sampleId !== '') {
                templateOptions.sampleId = this.sampleId;
            }
            $.get(self.metricsUrl).done(function(data) {
                var qcMetrics = data;
                if (!this.isMetagenomics) {
                    templateOptions.mapd = qcMetrics.mapd ? parseFloat(qcMetrics.mapd).toFixed(3) : '';
                }                
                if (self.isDnaRna || self.isRna) {
                    templateOptions.rnaReadCounts = qcMetrics.geneFusionMappedReadCounts;
                    templateOptions.fusionQC = qcMetrics.fusionQC;
                    templateOptions.fusionQCDetail = qcMetrics.fusionQCDetail;
                    templateOptions.fusionOverallCall = qcMetrics.fusionOverallCall;
                    templateOptions.fusionOverallCallDetail = qcMetrics.fusionOverallCallDetail;
                    templateOptions.mappedFusionReadsPool1 = qcMetrics.mappedFusionReadsPool1;
                    templateOptions.mappedFusionReadsPool2 = qcMetrics.mappedFusionReadsPool2;
                    templateOptions.mappedFusionReadsPool1andPool2 = qcMetrics.mappedFusionReadsPool1andPool2;
                    templateOptions.totalUnmappedReads = qcMetrics.totalUnmappedReads;
                    templateOptions.averageReadLength = qcMetrics.averageReadLength;
                    templateOptions.processControlsTotalReads = qcMetrics.processControlsTotalReads;
                    templateOptions.allRNAProcCntrlsDetected = qcMetrics.allRNAProcCntrlsDetected;
                }
                templateOptions.sampleFailedCNVQC = self.sampleFailedCNVQC;

                self.$el.html(self._template(templateOptions));
                $('div[data-toggle="tooltip"]').tooltip({placement: 'bottom'});
                if (self.isDnaRna || self.isRna) {
                    self.$('#rnaQC').tooltip({placement: 'bottom'});
                    self.$('#overallQC').tooltip({placement: 'bottom'});
                }
            });

            if (self.isLiquidBiopsy) {
                $.get(self.consensusMetricsUrl).done(function(data) {
                        $('#variants-heading-ocp').append(variantsHeadingLiquidBiopsyTemplate(data));
                    });
            }

            return this;
        },
        
        _setCancerType: function() {
            var memberKeys = ['DNA_FUSION', 'SINGLE_RNA_FUSION', 'SAMPLE'];
            
            var member = this.analysis.get('specimenGroup').get('members').find(function(m){
                return _.contains(memberKeys, m.get('role'));
            });
            if (member) {
                this.cancerType = new Specimen(member.get('specimen')).cancerType();
            }  else {
                memberKeys = ['PROBAND', 'TUMOR'];
                member = this.analysis.get('specimenGroup').get('members').find(function(m){
                    return _.contains(memberKeys, m.get('role'));
                });
                
                if (member) {
                    this.cancerType = member.get('specimen').attributeValueMap['Cancer Type'];
                }
            }
        }

    });

    return VariantsHeadingView;
});
