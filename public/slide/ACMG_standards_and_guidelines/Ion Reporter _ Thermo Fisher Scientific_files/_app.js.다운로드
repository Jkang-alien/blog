lass="fusionPanel">\n                <div class="row-fluid">\n                    <div class="span4 text-right">\n                        <label for="fusionPanelDiv">{{t \'workflow.fusion.panel.label\'}}:</label>\n                    </div>\n                    <div class="span8">\n                        <div id="fusionPanelDiv" class="row-fluid input-xlarge custom-region-container">\n                            <!-- templates/workflow-fusion-panel.html -->\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class="row-fluid">\n                <div class="span4"></div>\n                <div class="span8">\n                    <a id="uploadFusionPanel" href="#"\n                       title="{{t \'workflow.fusionpanel.file.upload.title\'}}" class="btn btn-small"><i class="icon icon-upload"></i> {{t \'upload.label\'}}</a>\n                    &nbsp;\n                    <a id="importFromFusionAmpliseq" href="javascript:void(0)" data-toggle="modal"\n                       title="{{t \'import.fusion.ampliseq.title\'}}" class="btn btn-small"><i class="icon-download-alt"></i> {{t \'import.ampliseq.label\'}}</a>\n                    <div id="uploadFusionPanelFile">\n                        <!-- templates/upload-fusionpanel-file.html -->\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n';});
define('views/reference',['jquery', 'underscore', 'data/workflow', 'views/ParentView', 'views/referenceGenomes', 'views/targetRegions',
        'views/targetRegionTypes', 'views/hotspotRegions', 'views/ampliseqImportView', 'views/fusionAmpliseqImportView', 'views/ampliseqConfigurationView',
        'views/targetRegionFileValidationView', 'views/hotspotRegionFileValidationView',
        'views/fusionPanelFileValidationView', 'views/fusionPanelView', 'views/common/bannersView',
        'collections/humanReferenceGenomes', 'collections/referenceGenomes', 'collections/targetRegions', 'collections/targetRegionTypes',
        'collections/hotspotRegions', 'collections/fusionPanels', 'hb!templates/workflow-reference.html', 'models/referenceGenome', 'events/eventDispatcher'],
    function ($, _, Constants, ParentView, ReferenceGenomesView, TargetRegionsView, TargetRegionTypesView,
              HotSpotRegionsView, AmpliseqImportView, FusionAmpliseqImportView, AmpliseqConfigurationView, TargetRegionFileValidationView,
              HotspotRegionFileValidationView, FusionPanelFileValidationView, FusionPanelView, BannerView,
              ReferenceGenomesTypeCollection,ReferenceGenomesCollection, TargetRegionsCollection, TargetRegionTypesCollection,
              HotSpotRegionsCollection, FusionPanelCollection, template, ReferenceGenomeModel,dispatcher) {

    

    var TYPES = _.object(_.keys(Constants.ApplicationTypes), _.keys(Constants.ApplicationTypes));
    var GROUPS = _.object(_.keys(Constants.SpecimenGroups), _.keys(Constants.SpecimenGroups));
    var listOfReferences = [];
    var referencePromiseResponse;
    var hg19NodeId;
    var currentModelName, referenceGenomePromise;
            
    var ReferenceView = ParentView.extend({
        initialize: function() {

            if(this.model.get('applicationType').toLowerCase() === 'metagenomics') {
                this.referenceGenomes = new ReferenceGenomesCollection();
            }
            else {
                this.referenceGenomes = new ReferenceGenomesTypeCollection();
            }
            this.referenceGenomeView = new ReferenceGenomesView({
                collection: this.referenceGenomes,
                model: this.model
            });

            this.targetRegions = new TargetRegionsCollection();
            this.targetRegionsView = new TargetRegionsView({
                collection: this.targetRegions,
                model: this.model
            });

            this.hotSpotRegions = new HotSpotRegionsCollection();
            this.hotSpotRegionsView = new HotSpotRegionsView({
                collection: this.hotSpotRegions,
                model: this.model,
                tagName: "select"
            });

            this.fusionPanels = new FusionPanelCollection();
            this.fusionPanelView = new FusionPanelView({
                collection: this.fusionPanels,
                model: this.model
            });

            this._ampliseqImportView = new AmpliseqImportView();
            this._fusionAmpliseqImportView = new FusionAmpliseqImportView();
            this.ampliseqConfigurationView = new AmpliseqConfigurationView({
                model: this.model
            });
        },

        events: {
            'click input[name="variantTypeDetection"]' : '_variantTypeDetectionChangeHandler',
            'click #uploadCustomRegion' : '_displayUploadTargetRegions',
            'click #uploadCustomHotspot' : '_displayUploadHotspotRegions',
            'click #uploadFusionPanel' : '_displayUploadFusionPanel',
            'click #importFromAmpliseq' : '_importFromAmpliseqHandler',
            'click #importFromFusionAmpliseq' : '_importFromFusionAmpliseq',
            'change input[name="references"]' : '_loadContentOfUpdatedReference',
            'change select#references': '_loadContentOfUpdatedReference'
        },
        
        delegateEvents: function() {
            ParentView.prototype.delegateEvents.apply(this, arguments);
            this.listenTo(this.referenceGenomes, 'sync', this.selectSingle);
            this.listenTo(this._ampliseqImportView, 'targetRegionAdded', this._targetRegionAdded);
            this.listenTo(this._fusionAmpliseqImportView, 'targetRegionAdded', this._fusionPanelAdded);
            this.listenTo(this.model, 'change', this._displayVariantTypeDetection);
        },
        
        undelegateEvents: function() {
            this.stopListening(this.model);
            this.stopListening(this._ampliseqImportView);
            this.stopListening(this._fusionAmpliseqImportView);
            this.stopListening(this.referenceGenomes);
            ParentView.prototype.undelegateEvents.apply(this, arguments);
        },

        render: function() {
            if(this.model.get('applicationType').toLowerCase() === 'metagenomics'){
                referenceGenomePromise = this.referenceGenomes.fetch({ 'type' : 'POST','reset' : true,async : false,'data' : JSON.stringify(this.model), 'dataType' : "json", 'contentType' : 'application/json' });
            }
            else {
                referenceGenomePromise = this.referenceGenomes.fetch({ 'type' : 'GET','reset' : true,async : false, 'data' : {referenceGenomeType : 'Human'}, 'dataType' : "json",});
            }
            hg19NodeId = null;
            referencePromiseResponse = referenceGenomePromise;
            if(this.model.get('applicationType').toLowerCase() !== 'metagenomics') {
                if(this.model.get('referenceGenome') === undefined) {
                    if(referenceGenomePromise.responseText){
                        listOfReferences = JSON.parse(referenceGenomePromise.responseText);
                    }
                    for(var i = 0 ; i < listOfReferences.length; i++){
                        if(listOfReferences[i].name.toLowerCase() === 'hg19'){
                            var obj = {'id' : listOfReferences[i].id, 'name' : listOfReferences[i].name};
                            this.model.set('referenceGenome', obj);
                            hg19NodeId = '#'+listOfReferences[i].name;
                            this._setReferenceGenome(listOfReferences[i].id, listOfReferences[i].name);
                        }
                    }
                }
                else {
                    if(referenceGenomePromise.responseText){
                        listOfReferences = JSON.parse(referenceGenomePromise.responseText);
                    }
                    currentModelName = '#'+this.model.get('referenceGenome').name;
                }
            }
            var targetRegionsPromise;
            var hotSpotRegionsPromise;
            if (this.model.isTargetRegionSelectable()){
                targetRegionsPromise = this.targetRegions.getAllowedSynchronically(this.model);
                hotSpotRegionsPromise = this.hotSpotRegions.getAllowedSynchronically(this.model);
            }

            var fusionPanelsPromise;
            if (this.model.isFusionPanelSelectable()) {
                fusionPanelsPromise = this.fusionPanels.getAllowedSynchronically(this.model);
            }

            var combinedRequest = $.when(referenceGenomePromise, targetRegionsPromise, hotSpotRegionsPromise,
                fusionPanelsPromise);

            combinedRequest.done(_.bind(this._renderReferenceGenomes, this));
            if(this.model.get('referenceGenome') !== undefined && this.model.get('referenceGenome').id !== undefined) {
                this._setReferenceGenome(this.model.get('referenceGenome').id, this.model.get('referenceGenome').name);
            }
            if(this.model.get('applicationType').toLowerCase() === 'oncology_liquid_biopsy') {
                this._handleLiquidBiopsyVariantTypeDetection();
            }
            return this;

        },

        _renderReferenceGenomes: function() {
            this.$el.html(template({
                helpMsgKey: this._getHelpMsg(),
                typedetectionReadonly: !this.model.isNew() && this.model.isVariantTypeDetectionSelectable(),
                applicationType: this.model.getApplicationType()
            }));

            this.renderSubView(this.referenceGenomeView, "#referenceDiv");

            this._displayRegions();
            this._displayFusionPanels();
            this._displayVariantTypeDetection();
            if(hg19NodeId !== null) {
                $(hg19NodeId).prop("checked", true);
            }
            else {
                $(currentModelName).prop("checked", true);
            }
        },

        selectSingle : function() {
            if (this.referenceGenomes.length === 1) {
                var existing = this.model.getReferences();
                if (!existing || existing.models[0].id !== this.referenceGenomes.models[0].id) {
                    this.model.setReferences(this.referenceGenomes);
                }
            }
        },

        _targetRegionAdded: function (e) {
            this.targetRegions.add(e.targetRegion);
            this.targetRegionsView.setSelected(e.targetRegion);
            this.hotSpotRegions.getAllowed(this.model);
            this.ampliseqConfigurationView.render();
            this._createBannerViewWithMessage('import.ampliseq.fixedPanel.success').render();
        },

        _fusionPanelAdded: function (e) {
            this.fusionPanels.add(e.fusionPanel);
            this.fusionPanelView.setSelected(e.fusionPanel);
            this._createBannerViewWithMessage('import.ampliseq.fixedPanel.success').render();
        },

        _getHelpMsg : function() {
            switch(this.model.getApplicationType()) {
            
            case TYPES.DNA:
                if (this.model.getSpecimenGroup() === GROUPS.SINGLE) {
                    return 'workflow.reference.dna.single.help';
                } else {
                    return 'workflow.reference.dna.other.help';
                }
                break;
            case TYPES.METAGENOMICS:
                return 'workflow.reference.metagenomics.help';
            case TYPES.DNA_RNA:
                return 'workflow.reference.dna.rna.fusions.help';
            case TYPES.RNA:
                return 'workflow.reference.rna.fusions.help';
            case TYPES.ANNOTATE_VARIANTS:
                return 'workflow.reference.aneuploidy.annotate.help';
            case TYPES.ANEUPLOIDY:
                return 'workflow.reference.aneuploidy.annotate.help';
            default:
                return 'workflow.reference.default.help';
            }
        },

        _displayRegions : function() {
            if (this.model.isTargetRegionSelectable()) {
                this.renderSubView(this.targetRegionsView, "#regionsDiv");
                this.renderSubView(this.hotSpotRegionsView, "#hotspotsDiv");
                this.renderSubView(this.ampliseqConfigurationView, "#selectRegionConfiguration");
                this._ampliseqImportView.render(this.model.get('referenceGenome'));
                this.$('#region').show();
            } else {
                this.$('#region').hide();
            }
        },

        _displayFusionPanels : function() {
            if (this.model.isFusionPanelSelectable()) {
                this.renderSubView(this.fusionPanelView, "#fusionPanelDiv");
                this._fusionAmpliseqImportView.render(this.model.get('referenceGenome'));
                this.$('#fusionPanels').show();
            } else {
                this.$('#fusionPanels').hide();
            }
        },

        _displayVariantTypeDetection : function() {
            if (this.model.isVariantTypeDetectionSelectable()) {
                var variantTypeDetection = this.model && this.model.getVariantTypeDetection() || null;
                var variantTypeDetectionBtnGroup = this.$(':radio[name="variantTypeDetection"]');
                if (variantTypeDetection) {
                    variantTypeDetectionBtnGroup.filter('[value="' + variantTypeDetection + '"]').prop('checked', true);
                } else {
                    variantTypeDetectionBtnGroup.prop('checked', false);
                }
                if (!this.model.isNew() && this.model.has('variantTypeDetection')) {
                    this.$('#variantTypeDetection').addClass('readonly');
                    this.$('#variantTypeDetection input:radio').attr('disabled', true);
                }
                this.$('#variantTypeDetection').show();
            } else {
                this.$('#variantTypeDetection').hide();
            }
        },

        _variantTypeDetectionChangeHandler : function(e) {
            var variantCaller = $(e.currentTarget).val();
            this.model.setVariantTypeDetection(variantCaller);
        },

        _createBannerViewWithMessage: function (messageKey) {
            return new BannerView({
                id: 'success-banner',
                container: $('.main-content>.container-fluid'),
                style: 'success',
                title: $.t(messageKey)
            });
        },

        _displayUploadTargetRegions: function(e) {
            e.preventDefault();
            var self = this;
            TargetRegionFileValidationView.open(function() {
                self.targetRegions.getAllowedSynchronically(self.model,
                    function(){self.targetRegionsView.setSelected(self.uploadedFile);}
                );
                self._createBannerViewWithMessage('targetRegion.file.upload.success').render();
            }, {
                model: self.model,
                onUploadSuccess: function(uploadedFile) {self.uploadedFile = uploadedFile;}
            });

        },

        _displayUploadHotspotRegions: function(e) {
            e.preventDefault();
            var self = this;
            HotspotRegionFileValidationView.open(function() {
                self.hotSpotRegions.getAllowedSynchronically(self.model,
                    function(){self.hotSpotRegionsView.setSelected(self.uploadedFile);}
                );
                self._createBannerViewWithMessage('hotspot.file.upload.success').render();
            }, {
                model: self.model,
                onUploadSuccess: function(uploadedFile) {
                    self.uploadedFile = uploadedFile;
                }
            });
        },

        _displayUploadFusionPanel: function(e) {
            e.preventDefault();
            var self = this;
            FusionPanelFileValidationView.open(function() {
                self.fusionPanels.getAllowed(self.model,
                    function(){self.fusionPanelView.setSelected(self.uploadedFile);}
                );
                self._createBannerViewWithMessage('fusionpanel.file.upload.success').render();
            }, {
                model: self.model,
                onUploadSuccess: function(uploadedFile) {self.uploadedFile = uploadedFile;}
            });
        },

        _importFromAmpliseqHandler : function(e) {
            e.preventDefault();
            if (this._ampliseqImportView.isModalVisible() === false) {
                this._ampliseqImportView.$el.find('#ajaxerror').hide();
                this._ampliseqImportView.$el.find("#customPanelsListContainer").remove();
                this._ampliseqImportView.showModal();
            }
        },

        _importFromFusionAmpliseq : function(e) {
            e.preventDefault();
            if (this._fusionAmpliseqImportView.isModalVisible() === false) {
                this._fusionAmpliseqImportView.$el.find('#ajaxerror').hide();
                this._fusionAmpliseqImportView.$el.find("#customPanelsListContainer").remove();
                this._fusionAmpliseqImportView.showModal();
            }
        },

        _loadContentOfUpdatedReference : function(e) {
            var obj = {};

            this._unsetAttributes();
            dispatcher.trigger('disable:chevron');
            if(!this.model.isNew() && !this.model.isVariantTypeDetectionSelectable()) {
                this._createInfoBannerViewWithMessage('workflow.presets.reset').render();
            }

            for(var i = 0 ; i < listOfReferences.length; i++){
                if(listOfReferences[i].id === $(e.currentTarget).attr('value')) {
                    obj = {'id' : $(e.currentTarget).attr('value'), 'name' : listOfReferences[i].name};
                }
            }
            this.model.set('referenceGenome', obj);

            this._fetchTargetRegions();
            this._fetchHotSpotRegions();
            this._fetchFusionPanels();

            this._displayRegions();
            this._displayFusionPanels();
            this._displayVariantTypeDetection();
            $(e.currentTarget).prop("checked", true);
            this._setReferenceGenome($(e.currentTarget).attr('value'), $(e.currentTarget).attr('id'));
            $('#nextStep').addClass('disabled');
            this._handleAneuploidyAndAnnotateApplication(this.model.get('applicationType').toLowerCase());
        },

        _fetchTargetRegions: function() {
            var targetRegionsPromise;
            if (this.model.isTargetRegionSelectable()){
                targetRegionsPromise = this.targetRegions.getAllowedSynchronically(this.model);
            }
        },

        _fetchHotSpotRegions: function() {
            var hotSpotRegionsPromise;
            if (this.model.isTargetRegionSelectable()){
                hotSpotRegionsPromise = this.hotSpotRegions.getAllowedSynchronically(this.model);
            }
        },

        _fetchFusionPanels: function() {
            var fusionPanelsPromise;
            if (this.model.isFusionPanelSelectable()) {
                fusionPanelsPromise = this.fusionPanels.getAllowedSynchronically(this.model);
            }
        },

        _setReferenceGenome : function(id, name){
            var refModel = new ReferenceGenomeModel();
            refModel.set({'id' : id, 'name' : name});
            var referenceGenomes = null;
            referenceGenomes = new ReferenceGenomesCollection();
            referenceGenomes.add(refModel);
            this.model.setReferences(referenceGenomes);
        },

        _unsetAttributes: function() {
            if(this.model.get('annotationSet') !== undefined) {
                this.model.unset('annotationSet');
            }
            if(this.model.get('myVariantDBs') !== undefined) {
                this.model.unset('myVariantDBs');
            }
            if(this.model.get('filterChain') !== undefined) {
                this.model.unset('filterChain');
            }
            if(this.model.get('reportTemplate') !== undefined) {
                this.model.unset('reportTemplate');
            }
            if(this.model.get('plugins') !== undefined) {
                this.model.unset('plugins');
            }
            if(this.model.get('baseline') !== undefined) {
                this.model.unset('baseline');
            }
            if(this.model.get('modules') !== undefined) {
                this.model.unset('modules');
            }
            if(this.model.get('targetRegion') !== undefined) {
                this.model.unset('targetRegion');
            }
            if(this.model.get('hotspotRegion') !== undefined) {
                this.model.unset('hotspotRegion');
            }
            if(this.model.get('fusionPanel') !== undefined) {
                this.model.unset('fusionPanel');
            }

        },

        _handleAneuploidyAndAnnotateApplication: function(applicationName) {
            if(applicationName === 'aneuploidy' || applicationName === 'annotate_variants') {
                $('#nextStep').removeClass('disabled');
            }
        },

        _handleLiquidBiopsyVariantTypeDetection: function() {
            $('input[name="variantTypeDetection"]').click();
        },

        _createInfoBannerViewWithMessage: function (messageKey) {
            return new BannerView({
                id: 'success-banner',
