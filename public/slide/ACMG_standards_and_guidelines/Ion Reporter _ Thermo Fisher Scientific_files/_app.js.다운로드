                var filterNameRegexForORPre = new RegExp(' OR \\s*' + filter_name + '$');
                var filterNameRegexForORPreAND = new RegExp(' OR \\s*' + filter_name +' \\s*AND ');
                var filterNameRegexForORPreOR = new RegExp(' OR \\s*' + filter_name +' \\s*OR ');
                var filterNameRegexForORPrePAR = new RegExp(' OR \\s*' + filter_name +'\\s*\\)');

                var filterNameRegexForAnd = new RegExp( filter_name + ' \\s*AND ');
                var filterNameRegexForAndPAR = new RegExp('\\(\\s*' + filter_name + ' \\s*AND ');

                var filterNameRegexForOR = new RegExp( filter_name + ' \\s*OR ');
                var filterNameRegexForORPAR = new RegExp('\\(\\s*' + filter_name + ' \\s*OR ');

                if(!(queryString.search(filterNameRegexForAndPreAND) !== -1 || queryString.search(filterNameRegexForAndPreOR) !== -1 ||
                        queryString.search(filterNameRegexForAndPrePAR) !== -1 || queryString.search(filterNameRegexForORPreAND) !== -1 ||
                        queryString.search(filterNameRegexForORPreOR) !== -1 || queryString.search(filterNameRegexForORPrePAR) !== -1 ||
                        queryString.search(filterNameRegexForAnd) !== -1 || queryString.search(filterNameRegexForAndPAR) !== -1 ||
                        queryString.search(filterNameRegexForOR) !== -1 || queryString.search(filterNameRegexForORPAR) !== -1 ||
                        queryString.search(filterNameRegexForAndPre) !== -1 || queryString.search(filterNameRegexForORPre) !== -1)) {
                    if(this.filterChain.getFilters().length > 0 && queryString !== "") {
                        queryString += ' AND ';
                    }
                    queryString += filter_name_initial;
                    this.$el.find('textarea#filter-chain-query-string').val(queryString);
                }
            }
        },

        updateQueryWithDeletedFilterName: function(deletedFilter, filters) {
            var queryString = this.$el.find('textarea#filter-chain-query-string').val() || "";
            var regex_filter_name = deletedFilter.get("name");
            if(queryString.indexOf(regex_filter_name) !== -1) {
                var filterNameRegexForAndPre = ' AND '+deletedFilter.get("name");
                var filterNameRegexForAndPreAND = ' AND '+deletedFilter.get("name")+' AND ';
                var filterNameRegexForAndPreOR = ' AND '+deletedFilter.get("name")+' OR ';
                var filterNameRegexForAndPrePAR = ' AND '+deletedFilter.get("name")+')';

                var filterNameRegexForORPre = ' OR '+deletedFilter.get("name");
                var filterNameRegexForORPreAND = ' OR '+deletedFilter.get("name")+' AND ';
                var filterNameRegexForORPreOR = ' OR '+deletedFilter.get("name")+' OR ';
                var filterNameRegexForORPrePAR = ' OR '+deletedFilter.get("name")+')';

                var filterNameRegexForAnd = deletedFilter.get("name")+' AND ';
                var filterNameRegexForAndPAR = '('+deletedFilter.get("name")+' AND ';

                var filterNameRegexForOR = deletedFilter.get("name")+' OR ';
                var filterNameRegexForORPAR = '('+deletedFilter.get("name")+' OR ';

                var queryLength = queryString.length;
                var replaceStringLength = 0;
                var remainingLength = 0;
                if(queryString.indexOf(filterNameRegexForAndPreAND) !== -1 || queryString.indexOf(filterNameRegexForORPreAND) !== -1 || queryString.indexOf(filterNameRegexForAndPreOR) !== -1 || queryString.indexOf(filterNameRegexForORPreOR) !== -1 || queryString.indexOf(filterNameRegexForAndPrePAR) !==-1 || queryString.indexOf(filterNameRegexForORPrePAR) !==-1){
                    if(queryString.indexOf(filterNameRegexForAndPreAND) !== -1){
                        queryString = queryString.replace(filterNameRegexForAndPreAND, ' AND ');
                    } else if(queryString.indexOf(filterNameRegexForAndPreOR) !== -1){
                        queryString = queryString.replace(filterNameRegexForAndPreOR, ' OR ');
                    } else if(queryString.indexOf(filterNameRegexForORPreAND) !== -1){
                        queryString = queryString.replace(filterNameRegexForORPreAND, ' AND ');
                    } else if(queryString.indexOf(filterNameRegexForORPreOR) !== -1){
                        queryString = queryString.replace(filterNameRegexForORPreOR, ' OR ');
                    } else if(queryString.indexOf(filterNameRegexForAndPrePAR) !== -1){
                        queryString = queryString.replace(filterNameRegexForAndPrePAR, ')');
                    } else{
                        queryString = queryString.replace(filterNameRegexForORPrePAR, ')');
                    }
                } else if(queryString.indexOf(filterNameRegexForAndPAR) !== -1 || queryString.indexOf(filterNameRegexForORPAR) !== -1 ) {
                    if(queryString.indexOf(filterNameRegexForAndPAR) !== -1){
                        queryString = queryString.replace(filterNameRegexForAndPAR, '(');
                    } else{
                        queryString = queryString.replace(filterNameRegexForORPAR, '(');
                    }
                } else if(queryString.indexOf(filterNameRegexForAndPre, queryLength-filterNameRegexForAndPre.length) !== -1 || queryString.indexOf(filterNameRegexForORPre, queryLength-filterNameRegexForORPre.length) !== -1){
                    if(queryString.indexOf(filterNameRegexForAndPre) !== -1 && queryString.indexOf(filterNameRegexForAndPre, queryLength-filterNameRegexForAndPre.length) !== -1){
                        replaceStringLength = filterNameRegexForAndPre.length;
                        remainingLength = queryLength - replaceStringLength;
                        queryString = queryString.slice(0,remainingLength);
                    } else{
                        replaceStringLength = filterNameRegexForORPre.length;
                        remainingLength = queryLength - replaceStringLength;
                        queryString = queryString.slice(0,remainingLength);
                    }
                } else if(queryString.lastIndexOf(filterNameRegexForAnd, 0) === 0 || queryString.lastIndexOf(filterNameRegexForOR, 0) === 0) {
                    if(queryString.indexOf(filterNameRegexForAnd) !== -1 && queryString.lastIndexOf(filterNameRegexForAnd, 0) === 0){
                        replaceStringLength = filterNameRegexForAnd.length;
                        queryString = queryString.slice(replaceStringLength, queryLength);
                    } else{
                        replaceStringLength = filterNameRegexForOR.length;
                        queryString = queryString.slice(replaceStringLength, queryLength);
                    }
                }  else {
                    queryString = queryString.replace(deletedFilter.get("name"), "");
                }
                this.updateQueryParentheses(filters, queryString);
            }

        },

        updateQueryParentheses: function(filters, queryString){
            _.each(filters, function(fil){
                var filterNameRegexForPar = '('+fil.get("name")+')';
                while(queryString.indexOf(filterNameRegexForPar) !== -1) {
                    var replaceString = '('+fil.get("name")+')';
                    queryString = queryString.replace(replaceString, fil.get("name"));
                }
            });
            this.$el.find('textarea#filter-chain-query-string').val(queryString);
        },

        updateVersionInQueryString: function() {
            if (this.filterChainQuery) {
                var filter_names=[];
                _.each(this._filters, function(filterRow) {
                    filter_names.push(filterRow.get('name'));
                });

                var query_names = this.filterChainQuery.split(/ AND | OR /);
                if(filter_names.length === 1) {
                    this.filterChainQuery = filter_names[0];
                }
                else {
                    if (filter_names.length === query_names.length) {
                        for (var i = 0; i < filter_names.length; i++) {
                            var filter = filter_names[i];
                            var query = query_names[i];
                            filter = filter.replace(/[\(\)]/g, "");
                            query = query.replace(/[\(\)]/g, "");
                            filter = filter_names[i].trim();
                            query = query_names[i].trim();
                            if (filter.toUpperCase() !== query.toUpperCase()) {
                                var openParCount = 0, closeParCount = 0;
                                var openPar = query_names[i].match(/\(/g);
                                var closePar = query_names[i].match(/\)/g);
                                if (openPar) {
                                    openParCount = openPar.length;
                                }
                                if(closePar) {
                                    closeParCount = closePar.length;
                                }
                                if(openParCount > closeParCount) {
                                    query_names[i] = query_names[i].replace(/\s*\(/,'');
                                } else if(openParCount < closeParCount){
                                    query_names[i] = query_names[i].replace(/\)\s*$/, '');
                                }

                                var filter_name = query_names[i].replace(/\(/g,'\\(').replace(/\)/g,'\\)').replace(/\+/g,'\\+');
                                var filterNameRegexForAnd = new RegExp( filter_name + ' \\s*AND ');
                                var filterNameRegexForAndPre = new RegExp(' AND \\s*' + filter_name + '$');
                                var filterNameRegexForAndPreAND = new RegExp(' AND \\s*' + filter_name +' \\s*AND ');
                                var filterNameRegexForAndPreOR = new RegExp(' AND \\s*' + filter_name +' \\s*OR ');
                                var filterNameRegexForAndPrePAR = new RegExp(' AND \\s*' + filter_name +'\\s*\\)');
                                var filterNameRegexForORPre = new RegExp(' OR \\s*' + filter_name + '$');
                                var filterNameRegexForORPreAND = new RegExp(' OR \\s*' + filter_name +' \\s*AND ');
                                var filterNameRegexForORPreOR = new RegExp(' OR \\s*' + filter_name +' \\s*OR ');
                                var filterNameRegexForORPrePAR = new RegExp(' OR \\s*' + filter_name +'\\s*\\)');
                                var filterNameRegexForAndPAR = new RegExp('\\(\\s*' + filter_name + ' \\s*AND ');
                                var filterNameRegexForOR = new RegExp( filter_name + ' \\s*OR ');
                                var filterNameRegexForORPAR = new RegExp('\\(\\s*' + filter_name + ' \\s*OR ');

                                if(this.filterChainQuery.search(filterNameRegexForAndPAR) !== -1) {
                                    this.filterChainQuery = this.filterChainQuery.replace(filterNameRegexForAndPAR, '('+ filter_names[i] + ' AND ');
                                } else if(this.filterChainQuery.search(filterNameRegexForAndPrePAR) !== -1) {
                                    this.filterChainQuery = this.filterChainQuery.replace(filterNameRegexForAndPrePAR, ' AND '+ filter_names[i] + ')');
                                } else if(this.filterChainQuery.search(filterNameRegexForORPrePAR) !== -1) {
                                    this.filterChainQuery = this.filterChainQuery.replace(filterNameRegexForORPrePAR, ' OR '+ filter_names[i] + ')');
                                } else if(this.filterChainQuery.search(filterNameRegexForORPAR) !== -1) {
                                    this.filterChainQuery = this.filterChainQuery.replace(filterNameRegexForORPAR, '('+ filter_names[i] + ' OR ');
                                } else if(this.filterChainQuery.search(filterNameRegexForAnd) !== -1) {
                                    this.filterChainQuery = this.filterChainQuery.replace(filterNameRegexForAnd, filter_names[i] + ' AND ');
                                } else if(this.filterChainQuery.search(filterNameRegexForAndPre) !== -1) {
                                    this.filterChainQuery = this.filterChainQuery.replace(filterNameRegexForAndPre, ' AND '+ filter_names[i]);
                                } else if(this.filterChainQuery.search(filterNameRegexForAndPreAND) !== -1) {
                                    this.filterChainQuery = this.filterChainQuery.replace(filterNameRegexForAndPreAND, ' AND '+ filter_names[i] + ' AND ');
                                } else if(this.filterChainQuery.search(filterNameRegexForAndPreOR) !== -1) {
                                    this.filterChainQuery = this.filterChainQuery.replace(filterNameRegexForAndPreOR, ' AND '+ filter_names[i] + ' OR ');
                                }  else if(this.filterChainQuery.search(filterNameRegexForORPre) !== -1) {
                                    this.filterChainQuery = this.filterChainQuery.replace(filterNameRegexForORPre, ' OR '+ filter_names[i]);
                                } else if(this.filterChainQuery.search(filterNameRegexForORPreAND) !== -1) {
                                    this.filterChainQuery = this.filterChainQuery.replace(filterNameRegexForORPreAND, ' OR '+ filter_names[i] + ' AND ');
                                } else if(this.filterChainQuery.search(filterNameRegexForORPreOR) !== -1) {
                                    this.filterChainQuery = this.filterChainQuery.replace(filterNameRegexForORPreOR, ' OR '+ filter_names[i] + ' OR ');
                                }  else if(this.filterChainQuery.search(filterNameRegexForOR) !== -1) {
                                    this.filterChainQuery = this.filterChainQuery.replace(filterNameRegexForOR, filter_names[i] + ' OR ');
                                }
                            }
                        }
                    }
                }
            }
        }

    });

    return FilterChainQueryView;

});
