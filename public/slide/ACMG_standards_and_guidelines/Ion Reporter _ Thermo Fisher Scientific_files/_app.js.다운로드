define('views/variants/pluginsResultsView',[ 'jquery',
         'underscore',
         'backbone',
         'views/variants/pluginsResultsFrameView',
         'views/common/bannersView',
         'hb!templates/variants/plugins/plugins-results-view.html'],
    function($,
             _,
             Backbone,
             ResultsFrameView,
             BannerView,
             template) {
        var PluginsResultsView = Backbone.View.extend({

            _template: template,

            events: {
                "click .summary" : '_renderHtml',
                'click .downloadLog' : '_downloadLog'
            },

            initialize: function(options) {
                options = options || {};
                this.analysisIds = options.allAnalysisIds;
            },

            render: function() {
                var self = this;
                var currentId, pluginDetailPath, blocks, block;
                var detailPlugin = [];
                for (var k = 0; k<this.analysisIds.length; k++) {
                    currentId = self.analysisIds[k];
                    this._getPluginDetails(k, currentId, detailPlugin);
                }

                detailPlugin = detailPlugin.filter(function(el) {
                    return el.data[0].path.length !== 0;
                });

                self.$el.html(template({
                    pluginData : detailPlugin
                }));

                _.each(detailPlugin, function(selectedAnalysis) {
                    self.pluginDetail = [];
                    pluginDetailPath = [];
                    self.configureResultView = [];
                    blocks = [];

                    for (var j = 0; j < selectedAnalysis.data.length; j++) {
                        pluginDetailPath = selectedAnalysis.data[j].path;
                        for (var i = 0; i<pluginDetailPath.length; i++) {
                            if (pluginDetailPath[i].indexOf("_block.html") > 0) {
                                block = {};
                                block.id = selectedAnalysis.data[j].id;
                                block.path = pluginDetailPath[i];
                                block.analysisId = selectedAnalysis.analysisId;
                                blocks.push(block);
                            } else  {
                                self.pluginDetail[selectedAnalysis.data[j].id] = pluginDetailPath[i];
                            }
                        }
                    }
                    if(!_.isEmpty(blocks)) {
                        self._renderResult(blocks);
                    }
                });

                return this;
            },

            _getPluginDetails: function(index, currentId, detailPlugin) {
                var self = this;
                var analysisPlugin = {};
                $.ajax({
                    url: '/ir/secure/api/v40/analysis/' + currentId + '/pluginResults',
                    type: 'GET',
                    async: false,
                    success: function(data) {
                        if (!_.isUndefined(data) && !_.isEmpty(data)) {
                            analysisPlugin.data = data;
                            analysisPlugin.analysisName = self.options.analysesNames[index];
                            analysisPlugin.analysisId = currentId;
                            detailPlugin.push(analysisPlugin);
                        }
                    }
                });
            },

            _renderResult: function(blocks) {
                var self = this;
                _.each(blocks, function(block) {
                    self.configureResultView[block.id] = new ResultsFrameView();
                    self.configureResultView[block.id]
                        .setLaunchURL('/ir/secure/api/v40/analysis/' + block.id + '/pluginResults/' + block.path)
                        .setElement(self.$('#'+block.analysisId+'_'+block.id))
                        .render();
                });
            },

            _renderHtml: function(e) {
                var self = this;
                var pluginId = $(e.currentTarget).attr('id');
                pluginId = pluginId.substring(pluginId.indexOf("_") +1);
                var urlBase =  '/ir/secure/api/v40/analysis/' + pluginId + '/pluginResults/' + self.pluginDetail[pluginId];
                $.ajax({
                    url: urlBase,
                    type: 'GET',
                    success: function(data) {
                        var newWindow = window.open(urlBase, "_blank");
                        var doc = newWindow.document;
                        doc.open();
                        newWindow.location.href = urlBase;
                        doc.write(data);
                        doc.close();
                    }
                });
            },

            _downloadLog: function(e) {
                var pluginId = $(e.currentTarget).attr('id');
                pluginId = pluginId.substring(pluginId.indexOf("_") +1);
                var analysisId = $(e.currentTarget).attr('analysisId');
                var urlBase = '/ir/secure/api/v40/analysis/pluginResults/'+ analysisId +'/logs/' + pluginId;
                this._getDownloadFile(urlBase);
            },

            _getDownloadFile: function(urlBase) {
                var self = this;
                var ajaxOptions = {
                    url: urlBase,
                    complete: function(jqXHR) {
                        switch (jqXHR.status) {
                        case 202:
                            setTimeout(function(){self._getDownloadFile(urlBase);}, 3000);
                            break;
                        case 201:
                            self._downloadURL(jqXHR.getResponseHeader('Location'));
                            break;
                        }
                    }
                };
                ajaxOptions.type = 'GET';
                $.ajax(ajaxOptions);
            },

            _downloadURL:function downloadURL(url) {
                $.fileDownload(url, {
                    failCallback: function() {
                        BannerView.show({
                            id: 'error-banner',
                            style: 'error',
                            title:$.t('plugin.log.file.download.error')
                        });
                    }
                });
            }
        });

        return PluginsResultsView;
    }
);
