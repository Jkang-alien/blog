            'click #cloneFinalReportTemplate': '_cloneCurrentFinalReportTemplate',
            'click #addFinalReportTemplate': '_createNewFinalReportTemplate'
        },

        render: function() {
            this._showOrHideEditCloneButtons();
            return this;
        },

        selectFinalReportTemplate: function(frt) {
            this._finalReportTemplate = frt;
            this._showOrHideEditCloneButtons();
        },

        _showOrHideEditCloneButtons: function() {
            var cloneButton = this.$('#cloneFinalReportTemplate'),
                editButton = this.$('#editFinalReportTemplate');
            if (this._finalReportTemplate) {
                cloneButton.show();
                editButton.toggle(this._finalReportTemplate.get('status') !== 'LOCKED');
            } else {
                cloneButton.hide();
                editButton.hide();
            }
        },

        _editCurrentFinalReportTemplate: function(e) {
            e.preventDefault();
            this._prepareSectionsAndOpenFinalReportTemplateDialog(this._finalReportTemplate,
                    this.modify,
                    this.onSuccessfulUpdate);
        },

        _cloneCurrentFinalReportTemplate: function(e) {
            e.preventDefault();
            var self = this;
            this._finalReportTemplate.fetch().done(function(data)  {
                var frtToClone = new FinalReportTemplate(data);
                frtToClone.unset('id');
                frtToClone.unset('name');
                frtToClone.get('sections').each(function(section){
                    section.unset('id');
                });
                self._prepareSectionsAndOpenFinalReportTemplateDialog(frtToClone,
                        self.clone,
                        self.onSuccessfulCreate);
            });
        },

        _createNewFinalReportTemplate: function(e, aNewFilterChain) {
            e.preventDefault();
            var newFilterChain = aNewFilterChain ? aNewFilterChain : null;
            this._prepareSectionsAndOpenFinalReportTemplateDialog(newFilterChain,
                    this.create,
                    this.onSuccessfulCreate);
        },

        _prepareSectionsAndOpenFinalReportTemplateDialog: function(finalReportTemplate, persist, onSuccessfulPersist) {
            FinalReportTemplateModule.initialize({
                model: finalReportTemplate,
                modalSelector: this._dialogSelector,
                action: persist,
                onComplete: onSuccessfulPersist
            });
        }

    });

    return FinalReportTemplateEditControlsView;
});

