                return price && kendo.toString(kendo.parseFloat(price, 'en-US'),'c');
            },
            
            _formatDate: function(date) {
                return date && kendo.toString(new Date(Date.parse(date)), 'MMM dd yyyy hh:mm tt');
            }

        });

