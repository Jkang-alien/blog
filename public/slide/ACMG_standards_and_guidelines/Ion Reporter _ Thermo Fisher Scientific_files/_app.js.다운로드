            TemplateView.prototype.delegateEvents.apply(this, arguments);
            this._gridView.on(AttributesSamplesGridView.Event.COL_ADDED, this._onGridColumnAdded, this);
            this._gridView.on(AttributesSamplesGridView.Event.COL_REMOVED, this._onGridColumnRemoved, this);
            this._gridView.on(KendoGridView.Event.EDIT_START, this._onGridEditStart, this);
            this._gridView.on(KendoGridView.Event.EDIT_SAVE, this._onGridEditStop, this);
            this._gridView.on(KendoGridView.Event.EDIT_CLOSE, this._onGridEditStop, this);
        },

        undelegateEvents: function() {
            this._gridView.off(KendoGridView.Event.EDIT_CLOSE, this._onGridEditStop, this);
            this._gridView.off(KendoGridView.Event.EDIT_SAVE, this._onGridEditStop, this);
            this._gridView.off(KendoGridView.Event.EDIT_START, this._onGridEditStart, this);
            this._gridView.off(AttributesSamplesGridView.Event.COL_REMOVED, this._onGridColumnRemoved, this);
            this._gridView.off(AttributesSamplesGridView.Event.COL_ADDED, this._onGridColumnAdded, this);
