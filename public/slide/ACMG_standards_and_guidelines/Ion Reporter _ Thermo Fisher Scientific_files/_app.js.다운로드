define('views/cnvbaseline/cnvBaselineSampleGridView',[
    'jquery',
    'underscore',
    'views/common/grid/kendoGridView',
    'models/specimen',
    'collections/specimens',
    'hb!templates/grid/grid-column-analyzed.html',
    'hb!templates/grid/grid-column-baseline-normal.html',
    'events/eventDispatcher'
].concat(
    'views/common/grid/plugins/multiSelectionGridPlugin',
    'views/common/grid/plugins/rowSelectionGridPlugin',
    'views/common/grid/plugins/statefulGridPlugin'
), function(
    $,
    _,
    KendoGridView,
    Specimen,
    SpecimenCollection,
    analyzedColumnTemplate,
    baselineNormalColumnTemplate,
    dispatcher
) {
    

    var normalSampleCount = 0;
    var Transport = KendoGridView.Transport.extend({
        read: function(options) {
            $.ajax({
                url: this._grid._url + '?' + $.param($.extend({},
                    this._parameterMap(options.data),
                    this._grid._filters
                )),
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(this._grid._cnvBaseline.toSlimJSON()),
                success: options.success,
                error: options.error
            });
        }
    });

    var SampleGridView = KendoGridView.extend({

        _excludedAttributes: [
            'File Path',
            'Gender',
            'Sample Name'
        ],

        _url: '/ir/secure/api/v40/cnvbaseline/allowed/samples',

        _model: Specimen,

        _transportCls: Transport,

        _fields: {
            analyzed : {
                type : 'boolean'
            },
            name : {
                type : 'string'
            },
            createdOn : {
                type : 'string'
            },
            attributeValueMap : {
                type : 'object'
            },
            metadata : {
                type : 'object'
            },
            normal: {
                type: 'boolean'
            }
        },

        _sort: [{
            field : 'name',
            dir   : 'asc'
        }],

        initialize: function(options) {
            KendoGridView.prototype.initialize.apply(this, arguments);

            options = options || {};
            this._cnvBaseline = options.cnvBaseline;

            this.loadPlugin('rowSelection');
            this.loadPlugin('multiSelection');
            this.loadPlugin('stateful');
            normalSampleCount = this._cnvBaseline.get('normalSampleCount') || 0;
            this._cnvBaseline.set('normalSampleCount', normalSampleCount);
            if(this._cnvBaseline.get('specimens') !== undefined && this._cnvBaseline.get('specimens').length > 0){
                this._loadedPlugins.multiSelection._selectedModels = this._cnvBaseline.get('specimens');
            }

        },

        events: {
            'click .is-normal-select': '_onIsNormalClicked'
        },

        delegateEvents: function() {
            KendoGridView.prototype.delegateEvents.apply(this, arguments);
            this.listenTo(this, 'multiSelect', this._onMultiSelect);
            this.listenTo(this, 'dataBound', this._onDataBound);
        },

        undelegateEvents: function() {
            this.stopListening(this);
            KendoGridView.prototype.undelegateEvents.apply(this, arguments);
        },

        _columns: function() {
            var columns = [{
                field : 'analyzed',
                width : '40px',
                sortable : false,
                headerTemplate : analyzedColumnTemplate({analyzed: true}),
                template : analyzedColumnTemplate
            }, {
                field : 'name',
                title : 'Sample',
                sortable : true
            }, {
                field : 'attributeValueMap.Gender',
                title : 'Gender',
                sortable : false,
                template: '#= attributeValueMap.Gender ? attributeValueMap.Gender : "Unknown" #'
            }, {
                field : 'metadata.Role',
                title : 'Role',
                sortable : false,
                template : '#= (metadata && metadata.hasOwnProperty("Role") && metadata.Role) ? (metadata.Role).toLowerCase() : "Unknown" #'
            }, {
                field : 'createdBy',
                title : 'Imported By',
                sortable : true,
                template : '#= (createdBy) ? createdBy.lastName + ", " + createdBy.firstName : "" #'
            }, {
                field : 'createdOn',
                title : 'Imported On',
                sortable : true,
                template : '#= kendo.toString(new Date(Date.parse(createdOn)),"MMM dd yyyy hh:mm tt") #'
            }];
            if(this.options.cnvBaseline.get('algorithmType') === 'CNV_VC_INFORMATICS_BASELINE'){
                var normalColumn = {
                    field: 'normal',
                    title: 'Normal',
                    sortable: false,
                    template: baselineNormalColumnTemplate
                };
                columns.push(normalColumn);
            }
            return columns;
        },

        _onMultiSelect: function(selected) {
            if(this.options.cnvBaseline.get('algorithmType') === 'CNV_VC_INFORMATICS_BASELINE' &&
                _.isUndefined(this._cnvBaseline.get('baseCNVBaselineId'))) {
                this._updateIsNormalProperty(selected.models);
            }
            this._cnvBaseline.unset('specimens');
            this._cnvBaseline.set('specimens', new SpecimenCollection(selected.models));
            var self = this;
            $('.k-grid').find('tbody tr').each(function() {
                var checkBox = $(this).find('td:last-child .is-normal-select');
                if(! $(this).hasClass('k-state-selected')){
                    if(! checkBox.hasClass('hide')){
                        if($(checkBox).is(':checked')){
                            $(checkBox).prop('checked', false);
                            normalSampleCount--;
                        }
                        $(checkBox).addClass('hide');
                        self._cnvBaseline.set('normalSampleCount', normalSampleCount);
                    }
                }
            });
        },

        _updateIsNormalProperty: function(selectedModels) {
            var self = this;
            this._withGrid(function(grid) {
                selectedModels.forEach(function(model){
                    var row = grid.dataSource.get(model.id);
                    if (row) {
                        self.$('tr[data-uid='+row.uid+']')
                            .find('.is-normal-select')
                            .removeClass('hide');
                        if(model.get('normal')) {
                            self.$('tr[data-uid='+row.uid+']')
                                .find('.is-normal-select')
                                .prop('checked', true);
                        }else {
                            self.$('tr[data-uid='+row.uid+']')
                                .find('.is-normal-select')
                                .prop('checked', false);
                        }
                    }
                });
            });
        },

        _onIsNormalClicked: function(e) {
            e.stopPropagation();
            var cb = $(e.currentTarget);
            var baselineModel = this._toModel(e.currentTarget);
            if(cb.is(':checked')) {
                this._loadedPlugins.multiSelection._selectedModels.get(baselineModel.id).set('normal', true);
                normalSampleCount++;
            }else {
                this._loadedPlugins.multiSelection._selectedModels.get(baselineModel.id).set('normal', false);
                normalSampleCount--;
            }
            this._cnvBaseline.set('normalSampleCount', normalSampleCount);
            dispatcher.trigger('validate', this.model);
        },

        _onDataBound: function() {
            var self = this;
            this._withGrid(function(grid) {
                self._cnvBaseline.get('specimens').forEach(function(model){
                    var row = grid.dataSource.get(model.id);
                    if (row) {
                        self.$('tr[data-uid='+row.uid+']').find('.is-normal-select').removeClass('hide');
                        self.$('tr[data-uid='+row.uid+']').find(':checkbox').prop('checked', true);
                        if(model.get('normal')) {
                            self.$('tr[data-uid='+row.uid+']')
                                .find('.is-normal-select')
                                .prop('checked', true);
                        }else {
                            self.$('tr[data-uid='+row.uid+']')
                                .find('.is-normal-select')
                                .prop('checked', false);
                        }
                    }
                });
            });
        }

    });

    return SampleGridView;
});

