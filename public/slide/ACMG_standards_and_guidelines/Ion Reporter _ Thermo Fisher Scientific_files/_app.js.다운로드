                    specimenNames = _.map(json.specimens, function(sp) { return sp.name; });
                }
                if(json.algorithmType === 'CNV_VC_INFORMATICS_BASELINE'){
                    workflow = this.model.get('workflow');
                    if(json.baseCNVBaselineId){
                        $.ajax({
                            url: 'api/v40/analysis/'+json.baseCNVBaselineId,
                            type: 'GET',
                            contentType: 'application/json',
                            async: false
                        }).done(function(response) {
                            augmentedBaseline = response.name;
                        });
                    }
                }

                return _.defaults(_.extend(json, 
                {
                    creator: json.createdBy && json.createdBy.lastName + ', ' + json.createdBy.firstName,
                    createdOn: json.createdOn && kendo.toString(new Date(Date.parse(json.createdOn)), 'MMM dd yyyy hh:mm tt'),
                    specimenCount: specimenNames ? specimenNames.length : 0,
                    specimenNames: specimenNames ? specimenNames.join(', ') : '',
                    normalSampleNames: normalSampleNames ? normalSampleNames.join(', '):'',
                    workflow: workflow,
                    augmentedBaseline: augmentedBaseline
                }), 
                {
                    name : '',
                    description : '',
                    creator: ''
                });
