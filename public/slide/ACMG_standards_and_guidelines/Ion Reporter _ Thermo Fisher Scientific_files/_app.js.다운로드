define('views/analysis/analysisOverviewPageView',[ 'jquery',
         'underscore',
         'backbone',
         'collections/analysis/batchAnalyses',
         'models/analysis/analysisModel',
         'views/analysis/analysisAbortView',
         'views/analysis/analysisGridView',
         'views/analysis/analysisDetailsView',
         'views/analysis/analysisSendToReportView',
         'views/analysis/analysisShareModalView',
         'views/analysis/batchAnalysisDetailsView',
         'views/analysis/batchAnalysisShareView',
         'views/common/grid/filters/gridFilterView',
         'views/common/actionsView',
         'views/common/bannersView',
         'views/analysis/metagenomics/analysisMetagenomicsResultView',
         'views/analysis/immunerepertoire/analysisImmuneRepertoireResultView',
         'views/analysis/mutationalLoad/analysisMutationalLoadResultView',
         'views/analysis/analysisActionHandler',
         'events/eventDispatcher',
         'hb!templates/analysis/analysis-overview-page.html'],
    function($,
             _,
             Backbone,
             BatchAnalyses,
             analysisModel,
             AnalysisAbortView,
             AnalysisGridView,
             AnalysisDetailsView,
             AnalysisSendToReportView,
             AnalysisShareModalView,
             BatchAnalysisDetailsView,
             BatchAnalysisShareView,
             GridFilterView,
             ActionsView,
             BannerView,
             AnalysisMetagenomicsResultView,
             AnalysisImmuneRepertoireResultView,
             AnalysisMutationalLoadResultView,
             AnalysisActionHandler,
             dispatcher,
             template) {
        var AnalysisOverviewPageView = Backbone.View.extend({

            _template: template,

            _gridEl: '#viewanalysis-grid',
            _filterEl: '#gridfilters',
            _actionsEl: '#details-options-menu',
            _batchActionsEl: '#batch-details-options-menu',
            _metagenomicsResultEl: '#metagenomics-result-pane',
            _immuneRepertoireResultEl: '#immunerepertoire-result-pane',
            _mutationalLoadResultEl: '#mutational-load-result-pane',

            _validOptions: ['canLaunchAnalysis', 'savedAnalysisName', 'hasAnalysisRole', 'flashMessage', 'canSeeSharingDetails', 'canViewWorkflowParams', 'canViewWorkflowDetails', 'canVisualize'],

            canLaunchAnalysis: false,
            savedAnalysisName: null,
            flashMessage: null,
            canSeeSharingDetails: false,
            canViewWorkflowParams: false,
            canViewWorkflowDetails: false,
            canVisualize: false,

            initialize: function(options) {
                _.extend(this, _.pick(options || {}, this._validOptions));

                this.router = options.router;
                this.isTFCloudIntegrationEnabled = options.isTFCloudIntegrationEnabled;
                this.startTime = options.startTime;

                this.gridView = new AnalysisGridView({
                    actionsEventSource: dispatcher,
                    canPerformBatchActions: options.canPerformBatchActions,
                    hosted: options.hosted
                });

                this.gridFilterView = new GridFilterView({
                    url: '/ir/secure/api/v40/analysis/analysisFilters',
                    method: 'POST',
                    title: 'ANALYSIS',
                    searchKey: 'analysisSearch',
                    filterKey:'analysisFilter',
                    gridView: this.gridView,
                    defaultFilters:['WORKFLOW_NAME','ANALYSIS_APPLICATION_VERSION_NAME']
                });

                this.actionsView = new ActionsView({
                    msgKeyPrefix: 'AnalysisAction.',
                    primaryActionMsgKeyPrefix: 'AnalysisAction.shortName.',
                    actionsEventSource: dispatcher
                });

                this.batchActionsView = new ActionsView({
                    msgKeyPrefix: 'AnalysisAction.',
                    actionsEventSource: dispatcher
                });

                this.metagenomicsResultView = new AnalysisMetagenomicsResultView();
                this.immuneRepertoireResultView = new AnalysisImmuneRepertoireResultView();
                this.mutationalLoadResultView = new AnalysisMutationalLoadResultView();
                this._analysisActionHandler = new AnalysisActionHandler(this, dispatcher);

            },

            delegateEvents: function() {
                Backbone.View.prototype.delegateEvents.apply(this, arguments);

                this.gridView.on('rowSelect', this._onSelectSingleAnalysis, this);
                this.gridView.on('multiSelect', this._onSelectMultipleAnalyses, this);
                this._analysisActionHandler.delegateEvents();
            },

            undelegateEvents: function() {
                this._analysisActionHandler.undelegateEvents();
                this.gridView.off('multiSelect', this._onSelectMultipleAnalyses, this);
                this.gridView.off('rowSelect', this._onSelectSingleAnalysis, this);
                Backbone.View.prototype.undelegateEvents.apply(this, arguments);
            },

            events: {
                'click #refreshData': '_onRefresh',
                'click #visualize-action-btn': '_onVisualizeFromAnalysisOverview',
                'click #generate-report-btn': '_onGenerateReportButton'
            },

            render: function() {
                this.$el.html(this._template({
                    canLaunchAnalysis: this.canLaunchAnalysis,
                    canVisualize: this.canVisualize
                }));
                $('#ana').show();
                this.gridFilterView.setElement(this.$(this._filterEl)).render();
                this.gridView.setElement(this.$(this._gridEl)).render();
                this.actionsView.setElement(this.$(this._actionsEl));
                this.batchActionsView.setElement(this.$(this._batchActionsEl));
                this.metagenomicsResultView.setElement(this.$(this._metagenomicsResultEl));
                this.immuneRepertoireResultView.setElement(this.$(this._immuneRepertoireResultEl));
                this.mutationalLoadResultView.setElement(this.$(this._mutationalLoadResultEl));

                var summarySection = this.$("#sidebar-container");
                summarySection.affix({
                    offset: {
                        top: summarySection.position().top
                    }
                });
                summarySection.width(summarySection.width());

                if (this.savedAnalysisName) {
                    new BannerView({
                        id: 'launch-success-alert',
                        container: $('.main-content>.container-fluid'),
                        style: 'success',
                        title: $.t('analysis.launch.success', { analysis: { name: this.savedAnalysisName}})
                    }).render();
                }

                if (this.flashMessage) {
                    new BannerView({
                        id: 'success-banner',
                        container: $('.main-content>.container-fluid'),
                        style: 'success',
                        title: this.flashMessage
                    }).render();
                }
                summarySection.css("max-height",$(window).height()-($("footer").height()+50));
            },

            openAbortAnalysisView: function () {
                var analysis = this.detailView.model;

                AnalysisAbortView.open({
                    title: $.t('dialog.analysis.abort.title', { analysisName: analysis.get('name') }),
                    model: analysis
                });
            },

            openShareAnalysisView: function (analysisToShare) {
                AnalysisShareModalView.open({
                    analysis: analysisToShare,
                    onSharingUpdated: _.bind(function() {
                        this._clearAnalysisSelection();
                        this.gridView.refresh();
                    }, this)
                });
            },

            openSendToReportGeneration: function () {
                AnalysisSendToReportView.open({
                    model: this.detailView.model
                });
            },

            openShareBatchAnalysisView: function() {
                var self = this,
                    currentSelection = this.gridView.getSelected();

                if (currentSelection.length > 1) {

                    var view = new BatchAnalysisShareView({
                        collection: currentSelection,
                        onSuccess: function(data) {
                            view.hide();
                            self._clearAnalysisSelection();
                            self.gridView.refresh();
                            new BannerView({
                                id: 'share-success-alert',
                                container: $('.main-content>.container-fluid'),
                                style: 'success',
                                title: $.t(data.message)
                            }).render();
                        }
                    }).render();

                }

            },

            enableVisualizeButton: function() {
                this.$('#visualize-action-btn').removeClass('disabled');
            },

            disableVisualizeButton: function() {
                this.$('#visualize-action-btn').addClass('disabled');
            },

            _clearAnalysisSelection: function() {
                if (this.detailView) {
                    this.detailView.destroy();
                    this.detailView = null;
                }
                this.actionsView
                    .setActions(null)
                    .setPrimaryAction(null)
                    .render()
                    .hide();
                if (this.batchDetailView) {
                    this.batchDetailView.destroy();
                    this.batchDetailView = null;
                }
                this.gridView.clearSelection({silent: true});
                this._hideBatchActionsView();
            },

            _onSelectSingleAnalysis: function(anAnalysis) {
                if (anAnalysis) {
                    anAnalysis.fetch({
                        success: _.bind(this._onFetchAnalysisSuccess, this),
                        error: _.bind(this._onFetchAnalysisError, this)
                    });
                } else {
                    this.$('#summary-section-content').hide();
                    this.actionsView.hide();
                    this.$('.details-help-section').show();
                    if(this.detailView) {
                        this.detailView.destroy();
                    }
                    this._refreshVisualizeButton();
                }
                $("#sidebar").height($("#sidebar-container").css("max-height"));
            },

            _onFetchAnalysisError: function(analysis) {
                if (this.detailView) {
                    this.stopListening(this.detailView.model);
                    this.detailView.destroy();
                    this.detailView = null;
                }
                this.$('#details-options-menu').hide();
                this.detailView = new AnalysisDetailsView({
                    el: '#summary-section-content',
                    model: analysis,
                    canSeeSharingDetails: this.canSeeSharingDetails,
                    canViewWorkflowParams: this.canViewWorkflowParams,
                    canViewWorkflowDetails: this.canViewWorkflowDetails,
                    isTFCloudIntegrationEnabled: this.isTFCloudIntegrationEnabled,
                    startTime: this.startTime
                }).render();
            },

            _onFetchAnalysisSuccess: function(analysis) {
                if (this.detailView) {
                    this.stopListening(this.detailView.model);
                    this.detailView.destroy();
                    this.detailView = null;
                }
                this.$('.details-help-section').hide();
                this.$('#summary-section-content').show();

                this.detailView = new AnalysisDetailsView({
                    el: '#summary-section-content',
                    model: analysis,
                    canSeeSharingDetails: this.canSeeSharingDetails,
                    canViewWorkflowParams: this.canViewWorkflowParams,
                    canViewWorkflowDetails: this.canViewWorkflowDetails,
                    isTFCloudIntegrationEnabled: this.isTFCloudIntegrationEnabled,
                    startTime: this.startTime
                }).render();

                this.actionsView
                    .setActions(analysis.getActions())
                    .setPrimaryAction(analysis.getPrimaryAction())
                    .render()
                    .show();

                this.listenTo(analysis, 'runAborted', this._onRunAborted);
                this.listenTo(analysis, 'sentForReportGeneration', this._onSentForReportGeneration);
                if (analysis.get('applicationType') === 'METAGENOMICS'){
                    this.actionsView.$el.find('a[href="download_unfiltered_data"]').text($.t('AnalysisAction.DOWNLOAD_UNFILTERED_DATA_METAGENOMICS'));
                } else if (analysis.get('applicationType') === 'IMMUNEREPERTOIRE') {
                    this.actionsView.$el.find('a[href="download_unfiltered_data"]').text($.t('AnalysisAction.DOWNLOAD_UNFILTERED_DATA_IMMUNEREPERTOIRE'));
                } else if (analysis.get('applicationType') === 'MUTATIONAL_LOAD') {
                    this.actionsView.$el.find('a[href="download_unfiltered_data"]').text($.t('AnalysisAction.DOWNLOAD_UNFILTERED_DATA_MUTATIONAL_LOAD'));
                } else if (analysis.get('applicationType') === 'RUN_TS_PLUGIN') {
                    this.actionsView.$el.find('a[href="download_unfiltered_data"]').text($.t('AnalysisAction.DOWNLOAD_UNFILTERED_DATA_TS_PLUGINS'));
                }

                this._refreshVisualizeButton();
            },

            _onSelectMultipleAnalyses: function(analyses) {
                var self = this;

                if (analyses.length > 1) {
                    this.batchActionsView
                        .setActions(null)
                        .setPrimaryAction(null)
                        .render();

                    this.batchDetailView = new BatchAnalysisDetailsView({
                        el: '#batch-summary-section-content',
                        collection: analyses
                    }).render();

                    new BatchAnalyses(analyses.models).getActions(function(actions) {
                        self.batchActionsView.renderActions(_.map(actions, function(anAction) {return 'BATCH_' + anAction;}));
                        self.$('#batch-summary-section').show();
                    });
                    this._refreshVisualizeButton();
                } else {
                    this._hideBatchActionsView();
                    this._refreshVisualizeButton();
                }
            },

            _hideBatchActionsView: function() {
                this.$('#batch-summary-section').hide();
                this.batchActionsView
                    .setActions(null)
                    .setPrimaryAction(null)
                    .render()
                    .hide();
            },

            _onFilter: function(filter) {
                localStorage.setItem('analysisFilter', filter);
                if (_.isEmpty(filter)) {
                    this.gridView.clearFilter('filter');
                } else {
                    this.gridView.addFilter('filter', filter);
                }
            },

            _onRefresh: function() {
                this.gridView.clearSelection();
                this.gridView.refresh();
            },

            _onRunAborted: function(analysis) {
                BannerView.show({
                    id: 'success-banner',
                    container: $('.main-content>.container-fluid'),
                    style: 'success',
                    title: $.t('analysis.abort.success', { analysis: { name: analysis.get('name') } })
                });

                this.gridView.refresh();
            },

            _onSentForReportGeneration: function(analysis) {
                BannerView.show({
                    id: 'success-banner',
                    container: $('.main-content>.container-fluid'),
                    style: 'success',
                    title: $.t('analysis.sendToReport.success', { analysis: { name: analysis.get('name') } })
                });

                this.gridView.refresh();
            },
            _refreshVisualizeButton: function() {
                var self = this;
                if(self.batchDetailView && self.batchDetailView.collection && self.batchDetailView.collection.length > 1) {
                    new BatchAnalyses(self.batchDetailView.collection.models).getVisualizeAction(function(actions) {
                        if(actions === 'VISUALIZE') {
                            self.enableVisualizeButton();
                        }else {
                            self.disableVisualizeButton();
                        }
                    });
                } else if(self.detailView && self.detailView.model && self.detailView.model.attributes && self.detailView.model.attributes.actions) {
                    if(_.contains(self.detailView.model.attributes.actions, 'VISUALIZE')) {
                        self.enableVisualizeButton();
                    } else {
                        self.disableVisualizeButton();
                    }
                } else if(self.gridView && self.gridView.getSelected().length === 1) {
                    if(self.detailView) {
                        self.detailView.model = self.gridView.getSelected().models[0];
                    }
                    if(_.contains(self.gridView.getSelected().models[0].attributes.actions, 'VISUALIZE')) {
                        self.enableVisualizeButton();
                    } else {
                        self.disableVisualizeButton();
                    }
                } else {
                    self.disableVisualizeButton();
                }
            },

            _onVisualizeFromAnalysisOverview: function(e) {
                var self = this;
                if ($('#visualize-action-btn').hasClass('disabled')) {
                    return false;
                }
                if(self.batchDetailView && self.batchDetailView.collection && (self.batchDetailView.collection.length > 1)) {
                    if (self.batchDetailView.collection.models[0].get('applicationType') === 'IMMUNEREPERTOIRE') {
                        self.actionsView.actionsEventSource.trigger('action:view_immunerepertoire', e);
                    } else {
                        self.actionsView.actionsEventSource.trigger('action:batch_visualize', e);
                    }
                }
                else {
                    if (self.detailView.model.get('applicationType') === 'IMMUNEREPERTOIRE') {
                        self.actionsView.actionsEventSource.trigger('action:view_immunerepertoire', e);
                    } else {
                        self.actionsView.actionsEventSource.trigger('action:visualize', e);
                    }
                }
            },

            _onGenerateReportButton: function(){

            }
        });

        return AnalysisOverviewPageView;
    }
);
