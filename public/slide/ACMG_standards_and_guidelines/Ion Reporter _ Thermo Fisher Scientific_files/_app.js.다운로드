            _captureSummarySection: function(el){
                var sectionData = {};
                var details = [];
                var self = this;

                el.find(".report-section-body table tr").each(function() {
                    var row= [];

                    $(this).find("td").each(function() {
                        var thisEl = $(this);
                        var obj = {};
                        var target = thisEl.find("div");
                        obj.text =  thisEl.text();
                        obj.text = self.isDoubleByteString(obj.text)?self.convertTextToImage(obj.text):obj.text;
                        var targetClass = target.attr("class");

                        if(targetClass){
                            targetClass = targetClass.replace("wordwrap","");
                            if(targetClass.length > 0){
                                obj.fontColor = self.rgbToHex($(target).css('color'));
                            }
                        }

                        targetClass = thisEl.attr('class');
                        if(targetClass){
                            targetClass = targetClass.replace("wordwrap","");
                            if(targetClass.length > 0){
                                obj.bgColor = self.rgbToHex(thisEl.css('backgroundColor'));
                            }
                        }
                        if(target.has("b").length>0){
                            obj.fontWeight = "bold";
                        }

                        row.push(obj);
                    });
                    details.push(row);
                });
                sectionData.rows = details;
                return sectionData;
            },

            rgbToHex: function(rgb){
                rgb = rgb.match(/^rgba?[\s+]?\([\s+]?(\d+)[\s+]?,[\s+]?(\d+)[\s+]?,[\s+]?(\d+)[\s+]?/i);
                return (rgb && rgb.length === 4) ? "#" +
                  ("0" + parseInt(rgb[1],10).toString(16)).slice(-2) +
                  ("0" + parseInt(rgb[2],10).toString(16)).slice(-2) +
                  ("0" + parseInt(rgb[3],10).toString(16)).slice(-2) : '';
            },

            _captureDetailsSection: function(el){
                var self = this;
                var sectionData = {};
                var sections = [];
                el.find(".report-section-body .unbreakable").each(function(){
                    var obj = {};
                    obj.sectionName = $(this).find("h4").text();
                    var rows = [];
                    $(this).find("table tr").each(function() {
                        var row = {};
                        if($(this).hasClass("k-grid-header")){
                            row.isHeader = true;
                        }
                        var columns = [];
                        $(this).find("td").each(function() {
                            var targetEl = $(this);
                            var cell = {};
                            var colSpan = targetEl.attr("colspan");
                            if(typeof colSpan !== typeof undefined){
                                cell.colSpan = colSpan;
                            }
                            cell.text = targetEl.text().trim();
                            cell.text = self.isDoubleByteString(cell.text)?self.convertTextToImage(cell.text):cell.text;

                            if(targetEl.find("b").length > 0){
                                cell.fontWeight = "bold";
                            }
                            var bgColor = targetEl.css('backgroundColor');
                            if(typeof bgColor !== typeof undefined && bgColor !== "rgba(0, 0, 0, 0)"){
                                cell.bgColor = self.rgbToHex(bgColor);
                            }
                            cell.fontColor = self.rgbToHex(targetEl.css('color'));
                            columns.push(cell);
                        });
                        row.detailsColumns = columns;
                        rows.push(row);
                    });
                    obj.detailsRows = rows;
                    sections.push(obj);
                });
                sectionData.detailsSections = sections;
                return sectionData;
            },

