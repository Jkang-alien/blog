                self.$el.html(servicesTemplate({
                    currentTab: 'configure'
                }));
                this.submitButton = $('#submitVal');
                this.inputElement = $('#configurevalue');
                $("#download-all-logs").hide();
                var selectedTabId = "#"+self.selectedTab;
                self.$el.find(".active").removeClass('active');
                self.$el.find(selectedTabId).addClass('active');
                this._getValue();
                break;
            }
        },

        _getValue: function() {
            var self = this;
            $.ajax({
                url: 'api/v40/concurrentAnalysisData',
                method: 'GET',
                contentType: 'application/json',
                async: false,
                success: function(data) {
                    self.updateCurrentAnalysisValue(data);
                },
                error: function() {
                    new BannerView({
                        id: 'error-banner',
                        style: 'error',
                        title: 'Failed to update configuration : number of concurrent analyses'
                    }).render();
                }
            });
        },
        _validateTextInput: function() {
            var value = this.inputElement.val();
            var parsedValue = parseInt(value, 10);
            if(isNaN(value) || _.indexOf(value, '.') > -1 || value === "" || parsedValue < 5 || parsedValue > 48) {
                this.disableElements();
            } else {
                this.enableElements();
            }
        },

        _renderView: function(e) {
            var self = this;
            self.selectedTab = $(e.currentTarget).attr('id');
            self.render();
        },

        disableElements: function() {
            this.submitButton.addClass('disabled');
            this.inputElement.addClass('error');
        },

        enableElements: function() {
            this.submitButton.removeClass('disabled');
            this.inputElement.removeClass('error');
        },

        updateCurrentAnalysisValue: function(data) {
            if(data.concurrentAnalysisNumber) {
                this._updateText(data.concurrentAnalysisNumber);
            } else {
                this._updateText(5);
            }

        },

        _updateText: function(value) {
            this.inputElement.val(value);
        },

        _onSave: function() {
            this._saveConcurrent();
            this._getValue();
        },

        _saveConcurrent: function(){

            if(this.submitButton.hasClass('disabled')) {
                return;
            }
            var value = this.inputElement.val();
            return $.ajax({
                url: 'api/v40/configService/' + value,
                method: 'GET',
                contentType: 'application/json',
                async: false,
                success: this._onSuccess(value),
                error: function() {
                    new BannerView({
                        id: 'error-banner',
                        style: 'error',
                        title: 'Failed to save value'
                    }).render();
                }
            });
        },

        _onSuccess: function() {
            new BannerView({
                id: 'success-banner',
                style: 'success',
                title: $.t('configure.threshold.save.success')
            }).render();
        }
    });
    return IRServicesOverviewPage;
});
