                    return result._type;
                });
                if (!counts) {
                    counts = {FAIL: 0, SUCCESS: 0};
                }
                if (!counts.SUCCESS) {
                    counts.SUCCESS = 0;
                }
                if (!counts.FAIL) {
                    counts.FAIL= 0;
                }

                return counts;
