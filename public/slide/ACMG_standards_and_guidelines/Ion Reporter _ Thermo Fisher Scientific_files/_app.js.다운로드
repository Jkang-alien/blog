        _onEdit: function(e, sample) {
            var sampleId = sample ? sample.get('id') : this.detailView.model.id;
            this._goToPage("sample/" + sampleId + "/edit");
        },

        _onRefresh: function() {
            this.gridView.clearSelection();
            this.gridView.refresh();
        },

        _goToPage: function(url) {
            window.location = url;
