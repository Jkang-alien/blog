define('views/samples/define/importFromTS/samplesFilterView',['jquery', 'underscore', 'kendo', 'backbone', 'hb!templates/sample/define/importFromTS/samples-filter.html'],
    function($, _, kendo, Backbone, template) {
        

        var SamplesFilterView = Backbone.View.extend({

            template: template,

            events: {
                'click input[type=radio]': '_onRadioClick',
                'click button[type=submit]': '_onFilter',
            },

            render: function() {
                this.$el.html(this.template());

                this.startDate = $("#start").kendoDatePicker({
                    change: _.bind(this._startChange, this),
                    parseFormats: ["YYYY-MM-DD"]
                }).data("kendoDatePicker");

                this.endDate = $("#end").kendoDatePicker({
                    change: _.bind(this._endChange, this),
                    parseFormats: ["YYYY-MM-DD"]
                }).data("kendoDatePicker");

                this._enableDates(false);

                return this;
            },

            _onRadioClick: function () {
                var selected = $('input[name=filter-button]:checked').val();

                if(selected === "all") {
                    this._resetDefaults();
                    $('button[type=submit]').prop('disabled', true);
                    this._removeFilter();
                } else if (selected === "filter") {
                    this._enableDates(true);
                    $('#start,#end').prop('readonly', true);
                }
            },

            _startChange: function() {
                this.endDate.min(this.startDate.value());
                this._enableFilterButton();
            },

            _endChange: function() {
                this.startDate.max(this.endDate.value());
                this._enableFilterButton();
            },

            _removeFilter: function() {
                this.trigger('removeDateFilter');
            },

            _onFilter: function() {
                this.trigger('dateFilter', this.startDate.value(), this.endDate.value());
            },

            _enableFilterButton: function() {
                if(!_.isNull(this.startDate.value()) && !_.isNull(this.endDate.value())) {
                    $('button[type=submit]').removeAttr('disabled');
                }
            },

            _enableDates: function(enabled) {
                this.startDate.enable(enabled);
                this.endDate.enable(enabled);
            },

            _resetDefaults: function() {
                this._enableDates(false);

                this.startDate.value(null);
                this.endDate.value(null);
                this.startDate.max(new Date(2099, 12, 31));
                this.endDate.min(new Date(1900, 1, 1));
            }
        });

        return SamplesFilterView;

    }
);
