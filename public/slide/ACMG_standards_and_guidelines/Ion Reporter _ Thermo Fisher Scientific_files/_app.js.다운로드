define('views/analysis/batchAnalysesGridView',[
    'jquery',
    'underscore',
    'views/common/grid/kendoGridView',
    'hb!templates/analysis/plugin-popover-content.html',
    'hb!templates/analysis/specimen-group-popover-content.html',
    'hb!templates/analysis/batch-analysis-workflow.html',
    'hb!templates/analysis/analysis-name-editable.html',
    'views/common/bannersView'
], function(
    $,
    _,
    KendoGridView,
    pluginPopoverTemplate,
    specimenGroupPopoverTemplate,
    workflowTemplate,
    analysisNameTemplate,
    BannerView
) {
    

    var _SEPARATOR = '___$$$$___';
    var _FIELD_SEPARATOR = '___$$:$$___';
    var _WORKFLOW_SEPARATOR = '___$$+$$___';
    var gridCellInformation = {};
    var rowsInError = [];
    var _ERROR_ = 'red';
    var _CORRECT_ = 'green';
    var self;

    var Transport = KendoGridView.Transport.extend({
        read: function(options) {
            var analyses = this._grid._batchAnalysis.get('launchables').map(function(analysis) {
                return {
                    analysis: analysis.toJSON()
                };
            });
            options.success.call(this, {content: analyses});
        }
    });

    var BatchAnalysesGridView = KendoGridView.extend({

        _fields: {
            name: {
                type: 'string'
            },
            applicationType: {
                type: 'string'
            },
            groupingType: {
                type: 'string'
            },
            workflow: {
                type: 'object'
            },
            specimenGroup: {
                type: 'object'
            },
            plugins: {
                type: 'array'
            }
        },

        _transportCls: Transport,

        initialize: function(opts) {
            var options = opts || {};

            KendoGridView.prototype.initialize.call(this, _.extend(options, {
                groupable: false,
                scrollable: false,
                selectable: false,
                sortable: true,
                editable: true,
                pageable: true,
                serverSorting: false,
                serverPaging: false
            }));

            this._total = this._getTotal;

            this.on('editStart', this._makeAnalysisNameColumnEditable);

            this.on('editClose', this._performValidationOnAnalysisName);
            self = this;


        },

        _columns: function() {
            return [
                this.cb()
                    .field('analysis.name')
                    .title('Name')
                    .template(analysisNameTemplate)
                    .width('20%')
                    .build(),
                this.cb()
                    .field('analysis.applicationType')
                    .title('Research Application')
                    .template('#= $.t("WorkflowApplicationType." + analysis.applicationType) #')
                    .width('20%')
                    .attributes({'class' : "breakall padding-top"})
                    .build(),
                this.cb()
                    .field('analysis.groupingType')
                    .title('Grouping Type')
                    .template('#= analysis.groupingType ? $.t("WorkflowSpecimenGroupType." + analysis.groupingType) : "" #')
                    .width('10%')
                    .build(),
                this.cb()
                    .field('workflow.name')
                    .title('Workflow')
                    .template(workflowTemplate)
                    .width('20%')
                    .build(),
                this.cb()
                    .field('workflow.applicationVersion')
                    .title('Version')
                    .template('#= (workflow.applicationVersion != null) ? workflow.applicationVersion.name : "" #')
                    .width('10%')
                    .build(),
                this.cb()
                    .field('specimenGroup.members.length')
                    .title('Samples')
                    .width('5%')
                    .template(this._renderSamples)
                    .build(),
                this.cb()
                    .field('plugins.length')
                    .title('Plugins')
                    .sortable(false)
                    .width('5%')
                    .template(this._renderPlugins)
                    .build()
            ];
        },

        _getTotal: function(result) {
            var data = this.data(result);
            return data ? data.length : 0;
        },

        render: function() {

            KendoGridView.prototype.render.call(this);
            
            this.$('a[data-is-plugin="true"]').each(function() {
                var dataPlugins = $(this).data('plugins').split(_SEPARATOR);
                var plugins = _.map(dataPlugins, function(plugin) {
                    return {
                        name: plugin
                    };
                });
                $(this).popover({
                    trigger: 'hover', 
                    placement: 'top', 
                    content: pluginPopoverTemplate({plugins: plugins}), 
                    html: true,
                    container: '#batch-launch'
                });
            });

            this.$('a[data-is-specimen="true"]').each(function() {
                var specimen = $(this).data('specimens').split(_WORKFLOW_SEPARATOR);
                var workflowApplicationType = specimen[1];
                var dataSpecimens = specimen[0].split(_SEPARATOR);
                var specimens = _.map(dataSpecimens, function(specimenName) {
                    var specimenWithRole = specimenName.split(_FIELD_SEPARATOR);
                    return {
                        role: specimenWithRole[1],
                        specimen: {
                            name: specimenWithRole[0]
                        }
                    };
                });
                $(this).popover({
                    trigger: 'hover', 
                    placement: 'top', 
                    content: specimenGroupPopoverTemplate({
                        workflow: {
                            applicationType: workflowApplicationType
                        },
                        specimenGroups: [{
                            members: specimens
                        }]
                    }),
                    html: true,
                    container: '#batch-launch'
                });
            });

            this.$('a[data-is-workflow="true"]').each(function() {
                $(this).popover({
                    trigger: 'hover',
                    placement: 'top',
                    html: true,
                    container: '#batch-launch'
                });
            });


        },

        setBatchAnalysis: function(batchAnalysis) {
            this._batchAnalysis = batchAnalysis;
        },

        _parseResponse: function(response) {
            response.content = _.map(response.content, function(value) {
                var analysis = value.analysis;
                return {
                    analysis : analysis,
                    workflow : analysis.workflow,
                    plugins : analysis.plugins,
                    specimenGroup : analysis.specimenGroup
                };
            });
            return response;
        },

        _renderPlugins: function(dataItem) {
            if (dataItem.plugins && dataItem.plugins.length > 0) {
                var pluginNames = _.map(dataItem.plugins, function(plugin) {
                    return plugin.name;
                }, this).join(_SEPARATOR);

                return '<a href="javascript:void(0)" data-is-plugin="true" data-plugins="' + pluginNames + '">'  +
                        '<span style="margin:20px;">' + dataItem.plugins.length + '</span>' +
                        '</a>';
            } else {
                return $.t('batch.analysis.entry.noPlugins');
            }
        },
        
        _renderSamples: function(dataItem) {
            if (dataItem.specimenGroup && 
                    dataItem.specimenGroup.members && 
                    dataItem.specimenGroup.members.length > 0) {
                var specimens = _.map(dataItem.specimenGroup.members, function(specimenRelationShip) {
                    return (specimenRelationShip.specimen && specimenRelationShip.specimen.name || '') +
                           _FIELD_SEPARATOR +
                           specimenRelationShip.role;
                }, this).join(_SEPARATOR).concat(_WORKFLOW_SEPARATOR).concat(dataItem.workflow.applicationType);

                return '<a href="javascript:void(0)" data-is-specimen="true" data-specimens="' + specimens + '">' +
                        '<span style="margin:20px;">' + dataItem.specimenGroup.members.length + '</span>' +
                        '</a>';
            } else {
                return '';
            }
        },

        _makeAnalysisNameColumnEditable : function(e) {
            var grid = $("#batch-analyses-grid").data("kendoGrid");
            grid.dataSource.bind('change', this._updateRowStatus);
            var row = $(e.container).closest("tr");
            var rowIdx = $("tr", grid.tbody).index(row);
            var colIdx = $("td", row).index(e.container);
            var currentSelectedRowContent = grid.dataItem(row);
            var columns = grid.columns;
            gridCellInformation.rowId = rowIdx;
            gridCellInformation.colId = colIdx;
            gridCellInformation.gridInfo = grid;
            gridCellInformation.row = row;
            gridCellInformation.previousAnalysisName =  currentSelectedRowContent.analysis.name;
            if(columns[colIdx].field){
                if(columns[colIdx].field !== 'analysis.name'){
                    $('#batch-analyses-grid').data("kendoGrid").closeCell();
                }
            }
        },

        _performValidationOnAnalysisName : function() {
            var currentEditedRow = gridCellInformation.gridInfo.dataItem(gridCellInformation.row);
            var analysisNameValidStatus = 1;
            if(currentEditedRow.analysis.name !== gridCellInformation.previousAnalysisName){
                analysisNameValidStatus = this._checkForDuplicateAnalysisNameInGrid(currentEditedRow.analysis.name);
                if(analysisNameValidStatus === 1) {
                    analysisNameValidStatus = this._performServerSideValidationForDuplicateName(currentEditedRow.analysis.name, currentEditedRow.workflow.applicationVersion.name);
                }
                if(currentEditedRow.analysis) {
                    for(var i = 0 ; i < this._batchAnalysis.getLaunchables().length; i++) {
                        if(this._batchAnalysis.getLaunchables()[i].toJSON().name === gridCellInformation.previousAnalysisName && i === gridCellInformation.rowId) {
                            this._batchAnalysis.getLaunchables()[i].set('name', currentEditedRow.analysis.name);
                            break;
                        }
                    }
                }
                this._moveRow(analysisNameValidStatus, currentEditedRow);
            }

        },

        _checkForDuplicateAnalysisNameInGrid : function(currentAnalysisName) {
            var analysisNameStatus = 1;
            var regexForSpecialChar = /[!$#%^&*()+|~=`{}\[\]:";'<>?,@\/]/;
            if(currentAnalysisName === undefined || currentAnalysisName === null || currentAnalysisName === ""){
                this._displayBanner('error', 'Analysis name cannot be empty', false);
                analysisNameStatus = 0;
            }
            else if(regexForSpecialChar.test(currentAnalysisName) === true) {
                this._displayBanner('error', 'Analysis name cannot have special characters', false);
                analysisNameStatus = 0;
            }
            else if(currentAnalysisName.length > 255) {
                this._displayBanner('error', 'Number of characters in analysis name should not exceed 255', false);
                analysisNameStatus = 0;
            }
            else {
                for(var i = 0 ; i < this._batchAnalysis.getLaunchables().length; i++) {
                    if(this._batchAnalysis.getLaunchables()[i].toJSON().name === currentAnalysisName){
                        analysisNameStatus = 0;
                        this._displayBanner('error', 'The analysis name "'+currentAnalysisName+'" already exists', false);
                        $(window).scrollTop($('#notifications').offset().top);
                        break;
                    }
                }
            }
            return analysisNameStatus;
        },

        _performServerSideValidationForDuplicateName : function(currentAnalysisName, workflowApplicationVersion) {
            var isAnalysisNameExists = 0;
            var self = this;
            $.ajax({
                url: "/ir/secure/api/v40/analysis/validate/analysisName/" + currentAnalysisName  + "/" + workflowApplicationVersion + "/",
                method: "GET",
                success: function(response){
                    if(response === true) {
                        isAnalysisNameExists = 0;
                        self._displayBanner('error', 'The analysis name "'+currentAnalysisName+'" already exists', false);
                        $(window).scrollTop($('#notifications').offset().top);
                    }
                    else {
                        isAnalysisNameExists = 1;
                    }
                },
                error: function() {
                    self._displayBanner('error', 'There is some issue with the server. Please try again after some time', false);
                },
                async : false
            });
            return isAnalysisNameExists;
        },

        _displayBanner: function(style, title, stable) {
            new BannerView({
                id: 'alert-banner',
                container: $('#notifications'),
                style: style,
                title: title,
                static: stable
            }).render();
        },
        _updateRowStatus: function() {
            _.each(rowsInError, function(rowInError){
                var rowToUpdate = $('[data-uid="'+rowInError.rowId+'"] > td:first')[0];
                if(rowInError.status === _ERROR_) {
                    if($(rowToUpdate).attr("style") === undefined || $(rowToUpdate).attr("style") === null) {
                        rowToUpdate.setAttribute("style","color:red;");
                    }
                } else {
                    if($(rowToUpdate) !== undefined || $(rowToUpdate).attr("style") !== null) {
                        $(rowToUpdate).removeAttr("style");
                    }
                }
            });
            self._toggleStartButton();

        },
        _moveRow: function(status, row) {
            var grid = $("#batch-analyses-grid").data("kendoGrid");
            grid.dataSource.sort({});
            var dataItem = grid.dataSource.getByUid(row.uid);

            var index = grid.dataSource.indexOf(dataItem);
            if(status === 0) {
                if(index !== 0) {
                    grid.dataSource.remove(dataItem);
                    grid.dataSource.insert(0, dataItem);
                    this._shitfLaunchables(0,index,-1);
                }
                rowsInError.push({rowId:row.uid,status:_ERROR_});

            } else {
                var indexInError = _.lastIndexOf(_.pluck(rowsInError,"rowId"),row.uid);
                rowsInError[indexInError].status = _CORRECT_;
                var analysesInErrorCount = _.countBy(_.pluck(rowsInError,"status"), function(status) {
                    if(status === _ERROR_){
                        return status;
                    }
                });
                grid.dataSource.remove(dataItem);
                grid.dataSource.insert(analysesInErrorCount.red, dataItem);

                this._shitfLaunchables(index,analysesInErrorCount.red,1);
            }

            this._updateRowStatus();
        },
        _shitfLaunchables: function(position1, position2, direction) {
            var i, temp, next;
            if(direction === -1) {
                temp = this._batchAnalysis.getLaunchables()[position2];
                for(i =position2; i>position1;i--) {
                    next = this._batchAnalysis.getLaunchables()[i-1];
                    this._batchAnalysis.getLaunchables()[i] = next;
                }
                this._batchAnalysis.getLaunchables()[position1] = temp;
            } else {
                temp = this._batchAnalysis.getLaunchables()[position1];
                for(i =position1; i<position2;i++) {
                    next = this._batchAnalysis.getLaunchables()[i+1];
                    this._batchAnalysis.getLaunchables()[i] = next;
                }
                this._batchAnalysis.getLaunchables()[position2] = temp;
            }

        },

        _toggleStartButton: function() {
            var analysesInErrorCount = _.countBy(_.pluck(rowsInError,"status"), function(status) {
                return status;
            });
            if(analysesInErrorCount.red === 0 || analysesInErrorCount.red === undefined) {
                if($('#start-batch > button').prop("disabled") !== false) {
                    $('#start-batch > button').prop("disabled",false);
                }
            } else {
                if($('#start-batch > button').prop("disabled") !== true) {
                    $('#start-batch > button').prop("disabled",true);
                }
            }

        }
    });

    return BatchAnalysesGridView;
});
