define('views/fusionAmpliseqImportView',['jquery',
        'underscore',
        'backbone',
        'i18n',
        'views/formView',
        'views/fusionFixedDesignPanelsView',
        'views/fusionCustomDesignPanelsView',
        'views/validationErrorsView',
        'collections/fusionFixedDesignPanels',
        'collections/fusionCustomDesignPanels',
        'views/common/confirmImportPanelModalView',
        'hb!templates/workflow-fusion-ampliseq-import.html'
    ].concat(
        'bootstrap.modal',
        'bootstrap.modalmanager'
    ),
    function($,
             _,
             Backbone,
             i18n,
             FormView,
             FusionFixedDesignPanelsView,
             FusionCustomDesignPanelsView,
             ValidationErrorsView,
             FusionFixedDesignPanelsCollection,
             FusionCustomDesignPanelsCollection,
             ConfirmImportPanelModalView,
             template
    ) {
    

    var AMPLISEQ_CUSTOM_TAB_ID = "#fusionAmpliseqCustomPanelsTab",
        AMPLISEQ_FIXED_TAB_ID = "#fusionAmpliseqFixedPanelsTab";

    var FusionAmpliseqImportView = FormView.extend({

        id: 'fusionImportAmpliseqModal',

        tagName: 'div',

        className: 'modal fade',
        submitButtonSelector: '#fusionAmpliseqImportBtn',
        cancelButtonSelector: '.btn-secondary',

        initialize: function() {
            this.modalVisible = false;

            this.referenceGenomeModel = {'id': null};

            this.activeTabId = AMPLISEQ_CUSTOM_TAB_ID;

            this.customDesignPanels = new FusionCustomDesignPanelsCollection();

            this.fusionCustomDesignPanelsView = new FusionCustomDesignPanelsView({
                collection: this.customDesignPanels,
                model: this.model
            });
            this.listenTo(this.fusionCustomDesignPanelsView, 'afterRender', this._updateDialogButtonStates);

            this.fixedDesignPanels = new FusionFixedDesignPanelsCollection();

            this.fusionFixedDesignPanelsView = new FusionFixedDesignPanelsView({
                collection: this.fixedDesignPanels,
                model: this.model
            });

        },

        events: {
            'show' : '_modalShowHandler',
            'hide' : '_modalHideHandler',
            'shown a[data-toggle="tab"]' : '_tabShownHandler'
        },

        render: function(referenceGenomeModel) {
            if(referenceGenomeModel && referenceGenomeModel.id) {
                this.referenceGenomeModel = referenceGenomeModel;
            }
            this.$el.html(template());
            this.$el.modal({
                show: false,
                backdrop: 'static',
                attentionAnimation: null,
                keyboard: false
            });
            this.renderSubView(this.fusionCustomDesignPanelsView, AMPLISEQ_CUSTOM_TAB_ID);
            this.renderSubView(this.fusionFixedDesignPanelsView, AMPLISEQ_FIXED_TAB_ID);
            this._updateDialogButtonStates();

            return this;
        },

        showModal: function () {
            this.delegateEvents();
            this.$el.modal('show');
            this._clearBanner();
        },

        isModalVisible: function () {
            return this.modalVisible;
        },

        _updateDialogButtonStates: function () {
            this.enableButton(this.cancelButtonSelector);
            this.enableButton(this.submitButtonSelector);
            if (AMPLISEQ_CUSTOM_TAB_ID === this.activeTabId) {
                var selectedAmpliseqId = this.fusionCustomDesignPanelsView.getSelectedAmpliseqId();
                if (selectedAmpliseqId === null) {
                    this.disableButton(this.submitButtonSelector, {
                        message: "No AmpliSeq panel selected for import"
                    });
                }
            }
        },

        _tabShownHandler : function (shownEvent) {
            this.activeTabId = $(shownEvent.target).attr("href");
            this._updateDialogButtonStates();
        },
        save : function () {
            this.disableButton(this.cancelButtonSelector);
            if (AMPLISEQ_FIXED_TAB_ID === this.activeTabId) {
                this.isFixedPanel = true;
                this._ampliseqImportFixedPanel();
            } else if (AMPLISEQ_CUSTOM_TAB_ID === this.activeTabId) {
                this.isFixedPanel = false;
                this._ampliseqImportCustomPanel();
            }
        },

        _ampliseqImportCustomPanel: function() {
            var self = this;
            this.customDesignPanelWithCredentials = {
                customDesignPanel: {
                    ampliseqId: this.fusionCustomDesignPanelsView.getSelectedAmpliseqId(),
                    referenceGenome: {'id' : this.referenceGenomeModel.id}
                },
                credentials: {
                    username: this.customDesignPanels.username,
                    password: this.customDesignPanels.password
                }
            };
            $.ajax({
                url: "/ir/secure/api/v40/fusionpanels/importAmpliseqCustomFusionPanel",
                type: 'POST',
                contentType: 'application/json',
                processData: false,
                data: JSON.stringify(this.customDesignPanelWithCredentials),
                error: _.bind(self._confirmation, self, this)
            })
                .always(_.bind(this._onImportPanelComplete, this))
                .done(_.bind(this._onImportPanelSuccess, this));
        },

        _ampliseqImportFixedPanel: function () {
            var self = this;
            this.fusionAmpliseqFixedPanel = {
                ampliseqId: this.fusionFixedDesignPanelsView.getSelectedAmpliseqId(),
                referenceGenome: {'id' : this.referenceGenomeModel.id}
            };
            $.ajax({
                url: "/ir/secure/api/v40/fusionpanels/importAmpliseqFixedFusionPanel",
                type: 'POST',
                contentType: 'application/json',
                processData: false,
                data: JSON.stringify(self.fusionAmpliseqFixedPanel),
                error: _.bind(self._confirmation, self, this)
            })
                .always(_.bind(this._onImportPanelComplete, this))
                .done(_.bind(this._onImportPanelSuccess, this));
        },

        _onImportPanelFail: function(data) {
            this._clearBanner();
            if (data && data.status === 400) {
                var container = $('.modal-body');
                ValidationErrorsView.show(data, container);
            }
        },

        _clearBanner: function() {
            $( ".alert-error" ).remove();
        },
        _onImportPanelComplete: function () {
            this.enableButton(this.cancelButtonSelector);
            this.enableButton(this.submitButtonSelector);
        },

        _onImportPanelSuccess: function(response) {
            this.$el.modal('hide');
            this.trigger('targetRegionAdded', {
                fusionPanel: response
            });
        },

        _modalShowHandler: function () {
            this.modalVisible = true;
            this.$el.find("#fixedPanelsList").empty();
            this.fixedDesignPanels.fetch();
        },

        _modalHideHandler: function () {
            this.modalVisible = false;
        },

        _confirmation: function(parent, error) {
            var url = this.isFixedPanel ? "/ir/secure/api/v40/fusionpanels/importAmpliseqFixedFusionPanel" : "/ir/secure/api/v40/fusionpanels/importAmpliseqCustomFusionPanel";
            var data = this.isFixedPanel ? parent.fusionAmpliseqFixedPanel : parent.customDesignPanelWithCredentials;
            if(JSON.parse(error.responseText).localizedError.errorCode.errorCode === '30121') {
                var confirmPanelImportModalView = new ConfirmImportPanelModalView({
                    parent: parent,
                    data: data,
                    url: url,
                    requestMethod: 'POST',
                    isFixedPanel: parent.isFixedPanel
                });
                confirmPanelImportModalView.render();
                error.status = 200;
            } else {
                this._onImportPanelFail(error);
            }
        }

    });

    return FusionAmpliseqImportView;
});
