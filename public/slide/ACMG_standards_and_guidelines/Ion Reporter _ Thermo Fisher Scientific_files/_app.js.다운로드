    'underscore',
    'backbone',
    'views/common/grid/kendoGridView',
    'hb!templates/variants/analyses-brca-report-page.html',
    'hb!templates/variants/brca-qc-cnv-status.html',
    'views/templateView',
    'views/common/bannersView'
], function(
    $,
    _,
    Backbone,
    KendoGridView,
    template,
    qccnvstatustemplate,
    TemplateView,
    BannerView) {

    


    var AnalysisBRCAReportView = TemplateView.extend({

        _template: template,

        initialize: function (options) {
            options = options || {};
            this.analysesList = null;
        },

        events: {
            'click #download-brca-results': '_downloadResults',
        },

        delegateEvents: function () {
            TemplateView.prototype.delegateEvents.apply(this, arguments);
        },

        undelegateEvents: function () {
            TemplateView.prototype.undelegateEvents.apply(this, arguments);
        },

        render: function () {
            var self = this;
            var analysesIds = _.map(this.options.analyses.models, function(model){
                return model.id;
            });
            var samplePlot = [];
            this.summaryData = [];
            $.ajax({
                url: '/ir/secure/api/v40/analysis/getVariantSummaryDetailsForBRCA',
                method: 'POST',
                async: false,
                contentType: 'application/json',
                data: JSON.stringify(analysesIds),
                success: function(data) {
                    var indexList = [];
                    var key = 0;
                    _.each(analysesIds, function(id){
                        indexList[id] = key;
                        key++;
                    });
                    _.each(data, function(brcaData) {
                        samplePlot[indexList[brcaData.containerId]] = {
                            "imageSrc": brcaData.fileLocation,
                            "analysisName": brcaData.name
                        };
                        _.each(brcaData.variantSummaries, function(variantSummary) {
                            self.summaryData[indexList[brcaData.containerId]] = {
                                "sampleId": variantSummary.sampleID,
                                "SNV": variantSummary.snv,
                                "InDel": variantSummary.inDel,
                                "BigInDel": variantSummary.bigDel,
                                "GeneCNV": variantSummary.geneCNV
                            };
                        });
                    });
                }
            });

            this.$el.html(this._template({
                analysisName: samplePlot,
                summaryData: self.summaryData
            }));
            var urlElement;
            for (var i=0; i<this.options.analyses.models.length; i++) {
                urlElement = '/ir/secure/analyses/'+this.options.analyses.models[i].id+'/immunerepertoire/'+samplePlot[i].imageSrc;
                this.loadPlotImage(urlElement, i);
                this.loadQCNVStatus(i);
            }
        },

        loadQCNVStatus: function(index) {
            var imageDivId = 'sample-'+index;
            var self = this;
            _.each(this.analysesList, function(analysis) {
                if(analysis.id === self.options.analyses.models[index].id) {
                    if(analysis.brcaAnalysis && analysis.brcaAnalysis.sampleFailedCNVQC) {
                        var sampleFailedCNVQCKeyValue = analysis.brcaAnalysis.sampleFailedCNVQC.split(":");
                        if (sampleFailedCNVQCKeyValue.length > 1) {
                            $('#'+imageDivId + ' h2').append(qccnvstatustemplate({
                                qckey: sampleFailedCNVQCKeyValue[0],
                                qcvalue: sampleFailedCNVQCKeyValue[1]
                            }));
                        } else if (sampleFailedCNVQCKeyValue.length > 0) {
                            $('#'+imageDivId + ' h2').append(qccnvstatustemplate({
                                qckey: sampleFailedCNVQCKeyValue[0]
                            }));
                        }
                    }
                }
            });
        },

        loadPlotImage: function(url, index) {
            var imageDivId = 'result-div-'+index;
            $('<img id="result-img-'+index+'" style="width:100%" src="'+ url +'">').load(function() {
                $('#'+imageDivId).html($(this));
            });
        },

        _downloadResults: function() {
            var analysesIds = _.map(this.options.analyses.models, function(model){
                return model.id;
            });
            analysesIds = analysesIds.join(',');
            this._downloadURL('/ir/secure/api/v40/variant/brcaresults/download?analysesIds='+analysesIds);
        },

        _downloadURL:function (url) {
            $.fileDownload(url, {
                failCallback: function() {
                    BannerView.show({
                        id: 'importErrorBanner',
                        style: 'error',
                        title: $.t('variant.brca.download.file')
                    });
                }
            });
        },

        _setAnalysesList: function(dataList) {
            this.analysesList = dataList;
        }

    });

    return AnalysisBRCAReportView;
});
