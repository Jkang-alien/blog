            this.allAvailableColumns = options.allAvailableColumns;
            this.defaultColumns=options.defaultColumns;

            this.allPillNames = options.allPillNames;
            this.analysisId = options.analysisId;

            this.annotationClassification = options.annotationClassification;

            this.data = {
                tableStatesLabels : options.themeNames,
                dataSource : options.dataSource
            };

            this.summaryColumnDetails = this.data.dataSource;
            this.currentTheme = options.currentTheme;
