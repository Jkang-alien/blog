define('views/analysis/immunerepertoire/analysisImmuneRepertoireResultView',[ 'jquery',
         'underscore',
         'backbone',
         'views/analysis/immunerepertoire/summaryTabGridView',
         'views/analysis/immunerepertoire/analysisImmuneRepertoireTabView',
         'views/analysis/immunerepertoire/multiSampleGridView',
         'views/common/searchView',
