                filterExpr = filterHandler._filterExpr(filter);
                if (filterExpr) {
                    return filterExpr;
                } else {
                    return _getUndefinedFilter(filter.name);
                }
            } else {
                return 'Unknown filter';
            }
        }

    });

    function _getUndefinedFilter(name) {
        return name + ' is undefined';
    }


