define('views/filterChains/filterEditTypeTextView',['jquery', 'underscore', 'backbone', 'hb!templates/filterChain/filter-edit-type-text.html' ],
function($, _, Backbone, template) {
    var FilterEditTypeTextView = Backbone.View.extend({

        _exprTextBoxEl: '#filter-text',

        initialize: function() {
            this.filter = this.options.filter;
        },

        render: function(isGroup) {
            this.$el.html(template({
                filter: this.filter,
                isGroup: isGroup
            }));
            return this;
        },

        prepareFilterForAdd: function() {
            var filter = this.filter;
            if (this.isInGroup()) {
                this.filter.set("enabled", this.isEnabled());
            }
            var expression = this.$el.find(this._exprTextBoxEl).val();
            filter.set("configuredFilteredText", this.removeUnwantedSpaces(expression));
        },

        isValidFilter: function() {
            var expression = this.$el.find(this._exprTextBoxEl).val();
            this.filter.set("configuredFilteredText", this.removeUnwantedSpaces(expression));
            var isValid = false, self = this;
            $.ajax({
                url: '/ir/secure/api/v40/filters/isValid',
                type: 'POST',
                async: false,
                contentType: 'application/json',
                data: JSON.stringify(this.filter),
                success: function(response) {
                    isValid = response;
                    self._showHideErrorNotification(response);
                }
            });
            return isValid;
        },

        removeUnwantedSpaces: function(expression) {
            var separators = ["\\bAND\\b","\\bOR\\b", ","];
            var tokens = expression.split(new RegExp("(" + separators.join('|') + ")" ));
            tokens = _.map(tokens, function(token) {
                return token.trim().replace(/\s/g, '');
            });
            return tokens.join(" ");
        },

        isInGroup: function() {
            var $enabledCheckbox = this._getEnabledCheckbox();
            return $enabledCheckbox && $enabledCheckbox.length > 0;
        },

        isEnabled: function() {
            return this._getEnabledCheckbox().prop('checked');
        },

        _getEnabledCheckbox: function() {
            return this.$el.find(this._exprTextBoxEl);
        },

        _showHideErrorNotification: function(isValidExpr) {
            var exprBoxElement = this.$el.find(this._exprTextBoxEl);
            if(isValidExpr){
                exprBoxElement.removeClass('error');
            }else{
                exprBoxElement.addClass('error');
            }

        },

    });

    return FilterEditTypeTextView;
});
