        },

        delegateEvents: function() {
            Backbone.View.prototype.delegateEvents.apply(this, arguments);

        },

        undelegateEvents: function() {
            Backbone.View.prototype.undelegateEvents.apply(this, arguments);
        },

        events: {
            'optionChanged.bs.select #reported-variants-drop-down' : '_onColumnSelect',
            'selectAll.bs.select #reported-variants-drop-down' : '_onAllColumnSelect',
            'deselectAll.bs.select #reported-variants-drop-down' : '_onAllColumnDeselect',
            'click .remove-column' : '_removeColumn',
            'click #btn-confirm' : '_updateSelectedColumns'
        },

        render: function () {
            this.$el.html(template(this.model));
            this.$(".selectpicker").selectpicker();
            this.$("ul#reported-variants-selected-list").sortable();
            return this;
        },

        _onColumnSelect: function(e, option) {
            var targetKey = option.option.data('key');
            var targetValue = option.option.val();
            var targetState = option.state;

            if(targetState){
                this._appendReportedVariantLi(targetKey,targetValue);
            } else {
                this.$("#reported-variants-selected-list").find("li[data-key='"+targetKey+"']").remove();
            }
        },

        _updateModel: function(key, status){
            _.each(this.model.availableAnnotations, function(annotation){
                if(annotation.key === key){
                    annotation.isSelected = status;
                }
            });
        },

        _appendReportedVariantLi: function(targetKey,targetValue){
            this.$("#reported-variants-selected-list").append("<li class='reported-variant-column' title='Drag to reorder.' data-value='"+targetValue+"' data-key='"+targetKey+"'>"+targetValue+
            "<span class='pull-right column-action'><a href='#' class='remove-column' title='Remove this column.'><i class='icon-remove'></i></a></span></li>");
        },

        _onAllColumnSelect: function() {
            var variantColumns = this.model.availableAnnotations;
            var self = this;
            $(variantColumns).each(function(){
                var targetKey = this.key;
                var targetValue = this.label;
                if(self.$("#reported-variants-selected-list li[data-key='"+targetKey+"']").length === 0){
                    self._appendReportedVariantLi(targetKey,targetValue);
                }
            });
        },

        _onAllColumnDeselect: function() {
            this.$("#reported-variants-selected-list").empty();
        },

        _removeColumn: function(e) {
            e.preventDefault();
            var currentLi = $(e.currentTarget).parents('li').eq(0);
            var targetKey = currentLi.data('key');
            $(currentLi).remove();
            $("#reported-variants-drop-down option[data-key='"+targetKey+"']").prop("selected", false);
            $("#reported-variants-drop-down").selectpicker('refresh');
        },

        _updateSelectedColumns: function(){
            var selectedVariantColumns = [];
            var self = this;
            this.$("#reported-variants-selected-list li").each(function(i){
                var targetKey = $(this).data('key');
                var obj;
                _.each(self.model.availableAnnotations,function(item){
                    if(item.key === targetKey){
                        obj = item;
                    }
                });
                if(typeof obj !== typeof undefined){
                    obj.order = i+1;
                    obj.isSelected = "true";
                    selectedVariantColumns.push(obj);
                }
            });
            this.model.selectedAnnotations = selectedVariantColumns;
            _.each(this.model.availableAnnotations, function(annotation){
                annotation.isSelected = "false";
            });
            _.each(selectedVariantColumns, function(annotation){
                self._updateModel(annotation.key, "true");
            });
        }
    });


    new ModalViewPlugin(FinalReportVariantColumnModalView, {
        title: "Select Reported Columns",
