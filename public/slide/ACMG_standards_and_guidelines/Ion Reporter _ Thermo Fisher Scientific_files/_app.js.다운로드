                    .filter(function (column) {
                        return column.hidden;
                    })
                    .sortBy(function (column) {
                        return column.title.toLowerCase();
                    }).value();
            selectColumns = _.reject(selectColumns, function(column){
                return column.hidden;
            });
            _.each(hiddenColumns, function(hiddenColumn){
                selectColumns.push(hiddenColumn);
            });

            return selectColumns;
        },

        _onShowAllPillsColumns : function() {
            $("#dropdownCaption").dropdown("toggle");
            var pillsAndColumns = {
                    allPillNames : this.allPillNames,
