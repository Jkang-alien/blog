                return this.model.save(_.extend(this._state(), {
                    type: this.type
                }), {
                    success: function(model) {
                        dispatcher.trigger('attribute:saved', model);
                    },
                    error: function(model, error) {
                        var container = $(".modal-body");
                        ValidationErrorsView.show(error, container);
                    }
                });
            }
