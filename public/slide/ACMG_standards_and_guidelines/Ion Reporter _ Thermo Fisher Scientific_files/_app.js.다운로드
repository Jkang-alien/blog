define('views/finalReportTemplate/finalReportTemplateDetailView',[ 'jquery', 'underscore', 'kendo', 'views/templateView',
        'hb!templates/finalReportTemplate/finalReportTemplate-detail.html',
        'hb!templates/grid/grid-column-locked.html', 'hb!templates/grid/grid-column-provided.html',
        'hb!templates/finalReportTemplate/sections-list.html' ],
        function($, _, kendo, TemplateView, template, lockedColumnTemplate, providedColumnTemplate, sectionsListTemplate) {
    var FinalReportTemplateDetailView = TemplateView.extend({

        template : template,

        _subTemplates : {
            locked : lockedColumnTemplate,
            provided : providedColumnTemplate,
            sectionsList : sectionsListTemplate
        },

        delegateEvents: function() {
            TemplateView.prototype.delegateEvents.apply(this, arguments);
            this.listenTo(this.model, 'refresh', this.refresh);
        },

        undelegateEvents: function() {
            this.stopListening(this.model);
            TemplateView.prototype.undelegateEvents.apply(this, arguments);
        },

        initialize: function() {
            if (this.model) {
                this.model.on('refresh', this.render, this);
            }
        },
        render: function() {
            var self = this;
            var viewModel = _.extend(self._modelToJSON(), {
                sub: self._subTemplates
            });
            self.$el.html(self.template(viewModel));
        },
        refresh: function() {
            var self = this;
            this.model.fetch({
                success: function() {
                    self.render();
                }
            });
        },
        _modelToJSON : function() {
            var json = this.model.toJSON();
            var sections = _.map(json.sections, function(section) {
                if (section._type === 'HeaderSection') {
                    return _.extend(section, {
                        logoURL : section.logo !== null && section.logo !== undefined ? '/ir/secure/api/v40/finalreporttemplates/headersectionlogo/'+
                            section.logo.id + '/icon.png' : '/ir/resources/img/no-image.png'
                    });
                } else if(section._type === 'ReportedVariantsSection') {
                    if(section.selectedVariantColumns){
                        var selectedReportedVariantColumns = [];
                        _.each(section.selectedVariantColumns, function(variantColumn){
                            selectedReportedVariantColumns.push(variantColumn.label);
                        });
                        section.selectedReportedVariantColumns = selectedReportedVariantColumns.join(", ");
                    }
                    return section;
                } else {
                    return section;
                }
            });
            json.sections = sections;
            return _.defaults(_.extend(json, {
                creator : json.createdBy && json.createdBy.lastName + ', ' + json.createdBy.firstName,
                createdOn : json.createdOn && kendo.toString(new Date(Date.parse(json.createdOn)), 'MMM dd yyyy hh:mm tt'),
                lastModifiedBy : json.lastModifiedBy && json.lastModifiedBy.lastName + ', ' + json.lastModifiedBy.firstName,
                lastModifiedOn : json.lastModifiedOn && kendo.toString(new Date(Date.parse(json.lastModifiedOn)), 'MMM dd yyyy hh:mm tt')
            }), {
                name : '',
                description : '',
                creator : ''
            });
        }
    });

    return FinalReportTemplateDetailView;

});
