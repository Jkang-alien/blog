define('views/variants/analysisVisualizationReportView',['backbone',
        'jquery',
        'underscore',
        'kendo',
        'hb!templates/variants/analysis-visualization-report.html',
        'hb!templates/variants/visualization-report-background-content.html',
        'hb!templates/variants/visualization-report-whole-genome-content.html',
        'hb!templates/variants/visualization-report-karyo-content.html',
        'hb!templates/variants/visualization-report-filters-content.html',
        'hb!templates/variants/visualization-report-tracks-content.html',
        'hb!templates/variants/visualization-report-summary-table-content.html',
        'hb!templates/variants/visualization-report-analysis-details-table-content.html',
        'hb!templates/variants/visualization-report-analysis-content.html',
        'hb!templates/variants/visualization-report-sample-content.html',
        'hb!templates/variants/visualization-report-comments-content.html',
        'hb!templates/variants/visualization-report-disclaimer-content.html',
        'hb!templates/variants/visualization-report-header-content.html',
        'hb!templates/variants/visualization-report-signoff-content.html',
        'models/analysis/analysisModel',
        'views/templateView',
        'views/common/bannersView',
        'views/sortable',
        'views/metrics'
    ], function (Backbone,
                 $,
                 _,
                 kendo,
                 template,
                 backgroundTemplate,
                 wholeGenomeViewTemplate,
                 karyoTemplate,
                 filtersTemplate,
                 tracksTemplate,
                 summaryTableTemplate,
                 analysisDetailsTableTemplate,
                 analysisInfoTemplate,
                 sampleInfoTemplate,
                 commentsTemplate,
                 disclaimerTemplate,
                 headerTemplate,
                 signOffTemplate,
                 AnalysisModel,
                 TemplateView,
                 BannerView,
                 SortableView,
                 Metrics) {
        
        return TemplateView.extend({

            events: {
                'click #generate-visualization-report-pdf': '_generateReport',
                'click #back-to-analyses-visualization-button': '_cancelReport',
                'click [data-action="RemoveAll"]': '_removeAll',
                'click [data-action="AddAll"]': '_addAll',
                'click [data-action="Reset"]': '_reset',
                'change #upload': '_displayUploadHeaderSectionLogo',
                'click #btn-add-author': '_onAddAuthor',
                'click #uploadCustomButton': '_openInputType',
                'keydown textarea': 'resizeText',
                'click .move-author-up': '_onMoveAuthorUp',
                'click .move-author-down': '_onMoveAuthorDown',                
                'click .remove-author': '_onDeleteAuthor',
                'click #removeCustomLogo' : '_removeLogo'
            },
            
            initialize: function (opts) {
                this.options = opts || {};
                this.models = this.options.allAnalyses.models;
                this.promises = [];
                this.analyses = [];
                this.members = [];
                this.specimens = [];
                this.roles = [];
                this.sampleGroups = [];
                this.defaultSections = [
                    {
                        section: 'header_section',
                        name: "",
                        address: "",
                        imageSrc: "/ir/resources/img/no-image.png"
                    },
                    {
                        section: 'background_section',
                        data: ""
                    },
                    {
                        section: 'Filters_section'
                    },
                    {
                        section: 'Summary_section'
                    },
                    {
                        section: 'wholeGenomeView_section'
                    },
                    {
                        section: 'analysisInformation_section'
                    },
                    {
                        section: 'comments_section',
                        data: ""
                    },
                    {
                        section: 'signoff_section',
                        data: ""
                    },
                    {
                        section: 'disclaimer_section',
                        data: ""
                    },

                ];

                this.user = this.options.user;
                this.isTFCloudIntegrationEnabled = this.options.isTFCloudIntegrationEnabled;
                this.startTime = this.options.startTime;
                this.imageSrc = null;
            },

            render: function (callback) {
                var self = this;
                this.fetchAnalysis().done(function () {
                    self._renderSections();
                    callback();
                });                             
                
                return this;
            },

            fetchAnalysis: function () {
                this.promises = _.map(this.models, function (model) {
                    var analysis = new AnalysisModel({
                        id: model.id
                    });
                    return analysis.fetch();
                });

                return $.when.apply($, this.promises);
            },


            _renderSections: function(){
                _.each(this.promises, function(analysis){
                    this.analyses.push(JSON.parse(analysis.responseText));
                },this);

                if(typeof this.options.wholeGenomeView !== 'undefined') {
                    this._orderAnalyses();
                }

                _.each(this.analyses, function (analysis) {
                    var sampleGroup = {
                        analysisName: "",
                        specimens: []
                    };
                    sampleGroup.analysisName = analysis.name;
                    var samples = [];
                    _.each(analysis.specimenGroup.members, function (member) {
                        _.each(member, function (specimens) {
                            var role = member.role;
                            if (_.isObject(specimens)) {
                                specimens.ROLE = role;
                                samples.push(specimens);
                            }

                        }, this);
                    }, this);
                    sampleGroup.specimens = samples;
                    this.sampleGroups.push(sampleGroup);
                }, this);

                this.$el.html(template());
            },

            _backgroundSection: function () {
                return {
                    id: 'background',
                    name: 'Background',
                    popContent: 'Contains summary text describing the purpose of the report generated by the workflow.',
                    content: backgroundTemplate({})

                };
            },

