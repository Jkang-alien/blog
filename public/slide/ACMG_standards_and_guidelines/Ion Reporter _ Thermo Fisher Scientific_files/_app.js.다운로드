define('models/cnvBaseline',['jquery', 'underscore', 'models/baseModel', 'models/cnvBaselineType', 'collections/specimens', 'models/common/nameValidation',
        'models/referenceGenome'],
    function($, _, BaseModel, CnvBaselineType, SpecimenCollection, NameValidation, ReferenceGenome) {
        

        var EDIT_ACTION = 'EDIT';

        var CnvBaseline = BaseModel.extend({

            WHOLE_GENOME: 'WHOLEGENOME_LOWCOVERAGE',
            TARGETSEQ_EXOME: 'TARGETSEQ_EXOME',
