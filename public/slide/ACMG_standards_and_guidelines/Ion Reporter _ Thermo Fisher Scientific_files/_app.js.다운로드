    'views/common/bannersView',
    'hb!templates/workflow-myVariantDB.html'],
function(_, $, ParentView, MyVariantDB, WorkflowMyVariantDBs, MyVariantDBSelectView, CreateMyVariantDBView, BannerView, template) {
    

    var WorkflowMyVariantDBView = ParentView.extend({

        initialize: function() {
            var workflow = this.model;
            this._myVariantDBSelectView = new MyVariantDBSelectView({
                model: workflow
            });
        },

        events: {
            'click #create_myVariantDB' : '_createMyVariantDB'
        },

        render: function() {
            this.$el.html(template);
            this._renderSelect();
            return this;
        },

        _renderSelect: function() {
            this._myVariantDBSelectView.setElement(this.$("#myVariantDBSelector")).render();
        },

        _createMyVariantDB: function(event) {
            event.preventDefault();
            new CreateMyVariantDBView({
                refGenId: this.model.get('referenceGenome').id,
                completeAction: _.bind(this._myVariantDBCreated, this),
                local: this.options.local
            }).render();
        },

        _myVariantDBCreated: function(myVariantDB) {
            this._displayBanner();
            var responseToArray = [];
            responseToArray.push(myVariantDB);
            var selectedMyVariantDBs = new WorkflowMyVariantDBs();
            selectedMyVariantDBs.set(responseToArray);
            this._myVariantDBSelectView.model.set('myVariantDBs', selectedMyVariantDBs);
            this._myVariantDBSelectView.render();
        },

        _displayBanner: function() {
            var options = {
                titleKey: "workflow.successful.myVariantDB.creation",
                style: 'success',
                id: 'success-banner'
            };

            BannerView.show(options);
        },

    });

    return WorkflowMyVariantDBView;

});
