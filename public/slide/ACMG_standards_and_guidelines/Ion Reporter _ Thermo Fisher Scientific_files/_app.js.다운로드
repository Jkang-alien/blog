        },

        render: function() {
            var chevronViews = [];
            this.collection.each(function(chevron) {
                chevronViews.push(new ChevronView({
                    tagName: 'li',
                    model: chevron
                }));
            });
            this.$el.empty();

            var disableAfterCurrent = (this.parentView.model && !this.parentView.model.isValid()) || !this.updateExistingEntity;

            var subEl;
            _.each(chevronViews, function(cv) {
                subEl = cv.render().$el;

                this.$el.append(subEl);

                var id = cv.model.get('identifier');
                if (this.isAfterMax(id) && disableAfterCurrent) {
                    subEl.addClass('disabled');
                }

                if (this.currentStep === id) {
                    subEl.addClass('active');
                }

                $('li', this.el).width(100 / this.collection.length + '%');
            }, this);

            return this;
        },

        _onWizardStepChanged: function(currentStep) {
            this.currentStep = currentStep;

            var currentStepIndex = this.getStepIndex(currentStep);
            if (currentStepIndex > this.maxStep) {
                this.maxStep = currentStepIndex;
            }
            this.render();

            if (this.maxStep > currentStepIndex) {
                this.changeActiveBackground();
            }
        },

        getStepIndex: function(stepName) {
            for (var i = 0, len = this.collection.models.length; i < len; i++) {
                if (stepName === this.collection.models[i].attributes.identifier) {
                    return i;
                }
            }
        },

        getStepName: function(stepIndex) {
            if (stepIndex < this.collection.models.length) {
                return this.collection.models[stepIndex].attributes.identifier;
            }
        },

        isAfterMax: function(stepName) {
            return this.maxStep < this.getStepIndex(stepName);
        },

        updateMax: function(stepName, options) {
            options = options || {};
            var stepIndex = this.getStepIndex(stepName);
            if (options.increase) {
                if (stepIndex < this.maxStep) {
                    this.changeActiveBackground();
                }
                
                if (this.maxStep <= stepIndex) {
                    this.maxStep = stepIndex;
                    this.changeActiveBackground();
                }
            } else if (options.decrease) {
                if (this.maxStep > stepIndex) {
                    this.maxStep = stepIndex;
                    this.render();
                }
            }
        },

        changeActiveBackground: function() {
            var nextStepName = this.getStepName(this.maxStep + 1);
            var currentStepName = this.getStepName(this.maxStep);
            if (!_.isUndefined(nextStepName)) {
                $('a[data-id=' + nextStepName + ']').addClass("prev-active");
                $('a[data-id=' + currentStepName + ']').removeClass("prev-active");
            }
        }
    });


    return ChevronsView;
