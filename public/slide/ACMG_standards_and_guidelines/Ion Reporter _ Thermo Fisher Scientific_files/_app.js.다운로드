            },

            undelegateEvents: function() {
                this.off('dateValidationError', this.displayErrorBanner);
                this.off('dateValidationError', this.displayErrorBanner);
                this.off('filterRetrievalError', this.displayErrorBanner);
                dispatcher.off('resetFiltersAndSearch');
                this.searchView.off('search', this._onSearch, this);

                Backbone.View.prototype.undelegateEvents.apply(this, arguments);
            },

            getFilters: function(callback, filter, filterData){
                this.showFilterSpinner();
                var self = this;
                $.ajax({
                    url: self.url,
                    method: self.method,
                    async: false,
                    contentType: 'application/json',
                    data: JSON.stringify(filter),
                    success: function(data) {
                        callback.call(self, data, filter, filterData);
                    },
                    error: function() {
                        self.trigger('filterRetrievalError', {issue: 'FILTER_RETRIEVAL_ERROR'});
                    }
                });
            },

            initCallback: function(data){
                this.gridView.setFilterAndThemeData(data);
                this.setFilterData(data);
                this.getFilterKeys(this.filtersJson);
                this._doRender.call(this);
                this.hideFilterSpinner();
            },

            setFilterData: function(data){
                this.filtersJson = data;
            },

            loadFiltersCallback: function(data, selectedFilter, filterData){
                var self = this;
                _.each(data, function(_d) {
                    _.each(self.filtersJson, function(_f) {
                        if(_d.filterKey === _f.filterKey) {
                            _f.filterData = _d.filterData;
                        }
                    });
                });
                self.getFilterKeys(self.filtersJson);
                if(!_.isArray(selectedFilter)){
                    self.addFilter(selectedFilter, filterData);
                }
                else{
                    var sortedFilters = self.getSortedFiltersList(selectedFilter);
                    _.each(sortedFilters, function(s){
                        self.addFilter(s, filterData);
                    });
                }
                this.hideFilterSpinner();
            },


            render: function() {
                this.getFilters(this.initCallback, []);
                return this;
            },

            getFiltersData:function(selectedFilter, filterData) {
                var self = this;
                filterData = filterData || [];
                var f;
                if(!_.isArray(selectedFilter)){
                    f = _.find(self.filtersJson, function(filter){
                        return filter.filterKey === selectedFilter.filterKey && !_.isEmpty(filter.filterData);
                    });
                }

                if(_.isObject(selectedFilter) && (selectedFilter.filterType === 'DATE')) {
                    self.addFilter(selectedFilter, filterData);
                }
                else if(_.isUndefined(f)) {
                    f = [].concat(selectedFilter);
                    self.getFilters(self.loadFiltersCallback, f, filterData);
                }
                else{
                    self.addFilter(f, filterData);
                }
            },

            getSortedFiltersList: function(filters) {
                return _.sortBy(filters, function(filter) {
                    return filter.filterLabel.toLowerCase();
                });
            },

            _onSearch: function(query) {
                localStorage.setItem(this.searchKey, query);
                if (_.isEmpty(query)) {
                    this.gridView.clearFilter('q');
                } else {
                    this.gridView.addFilter('q', query);
                }
            },

            _doRender: function() {
                var self = this;
                var analysisFiltersList = [],
                sampleFiltersList = [],
                specimenFactoryAttributeList = [],
                specimenCustomAttributeList = [],
                workflowFiltersList = [],
                defaultFilters = [];
                _.each(self.filtersJson, function(filter) {
                    if(_.contains(self.defaultFilters, filter.filterKey)){
                        var sortedFilter = _.sortBy(filter.filterData, function(filterValue) {
                            return filterValue.filterText.toLowerCase();
                        });
                        filter.filterData = sortedFilter;
                        defaultFilters.push(filter);
                    }
                    else if(filter.filterKey.indexOf('WORKFLOW_') === 0 || filter.filterKey.indexOf('DATE_WORKFLOW') === 0) {
                        workflowFiltersList.push(filter);
                    }
                    else if(filter.filterKey.indexOf('SPECIMENGROUP_') === 0 || filter.filterKey.indexOf('DATE_SPECIMEN') === 0) {
                        sampleFiltersList.push(filter);
                    }
                    else if(filter.filterKey.indexOf('ATTRIBUTE_FACTORY_') === 0) {
                        specimenFactoryAttributeList.push(filter);
                    }
                    else if(filter.filterKey.indexOf('ATTRIBUTE_CUSTOM_') === 0) {
                        specimenCustomAttributeList.push(filter);
                    }
                    else {
                        analysisFiltersList.push(filter);
                    }
                });

                var sortedAnalysisFilters = self.getSortedFiltersList(analysisFiltersList);

                var sortedWorkflowFilters = self.getSortedFiltersList(workflowFiltersList);

                var sortedSampleFilters = self.getSortedFiltersList(sampleFiltersList);

                var sortedFactoryAttributeFilters = self.getSortedFiltersList(specimenFactoryAttributeList);

                var sortedCustomAttributeFilters = self.getSortedFiltersList(specimenCustomAttributeList);

                var sortedDefaultFilters = self.getSortedFiltersList(defaultFilters);
                self.$el.html(self.template({
                    defaultFilters: sortedDefaultFilters,
                    analysisFilters: sortedAnalysisFilters,
                    workflowFilters: sortedWorkflowFilters,
                    sampleFilters: sortedSampleFilters,
                    specimenFactoryAttributeFilters:sortedFactoryAttributeFilters,
                    specimenCustomAttributeFilters:sortedCustomAttributeFilters,
                    title: self.title
                }));

                this.hideFilterSpinner();
                var filters = self.getFromLocalStorage();

                self._showFilters(filters);

                self.$el.find('.selectpicker').selectpicker('refresh');

                this.searchView.setElement(this.$(this._searchEl)).render();

                var onSearch = localStorage.getItem(this.searchKey);
                if (onSearch) {
                    this.searchView.setValue(onSearch);
                    this._onSearch(onSearch);
                }
            },
            getFilterKeys: function(json){
                _.each(json, function(filter){
                    var grpByText = _.groupBy(filter.filterData, function(t){ return t.filterText;});
                    var filterData = [];
                    _.each(_.keys(grpByText), function(k){
                        var filterKey = {filterId:"", filterText:k};
                        _.each(grpByText[k], function(f){
                            if(filterKey) {
                                filterKey.filterId = filterKey.filterId +"|"+f.filterId;
                            }
                        });
                        if(filterKey.filterId && !_.isEmpty(filterKey.filterId) && _.indexOf(filterKey.filterId, '|') === 0) {
                            filterKey.filterId = filterKey.filterId.substring(1);
                        }
                        filterData.push(filterKey);
                    });
                    filter.filterData = filterData;
                });
            },

            filterChanged: function(e, clickedIndex) {
                e.stopPropagation();
                $('#filtersMain').selectpicker('toggle');
                var self = this;
                var elem = self.$el.find(self._filtersMainEl).find('option').eq(clickedIndex).val();
                if(self._isSelected(elem)) {
                    self.selectedFilter = _.find(self.filtersJson, function(filter) {
                        return (elem === filter.filterKey);
                    });
                    if(!_.isEmpty(self.selectedFilter)) {
                        self.getFiltersData(self.selectedFilter);
                    }
                    self.updateSubFilters(e);
                } else {
                    var elemToRemove = $(self._filtersSubEl).find('select[id="'+elem+'"]');
                    if(elemToRemove) {
                        $(elemToRemove).selectpicker('destroy').remove();
                        $("span[data-filter-input='"+elem+"']").remove();
                    }
                    var filters = self.updateSubFilters(e, true);
                    if(_.isArray(filters)){
                        self._applyFilter(filters);
                    }
                }

            },

            updateSubFilters: function(e, refresh) {
                var self = this;
                var filterVar = {};
                var filterData = {};
                var filterDataList = [];
                var filters = [];
                var validDate = true;
                var refreshGrid = _.isBoolean(refresh) ? refresh : true;
                var _temp = self.$el.find('select.subfilters.selectpicker');
                _.each(_temp, function(filter) {
                    filterDataList = [];
                    _.each($(filter).find('option:selected'), function(filterElement) {
                        filterData = {};
                        filterData.filterId = filterElement.value;
                        filterData.filterText = filterElement.text;
                        filterDataList.push(filterData);
                    });
                    if($(filter).data('type') === 'DATE') {
                        filterDataList = [];
                        filterData = {};
                        filterData.filterId = $(filter).find('option:selected').val();
                        filterData = self.showDateFilter(filter, filterData);
                        if(_.isObject(filterData)){
                            filterDataList.push(filterData);
                        }
                        else{
                            validDate = false;
                        }
                    }
                    else if($(filter).data('type') === 'NUMERIC') {
                        filterDataList = [];
                        refreshGrid = self.validateNumeric(e);
                        filterData = self.showNumericFilter(filter);
                        filterDataList.push(filterData);
                    }
                    filterVar = {
                        filterKey: filter.id,
                        filterType: $(filter).data('type'),
                        filterLabel: $(filter).data('label'),
                        filterData: filterDataList,
                        filterCategory:$(filter).data('category')
                    };
                    filters.push(filterVar);
                });
                if($(self._filtersSubEl).find('select').length === 0) {
                    $(self._filtersSubEl).empty();
                }
                if(!validDate || !refreshGrid) {
                    if(validDate) {
                        self.setToLocalStorage(filters);
                    }
                    return false;
                } else {
                    self.setToLocalStorage(filters);
                    return filters;
                }
            },

            isValidDate: function(dateVal) {
                var date = new Date(dateVal);
                if(isNaN(date)) {
                    this.trigger('dateValidationError', {issue: 'DATE_WRONG_FORMAT'});
                    return false;
                } else {
                    return date.getMonth()+1+'/'+date.getDate()+'/'+date.getFullYear();
                }
            },

            showFilterInput: function(filterElement) {
                filterElement.removeClass('hide-filter');
            },

            hideFilterInput: function(filterElement) {
                filterElement.addClass('hide-filter');
                filterElement.find('input').val('');
            },

            showDateFilter: function(filter, filterData){
                var self = this;
                var fromDate = ' ';
                var toDate = ' ';
                var validDate = true;
                var filterElem = $("span[data-filter-input='"+filter.id+"']");
                var today = new Date();
                var _tempDate = new Date();
                switch(filterData.filterId){
                case 'today':
                    self.hideFilterInput($(filterElem));
                    filterData.filterText = kendo.toString(today, 'MM/dd/yyyy')+'- ';
                    break;
                case 'last7days':
                    self.hideFilterInput($(filterElem));
                    today = new Date().setDate(_tempDate.getDate()-7);
                    filterData.filterText = kendo.toString(new Date(today), 'MM/dd/yyyy')+'- ';
                    break;
                case 'last30days':
                    self.hideFilterInput($(filterElem));
                    today = new Date().setDate(_tempDate.getDate()-30);
                    filterData.filterText = kendo.toString(new Date(today), 'MM/dd/yyyy')+'- ';
                    break;
                case 'Date Range':
                    self.showFilterInput($(filterElem));
                    var fromDateInput = $(filterElem).find('#fromDate');
                    var toDateInput = $(filterElem).find('#toDate');

                    if(!$(filterElem).find('input').hasClass('k-input')) {
                        fromDateInput.kendoDatePicker();
                        toDateInput.kendoDatePicker();
                    }
                    if(fromDateInput.val() !== '') {
                        validDate = self.isValidDate(fromDateInput.val());
                        fromDate = validDate || ' ';
                    }
                    if(toDateInput.val() !== '') {
                        validDate = self.isValidDate(toDateInput.val());
                        toDate = validDate || ' ';
                    }
                    filterData.filterText = fromDate+'-'+toDate;
                    if(fromDate !== ' ' && toDate !== ' ') {
                        var from = new Date(fromDate);
                        var to = new Date(toDate);
                        if(from > to) {
                            self.trigger('dateValidationError', {issue: 'DATE_VALIDATION'});
                            validDate = false;
                        }
                    }
                    break;
                default:
                    self.hideFilterInput($(filterElem));
                    break;
                }
                return validDate ? filterData : validDate;
            },

            showNumericFilter: function(filter){
                var self = this;
                var filterInputs = $("span[data-filter-input='"+filter.id+"']");
                self.showFilterInput(filterInputs);
                var filterVal = $(filter).find('option:selected').val();
                var minInput = $(filterInputs).find('#min');
                var maxInput = $(filterInputs).find('#max');
                var filterId = $(filterInputs).find('#filterId').val();
                var filterData = {};
                filterData.filterId = filterId;
                filterData.filterCondition = filterVal;
                switch(filterVal){
                case 'more':
                    minInput.removeClass('hide-filter');
                    minInput.focus();
                    filterData.filterText = minInput.val();
                    maxInput.val('');
                    maxInput.addClass('hide-filter');
                    break;
                case 'less':
                    maxInput.removeClass('hide-filter');
                    maxInput.focus();
                    filterData.filterText = maxInput.val();
                    minInput.val('');
                    minInput.addClass('hide-filter');
                    break;
                case 'between':
                    minInput.removeClass('hide-filter');
                    minInput.focus();
                    maxInput.removeClass('hide-filter');
                    filterData.filterText = minInput.val()+','+maxInput.val();
                    break;
                default:
                    minInput.val('');
                    minInput.addClass('hide-filter');
                    maxInput.val('');
                    maxInput.addClass('hide-filter');
                    break;
                }

                return filterData;
            },



            addFilter: function(filter, filterData) {
                var self = this;
                var filterKey = filter.filterKey;
                var isDefault = false;
                if(_.contains(self.defaultFilters, filterKey)){
                    isDefault = true;
                }
                filterData = _.isUndefined(filterData) ? filter.filterData : filterData;
                if( !($(self._filtersSubEl).find('select[id="'+filter.filterKey+'"]').length) && !isDefault ) {
                    var selectedFilter = _.filter(self.filtersJson, function(subFilter) {
                        return subFilter.filterKey === filter.filterKey;
                    });
                    if(filter.filterType === 'DATE') {
                        self.addDateFilter(filter, filterData);
                    }
                    else if (filter.filterType === 'NUMERIC') {
                        self.addNumericFilter(filter, filterData);
                    }
                    else {
                        self.addDropdownFilter(selectedFilter, filter, filterData);
                    }
                    $('select[id="'+filter.filterKey+'"]').selectpicker('refresh');
                } else if(isDefault === true) {
                    var selectedOptions = _.pluck(filterData, 'filterId');
                    self.$el.find('select[id="'+filter.filterKey+'"]').val(selectedOptions);
                    self.$el.find('select[id="'+filter.filterKey+'"]').selectpicker('refresh');
                }
            },
            addDropdownFilter: function(selectedFilter, filter, filterData) {
                var self = this;
                var sortedFilters = _.sortBy(selectedFilter[0].filterData, function(filterValue) {
                    return filterValue.filterText.toLowerCase();
                });
                self.$(this._filtersSubEl).append(self.dropdownTemplate({
                    filterValues: sortedFilters,
                    filterData: filterData,
                    filterCategory:filter.filterCategory,
                    filterType:filter.filterType,
                    filterKey: filter.filterKey,
                    filterLabel: filter.filterLabel,
                    messagePrefix: filter.filterKey + '.'
                }));
            },
            addDateFilter: function(filter, filterData) {
                var self = this;
                var fromDate = '';
                var toDate = '';
                var dateAdded = false;
                if(!_.isEmpty(filterData)) {
                    var filterText = filter.filterData[0].filterText;
                    if(!_.isUndefined(filterText)){
                        fromDate = filterText.substring(0, filterText.indexOf('-'));
                        toDate = filterText.substring(filterText.indexOf('-')+1);
                        if(!_.isUndefined(fromDate)){
                            fromDate = fromDate.trim();
                        }
                        if(!_.isUndefined(toDate)){
                            toDate = toDate.trim();
                        }
                    }

                    if(filter.filterData[0].filterId === 'Date Range') {
                        dateAdded = true;
                    }
                }
                var selectedValues = self._getDateFilters();

                var tmpl = {
                    filterKey: filter.filterKey,
                    filterLabel: filter.filterLabel,
                    filterCategory: filter.filterCategory,
                    filterType: filter.filterType,
                    filterData: filterData,
                    toDate: toDate,
                    fromDate: fromDate,
                    dateAdded: dateAdded,
                    filterValues: selectedValues
                };

                $(self._filtersSubEl).append(self.dateTemplate(tmpl));
                if(dateAdded) {
                    $('.datepicker').kendoDatePicker();
                }
            },
            addNumericFilter: function(filter, filterData) {
                var self = this;
                var min = '';
                var max = '';
                var selectedValues = self._getNumericFilters();
                var filterId = '';
                var _temp = [];
                var filterCondition = '';
                var tmpl = {
                    filterKey: filter.filterKey,
                    filterLabel: filter.filterLabel,
                    filterCategory: filter.filterCategory,
                    filterType: filter.filterType,
                    filterData: filterData,
                    filterValues: selectedValues,
                    filterId:filterId,
                    showFilter:true
                };
                if(filter.filterData && filter.filterData.length) {
                    var filterText = filter.filterData[0].filterText;
                    filterId = filter.filterData[0].filterId;
                    filterCondition = filter.filterData[0].filterCondition;
                    if(_.isUndefined(filterCondition)){
                        tmpl.filterData = [].concat(selectedValues[0]);
                    } else if(!_.isUndefined(filterText)){
                        _temp = filterText.split(",");
                        if(!_.isEmpty(_temp)) {
                            min = _temp[0];
                            max = _temp.length === 2 ? _temp[1] : '';
                        }
                    }
                }
                else{
                    tmpl.filterData = [].concat(selectedValues[0]);
                }
                tmpl.min=min;
                tmpl.max=min;
                tmpl.filterId=filterId;
                switch(filterCondition) {
                case 'more':
                    tmpl.showMin = true;
                    tmpl.showMax = false;
                    break;
                case 'less':
                    tmpl.showMin = false;
                    tmpl.showMax = true;
                    tmpl.max=min;
                    break;
                case 'between':
                    tmpl.showMin = true;
                    tmpl.showMax = true;
                    tmpl.max=max;
                    break;
                default:
                    tmpl.showFilter = false;
                    tmpl.showMin = false;
                    tmpl.showMax = false;
                }

                $(self._filtersSubEl).append(self.numericTemplate(tmpl));

            },

            _getNumericFilters: function() {
                return [{
                    filterId:"All",
                    filterCondition:"All",
                    filterText:"Show All"
                },{
                    filterId:"less",
                    filterCondition:"less",
                    filterText:"Less than or equal to"
                },{
                    filterId:"more",
                    filterCondition:"more",
                    filterText:"Greater than or equal to"
                },{
                    filterId:"between",
                    filterCondition:"between",
                    filterText:"Between"
                }];
            },

            _getDateFilters: function() {
                return [
                    {
                        filterId:"",
                        filterCondition:"All",
                        filterText:"Show All"
                    },{
                        filterId:"today",
                        filterText:"Today"
                    },{
                        filterId:"last7days",
                        filterText:"Last 7 Days"
                    },{
                        filterId:"last30days",
                        filterText:"Last 30 Days"
                    },{
                        filterId:"Date Range",
                        filterText:"Date Range"
                    }
                ];
            },

            _isSelected: function(elem) {
                var selectedElements = $(this._filtersMainEl).val();
                if(_.contains(selectedElements, elem)) {
                    return true;
                } else {
                    return false;
                }
            },

            _showFilters: function(filterList) {
                var self = this;
                _.each(filterList, function(filter) {
                    var o = $(self._filtersMainEl).find('option[id="'+filter.filterKey+'"]');
                    if(!o.is(':selected')) {
                        o.prop('selected', true);
                    }
                });
                if(!_.isEmpty(filterList)){
                    this.getFilters(this.loadFiltersCallback, filterList);
                }
            },

            setToLocalStorage: function(filters) {
                localStorage.setItem(this.filterKey, JSON.stringify(filters));
            },

            getFromLocalStorage: function() {
                var filters = localStorage.getItem(this.filterKey);
                if(filters) {
                    return JSON.parse(filters);
                } else {
                    return [];
                }
            },

            dateChanged: function(e) {
                this._onSubFilterChanged(e, true);
            },

            numericValChanged: function(e) {
                this._onSubFilterChanged(e, true);
            },

            validateNumeric: function(e) {
                var key = $(e.currentTarget).parent().data('filter-input');
                var filterVal = $('select#'+key).val();
                var minVal = $(e.currentTarget).parent().find('#min');
                var maxVal = $(e.currentTarget).parent().find('#max');
                if(filterVal === 'between'){
                    if(_.isEmpty(minVal.val())) {
                        minVal.addClass('error');
                        return false;
                    }
                    else if(_.isEmpty(maxVal.val())) {
                        maxVal.addClass('error');
                        return false;
                    }
                    if(parseFloat(minVal.val()) > parseFloat(maxVal.val())) {
                        minVal.removeClass('error');
                        maxVal.addClass('error');
                        return false;
                    }
                }
                minVal.removeClass('error');
                maxVal.removeClass('error');
                return true;
            },

            selectAllFilters: function(e) {
                e.stopPropagation();
                this.getFiltersData(this.filtersJson);
                this.updateSubFilters(e);
            },

            deselectAllFilters: function(e) {
                e.stopPropagation();
                var self = this;
                var defaultFilters = _.filter(self.gridView._filters.filters.filters, function(fl) {
                    return _.indexOf(self.defaultFilters, fl.filterKey) >=0;
                });
                self.gridView._filters.filters.filters = defaultFilters;
                self.clearAllFilters();
                localStorage.removeItem(this.filterKey);
                self.setToLocalStorage(defaultFilters);
                self.gridView.reset();
            },

            clearAllFilters: function() {
                $(this._filtersSubEl).empty();
            },

            _applyFilter: function(filters) {
                var appliedFilters = {};
                appliedFilters.filters = filters;
                this.gridView.setFilters(appliedFilters);
            },

            _onSubFilterChanged: function(e, refresh) {
                var filters = this.updateSubFilters(e, refresh);
                var noRefresh = ['Date Range','less','more','between'];
                var type = $(e.currentTarget).data('type');
                var opt = $(e.currentTarget).find('option');
                if(_.isArray(filters) && (refresh === true ||
                                          type === 'DROPDOWN' ||
                                          _.indexOf(noRefresh,opt.eq(refresh).val()) === -1)) {
                    this._applyFilter(filters);
                }
            },

            _onSubFilterRemoved: function(e) {
                var elem = e.currentTarget.id;
                this.$el.find('select[id="'+elem+'"]').selectpicker('destroy').remove();
                if(this.$el.find("span[data-filter-input='"+elem+"']")){
                    this.$el.find("span[data-filter-input='"+elem+"']").remove();
                }
                if(this.$el.find('.'+elem)) {
                    this.$el.find('.'+elem).remove();
                }
                $(this._filtersMainEl).find('option[id="'+elem+'"]').prop('selected', false);
                $(this._filtersMainEl).selectpicker('refresh');
                this._onSubFilterChanged(e, true);
            },

            removeAllFiltersAndSearch: function() {
                var self = this;
                self.clearFiltersAndSearch();
                self._doRender();
                self.gridView.reset();
            },

            clearFiltersAndSearch: function() {
                var self = this;
                $('#searchBar').val('');
                self.gridView._filters.filters= {};
                self.gridView._filters.q = '';
                self.clearAllFilters();
                self.clearDefaultFilters();
                localStorage.removeItem(self.searchKey);
                localStorage.removeItem(self.filterKey);
                $(this._filtersMainEl).val('');
                $(this._filtersMainEl).selectpicker('refresh');
            },

            clearDefaultFilters: function() {
                var self = this;
                _.each(self.defaultFilters, function(fil) {
                    $('select[id="'+fil+'"]').val('');
                    $('select[id="'+fil+'"]').selectpicker('refresh');
                });
            },

            showFilterSpinner: function() {
                $('#spinnerElem').show();
            },

            hideFilterSpinner: function() {
                $('#spinnerElem').hide();
            },

            displayErrorBanner: function(message) {
                new BannerView({
                    id: 'date-validation-failure',
                    container: $('.main-content>.container-fluid'),
                    style: 'error',
                    title: $.t(message.issue)
                }).render();
            }

        });
        return GridFilterView;
    }
);
