                this.collection.on('remove', this.render, this);
                this.collection.on('change', this._onCollectionChanged, this);
            },

            undelegateEvents: function() {
                this.collection.off('change', this._onCollectionChanged, this);
                this.collection.off('remove', this.render, this);
