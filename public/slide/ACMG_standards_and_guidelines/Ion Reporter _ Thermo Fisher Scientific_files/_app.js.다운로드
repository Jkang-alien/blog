define('views/variants/myVariantFileValidationView',['jquery', 'underscore', 'views/variants/myVariantFileValidationModalView', 'views/common/confirmFileUploadModalView','hb!templates/upload-myVariant-file.html',
    'models/configuration'],
    function($, _, MyVariantFileValidationModalView, ConfirmFileUploadModalView, uploadmyVariantFileTemplate, Configuration) {
        var MyVariantFileValidationView = MyVariantFileValidationModalView.extend({

            selectedType : '',

            initialize: function(options) {
                MyVariantFileValidationModalView.prototype.initialize.call(this, _.extend(options || {}, {
                    bodyTemplate: uploadmyVariantFileTemplate,
                    fileElement: '#myvariant-file-data',
                    uploadSuccess: _.bind(this.uploadSuccessCallback, this),
                    pollUrl: '/ir/secure/api/v40/analysis/validate/myVariantFiles/'
                }));
                _.extend(this, {
                    headerKey: 'analysis.myvariant.upload.header'
                });
                this.selectedPath = options.selectedPath;
                this.myVariantDBId = options.myVarDBId;
            },

            render: function() {
                MyVariantFileValidationModalView.prototype.render.apply(this, arguments);
            },

            uploadSuccessCallback: function(data) {
                var self = this;

                this.myVariantFile = {
                    id : data.result.uploadedFile.id,
                    length: data.result.uploadedFile.fileLength,
                    name: data.result.uploadedFile.name,
                    path: data.path
                };
                $.ajax({
                    url: '/ir/secure/api/v40/analysis/validate/myVariantFiles/' + data.result.uploadedFile.id + "/" + self.myVariantDBId,
                    type: 'GET',
                    contentType: 'application/json',
                    dataType: 'json',
                    success: _.bind(this.pollForSuccess, this),
                    error: _.bind(self._confirmation, self, this),
                    async: false
                }).done(function(data){
                    if (data.path) {
                        self.selectedPath(_.pluck(data.path, 'name'));
                    }
                });

            },

            onTypeChange: function(e) {
                this.selectedType = $(e.currentTarget).val();
            },

            getValidationStatus: function(data) {
                return data.status;
            },

            onHide: function(e) {
                e.preventDefault();
                this.$el.modal('hide');

            },

            _confirmation: function(parent, error) {
                if(JSON.parse(error.responseText).localizedError && JSON.parse(error.responseText).localizedError.errorCode.errorCode === '30121') {
                    var confirmFileUploadModalView = new ConfirmFileUploadModalView({
                        parent: parent,
                        data: parent.myVariantFile,
                        url: '/ir/secure/api/v40/analysis/validate/myVariantFiles/' +  parent.myVariantFile.id + "yes/" + parent.myVariantDBId,
                        requestMethod: 'GET'
                    });
                    confirmFileUploadModalView.render();
                    error.status = 200;
                } else {
                    this._uploadError(error);
                }
            },

            _handleValidFile: function(data) {

                if (this.myVariantFile.path) {
                    this.selectedPath(_.pluck(this.myVariantFile.path, 'name'));
                }
                var messageDescription = this.getSuccessDescription(data);
                this.$('.progress').removeClass('active progress-striped').addClass('progress-success');
                this.$('#validationProgressMessage').hide();
                this.$('#validationProgressIcon').hide();
                this.$('.upload-message').text($.t('file.upload.validation.success')+messageDescription);
                this.$('#submitFileUpload').attr('disabled',false);
                this.validationSuccess();
                this.setFileId(this.myVariantFile.id);
                this.$('#close').show();

            },

            getSuccessDescription: function(data) {
                return data.name!==undefined?data.name:'';
            },


            POLL_TIMEOUT: Configuration.getAsInt('pollTimeout.millis.vcfSpecimenFile')

        });

        return MyVariantFileValidationView;

    }
);
