                for(var i = 0 ; i < this._batchAnalysis.getLaunchables().length-1; i++) {
                    for(var j = i+1; j < this._batchAnalysis.getLaunchables().length; j++) {
                        if(this._batchAnalysis.getLaunchables()[i].toJSON().name === this._batchAnalysis.getLaunchables()[j].toJSON().name) {
                            if(this.listOfDuplicateAnalysisNames === '') {
                                this.listOfDuplicateAnalysisNames = this._batchAnalysis.getLaunchables()[i].toJSON().name;
                            }
                            else {
                                this.listOfDuplicateAnalysisNames = this.listOfDuplicateAnalysisNames + ', ' + this._batchAnalysis.getLaunchables()[i].toJSON().name;
