define('views/changePasswordView',[
    'jquery',
    'i18n',
    'backbone',
    'underscore',
    'models/changePasswordModel',
    'views/ParentView',
    'views/common/bannersView',
    'views/common/plugins/modalViewPlugin',
    'hb!templates/change-password.html'
], function (
    $,
    i18n,
    Backbone,
    _,
    ChangePasswordModel,
    ParentView,
    BannerView,
    ModalViewPlugin,
    template
) {
    

    var ChangePasswordView = ParentView.extend({

        events: {
            'keyup :input': '_keyUpInInput'
        },

        initialize: function () {
            this.listenTo(this.model, 'invalid', this._invalidModel);
            this.listenTo(this.model, 'request', this._clearAllVisibleErrors);
            this.listenTo(this.model, 'error', this._errorModel);
            this.listenTo(this.model, 'sync', this._syncModel);

            this.listenTo(this, ModalViewPlugin.Event.CONFIRM, this._onConfirm);
        },

        render: function () {
            this.$el.html(template(this.model.toJSON()));
            return this;
        },

        _keyUpInInput: function () {
            this._clearAllVisibleErrors();
            this._updateModelFromDom();
        },

        _addErrorToField: function (fieldName) {
            this.$('.control-group').has('input[name=' + fieldName + ']').addClass('error');
        },

        _invalidModel: function (model, errors, options) {
            this._clearAllVisibleErrors();
            var clientErrorsDiv = this.$('#changePasswordClientErrors');
            if (!options.silent) {
                _.forEach(errors, function (error) {
                    var bannerView = new BannerView({
                        container: clientErrorsDiv,
                        style: 'error',
                        title: error.message
                    });

                    bannerView.render();

                    this._addErrorToField(error.field);
                }, this);
            }
        },

        _clearAllVisibleErrors: function () {
            this.$('#changePasswordClientErrors').empty();
            this.$el.find('.control-group').removeClass('error');
        },

        _errorModel: function (model, response) {
            var error = JSON.parse(response.responseText);
            _.each(error.errors.allErrors, function(e) {
                if (e.field) {
                    this._addErrorToField(e.field);
                }
            }, this);
        },

        _syncModel: function () {
            this.model.set({
                existingPassword: '',
                newPassword: '',
                retypedNewPassword: ''
            });
            this.render();
        },

        _save: function (options) {
            this._updateModelFromDom();
            if (this.model.isValid()) {
                return this.model.save({}, options);
            } else {
                return false;
            }
        },

        _updateModelFromDom: function () {
            this.model.set({
                existingPassword: this.$('#existingPassword').val(),
                newPassword: this.$('#newPassword').val(),
                retypedNewPassword: this.$('#retypedNewPassword').val()
            });
        },

        _onConfirm: function() {
            var self = this;
            this._save().done(function() {
                BannerView.show({
                    style: 'success',
                    title: i18n.t('profile.changePassword.success')
                });
                self.$el.modal('hide');
            });
        }
    });

    new ModalViewPlugin(ChangePasswordView, {
        title: $.t('dialog.changePassword.title'),
        buttons: {
            confirm: {
                label: 'dialog.changePassword.confirm',
                cls: 'primary'
            },
            close: {
                label: 'dialog.changePassword.close'
            }
        }
    });

    return ChangePasswordView;
});
