                this.listenTo(this.techniqueFilterView, 'filter', this.onFilterTechnique);
                this.listenTo(this.groupFilterView, 'filter', this.onFilterGroup);
                this.listenTo(this.versionFilterView, 'filter', this.onFilterVersion);
