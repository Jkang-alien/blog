define('views/workflows/cnvBaselineFileValidationView',['jquery', 'underscore', 'views/common/fileValidationModalView', 'views/common/confirmFileUploadModalView','hb!templates/upload-cnv-baseline-file.html',
    'models/configuration'],
    function($, _, FileValidationModalView, ConfirmFileUploadModalView, uploadSpecimenFileTemplate, Configuration) {
        var CnvBaselineFileValidationView = FileValidationModalView.extend({

            selectedType : '',

            initialize: function(options) {
                FileValidationModalView.prototype.initialize.call(this, _.extend(options || {}, {
                    bodyTemplate: uploadSpecimenFileTemplate,
                    fileElement: '#cnv-baseline-file-data',
                    uploadSuccess: _.bind(this.uploadSuccessCallback, this),
                    pollUrl: '/ir/secure/api/v40/cnvbaseline/validate/cnvbaselineFiles/',
                    accept: ['zip']
                }));
                _.extend(this, {
                    headerKey: 'workflow.presets.upload.header'
                });
                this.selectedPath = options.selectedPath;
            },

            render: function() {
                FileValidationModalView.prototype.render.apply(this, arguments);
            },

            uploadSuccessCallback: function(data) {
                var self = this;

                this.cnvBaseline = {
                    id : data.result.uploadedFile.id,
                    length: data.result.uploadedFile.fileLength,
                    name: data.result.uploadedFile.name,
                    path: data.path
                };
                $.ajax({
                    url: '/ir/secure/api/v40/cnvbaseline/validate/cnvbaselineFiles/' + data.result.uploadedFile.id,
                    type: 'GET',
                    contentType: 'application/json',
                    dataType: 'json',
                    success: _.bind(this.pollForSuccess, this),
                    error: _.bind(self._confirmation, self, this)
                }).done(function(data){
                    if (data.path) {
                        self.selectedPath(_.pluck(data.path, 'name'));
                    }
                });
            },

            onTypeChange: function(e) {
                this.selectedType = $(e.currentTarget).val();
            },

            getValidationStatus: function(data) {
                return data.status;
            },

            onHide: function(e) {
                e.preventDefault();
                this.$el.modal('hide');
                if(e.currentTarget.id === 'close') {
                    window.location= "/ir/secure/workflows-presets.html#baseline";
                    window.location.reload();
                }
            },

            _confirmation: function(parent, error) {
                if(JSON.parse(error.responseText).localizedError.errorCode.errorCode === '30121') {
                    var confirmFileUploadModalView = new ConfirmFileUploadModalView({
                        parent: parent,
                        url: '/ir/secure/api/v40/cnvbaseline/validate/cnvbaselineFiles/' +  parent.cnvBaseline.id + "yes",
                        requestMethod: 'GET'
                    });
                    confirmFileUploadModalView.render();
                    error.status = 200;
                } else {
                    this._uploadError(error);
                }
            },

            _validationComplete: function() {

                if (this.cnvBaseline.path) {
                    this.selectedPath(_.pluck(this.cnvBaseline.path, 'name'));
                }
                var errorBanner = $('#ajaxerror > button')[0];
                if(errorBanner !== undefined) { $(errorBanner).click();}
                this.$('.progress').removeClass('active progress-striped').addClass('progress-success');
                this.$('#validationProgressMessage').hide();
                this.$('#validationProgressIcon').hide();
                this.$('.upload-message').text($.t('file.upload.validation.success'));
                this.validationSuccess();

            },

            POLL_TIMEOUT: Configuration.getAsInt('pollTimeout.millis.vcfSpecimenFile')

        });

        return CnvBaselineFileValidationView;

    }
);

