                window.location = "/ir/secure/analysis-launch.html?workflowId=" + workflowId;
            }
        },

        _onTechniqueFilter: function(filter) {
            localStorage.setItem('workflowTechniqueFilter', filter);
            if (_.isEmpty(filter)) {
                this.gridView.clearFilter('technique');
            } else {
                this.gridView.addFilter('technique', filter);
            }
        },

        _onVersionFilter: function(filter) {
            localStorage.setItem('workflowVersionFilter', filter);
            if (_.isEmpty(filter)) {
                this.gridView.clearFilter('versionFilter');
            } else {
                this.gridView.addFilter('versionFilter', filter);
            }
        },
        _onApplicationCategoryFilter: function(filter) {
            localStorage.setItem('workflowApplicationCategoryFilter', filter);
            if (_.isEmpty(filter)) {
                this.gridView.clearFilter('applicationCategoryFilter');
            } else {
                this.gridView.addFilter('applicationCategoryFilter', filter);
            }
        },


        _onReferenceGenomeFilter: function(filter) {
            localStorage.setItem('workflowReferenceGenomeFilter', filter);
            if (_.isEmpty(filter)) {
                this.gridView.clearFilter('referenceGenomeFilter');
            } else {
                this.gridView.addFilter('referenceGenomeFilter', filter);
            }
        },

        _onGroupFilter: function(filter) {
            localStorage.setItem('workflowGroupFilter', filter);
            if (_.isEmpty(filter)) {
                this.gridView.clearFilter('group');
            } else {
                this.gridView.addFilter('group', filter);
            }
        },

        _getSelectedWorkflowModel: function() {
            return this.detailView && this.detailView.model;
        },

        _getSelectedWorkflowModelId: function() {
            return this.detailView && this.detailView.model && this.detailView.model.id;
        },

        _onDelete: function() {
            var workflow = this._getSelectedWorkflowModel();
            if (workflow) {
                Confirm.open(_.bind(this._deleteWorkflow, this, workflow), {}, ConfirmDeleteWorkflow);
            }
        },

        _deleteWorkflow: function(workflow) {
            var self = this,
                json = workflow.toJSON();
            workflow.destroy({
                url: '/ir/secure/api/v40/workflows/' + workflow.get('id'),
                success: function() {
                    new BannerView({
                        id: 'success-banner',
                        container: $('.main-content>.container-fluid'),
                        style: 'success',
                        title: $.t('workflow.delete.success', { workflow: json })
                    }).render();

                    self.actionsView.$el.hide();
                    self.detailView.destroy();
                    self.gridView.refresh();
                    self.gridView.clearSelection();
                }
            });
        },

        _onBatchDelete: function() {
            var workflows = this.gridView.getSelected(),
                self = this,
                batch = new BatchWorkflows(workflows.models),
                totalWorkflows = batch.length;
            if (totalWorkflows) {
                MessageView
                    .open({
                        id: 'confirm-batch-delete',
                        title: $.t('confirm.batch.delete.title'),
                        message: $.t('batch.workflows.delete.confirm'),
                        buttons: {
                            confirm: {
                                label: 'confirm.yes'
                            },
                            close: {
                                label: 'confirm.no',
                                cls: 'primary'
                            }
                        }
                    })
                    .confirm(function() {
                        batch.destroy().done(function(response) {
                            var undeletedWorkflows = batch.length,
                                deletedWorkflows = totalWorkflows - undeletedWorkflows,
                                batchResult = new BatchResult(response);

                            if (deletedWorkflows) {
                                BannerView.show({
                                    id: 'success-banner',
                                    container: $('.main-content>.container-fluid'),
                                    style: 'success',
                                    title: $.t('batch.workflows.delete.response.success', {
                                        total: totalWorkflows,
                                        deleted: deletedWorkflows
                                    })
                                });
                            }

                            if (undeletedWorkflows) {
                                BannerView.show({
                                    id: 'error-banner',
                                    container: $('.main-content>.container-fluid'),
                                    style: 'error',
                                    sticky: true,
                                    title: $.t('batch.workflows.delete.response.error', {
                                        total: totalWorkflows,
                                        failed: undeletedWorkflows
                                    }),
                                    messages: batchResult.getErrorMessages()
                                });
                            }

                            self.gridView.clearSelection();
                            self.gridView.clearRow();
                            self.gridView.refresh();
                        });
                        MessageView.close();
                    });
            }
        },

        _onEdit: function(e, workflow) {
            var workflowId = workflow ? workflow.get('id') : this._getSelectedWorkflowModelId();
            if (workflowId) {
                window.location = "workflow/" + workflowId + "/edit";
            }
        },

        _onCopy: function() {
            var workflowId = this._getSelectedWorkflowModelId();
            if (workflowId) {
                window.location = "workflow/" + workflowId + "/copy";
            }
        },

        _onFlag: function() {
            var workflowId = this._getSelectedWorkflowModelId();
            if (workflowId) {
                window.location = "workflow/" + workflowId + "/favorite";
            }
        },

        _onTagUntagForExportToIRU: function() {
            var self = this;
            var workflowId = this._getSelectedWorkflowModelId();
            var modelName = this.detailView.model.get('name');
            if (workflowId) {
                $.ajax({
                    url: '/ir/secure/api/v40/workflow/' + workflowId + '/tagUntagForExportToIRU',
                    type: 'POST',
                    success : function() {
                        new BannerView({
                            id: 'tag-success-banner',
                            container: $('.main-content>.container-fluid'),
                            style: 'success',
                            title: $.t('workflow.tag.success', { workflowName: modelName})
                        }).render();
                        self.gridView.refresh();
                        self._onGridSelect(self.detailView.model);
                    }
                });
            }
        },
        _onUnflag: function() {
            var workflowId = this._getSelectedWorkflowModelId();
            if (workflowId) {
                window.location = "workflow/" + workflowId + "/unfavorite";
            }
        },

        _onLock: function() {
            var modelId = this._getSelectedWorkflowModelId();
            var modelName = this.detailView.model.get('name');
            var self = this;
            Confirm.open(function() {
                $.ajax({
                    url: '/ir/secure/api/v40/workflows/' + modelId + '/lock',
                    type: 'POST',
                    success : function() {
                        new BannerView({
                            id: 'lock-success-banner',
                            container: $('.main-content>.container-fluid'),
                            style: 'success',
                            title: $.t('workflow.lock.success', { workflowName: modelName})
                        }).render();
                        self.actionsView.$el.hide();
                        self.gridView.refresh();
                    }
                });
            }, {
                cancelClass: 'btn-primary',
                dialogName: 'confirm-workflow-lock'
            }, ConfirmLockWorkflow);
        },

        _displayUploadWorkflow: function(e) {
            e.preventDefault();
            var self = this;
            BaseModalView.open(
                _.bind(this._onUploadComplete, this),
                {
                    selectedPath: function(selectedPath) {
                        self.selectedPath = selectedPath;
                    }
                },
                WorkflowImportFileValidationView
            );
        },

        _onUploadComplete: function() {
            new BannerView({
                id: 'success-banner',
                container: $('.main-content>.container-fluid'),
                style: 'success',
                title: $.t('workflow.presets.file.upload.success')
            }).render();
        }
    });

    return WorkflowOverviewPageView;
});
