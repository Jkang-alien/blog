define('views/variants/variantsSampleFilterView',['jquery',
    'underscore',
    'views/templateView',
    'hb!templates/variants/variants-sample-filtering.html',
    'hb!templates/variants/variants-sample-display.html'
], function($,
    _,
    TemplateView,
    SampleFilteringTemplate,
    SampleDisplayTemplate) {
    

    var SampleFilterView = TemplateView.extend({

        initialize: function(options) {
            this.analysis = options.analysis;
            this.variantsSearchContext = options.variantsSearchContext;
            this.listenTo(this.analysis, 'change:specimenGroup', this.render, this);
        },

        events: {
            'click #filter-variants-by-sample': '_filterVariants'
        },

        render: function() {
            var roles = _.map(this.$(':checked'), function(x){ return $(x).val();});

            if(this._canFilter(this.analysis.get('specimenGroup'))) {
                this.$el.html(SampleFilteringTemplate(this.analysis.toJSON()));
                if(roles.length > 0) {
                    this._checkFilterVariants(roles);
                }
            } else {
                this.$el.html(SampleDisplayTemplate(this.analysis.toJSON()));
            }
            return this;
        },

        _checkFilterVariants: function(roles) {
            $('#samples-container input').each(function() {
                for (var i = 0; i < roles.length; i++) {
                    if(roles[i] === this.value) {
                        $('#samples-container input[value="' + this.value + '"]').prop('checked', true);
                    }
                }
            });
        },


        _canFilter: function(group) {
            return this.options.canFilterVariants &&
                group && group.get("groupType") === 'PAIRED';
        },

        _filterVariants: function(changeEvent) {
            var selectedRoles = _.map(this.$(':checked'), function(x){ return $(x).val();});

            this.variantsSearchContext.setVariantsBySpecimenFilter(selectedRoles);
            if (changeEvent) {
                this.variantsSearchContext.trigger('refreshVariantsGrid');
            }
        }

    });


    return SampleFilterView;
});
