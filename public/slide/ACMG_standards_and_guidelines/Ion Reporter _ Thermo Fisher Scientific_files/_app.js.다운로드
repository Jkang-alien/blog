                error: error
            }).always(function() {
                loadingView.hide();
            });
        },

        _displayCreateInProgress: function() {
            return new LoadingView({
                bodyKey: 'request.account.register.processing'
            }).render();
        },

        getCountries: function(success) {
            $.ajax({
                type: 'GET',
                url: 'requestAccount/countries',
                success: success
            });
        }

