define('views/finalReportTemplate/signOffSectionView',[ 'jquery', 'collections/BaseCollection', 'views/finalReportTemplate/finalReportSectionView', 'views/finalReportTemplate/authorsView',
        'hb!templates/finalReportTemplate/signoff-section.html' ],
        function($, BaseCollection, FinalReportSectionView, AuthorsView, template) {

    

    var SignOffSectionView = FinalReportSectionView.extend({
        _termsEl: '#authors',

        _template: template,

        initialize : function(options) {
            FinalReportSectionView.prototype.initialize.call(this, options);

            if (!this.model.get('authors')) {
                this.model.set('authors', new BaseCollection());
            }
            this.authorsView = new AuthorsView({
                collection : this.model.get('authors'),
                readonly : options.readonly || false,
                isEditable : options.isEditable
            });
        },
        events : {
            'click .report-header :radio' : '_onToggleIncludeExclude',
            'click #btn-add-author' : '_onAddTerm',
            'click .icon-trash' : '_onDeleteTerm',
            'keyup #name-text' : '_onEnableAdd',
            'keyup #qualification-text' : '_onEnableAdd'
        },

        render : function() {
            FinalReportSectionView.prototype.render.call(this);
            this.renderSubView(this.authorsView, this._termsEl);
            this.$('#btn-add-author').addClass('disabled');

            return this;
        },

        _onEnableAdd : function() {
            var name = this.$('#name-text').val().trim(),
                qualification = this.$('#qualification-text').val().trim();

            if (name.length > 0 && qualification.length > 0) {
                this.$('#btn-add-author').removeClass('disabled');
            } else {
                this.$('#btn-add-author').addClass('disabled');
            }
        },

        _onAddTerm : function(e) {
            e.preventDefault();
            var authors = this.model.get('authors'),
                name = this.$('#name-text').val().trim(),
                qualification = this.$('#qualification-text').val().trim();

            if (name.length && qualification.length) {
                authors.add({
                    name : name,
                    qualification : qualification
                });
                this.$('#name-text').val('');
                this.$('#qualification-text').val('');
                this.model.trigger('change');
            }
        },

        _onDeleteTerm : function(e) {
            e.preventDefault();
            var authors = this.model.get('authors'),
                cid = $(e.currentTarget).data('cid'),
                author = authors.get(cid);
            if (author) {
                authors.remove(author);
                this.model.trigger('change');
            }
        }
    });

    return SignOffSectionView;
});
