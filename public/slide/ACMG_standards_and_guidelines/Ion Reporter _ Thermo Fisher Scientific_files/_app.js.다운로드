        _captureChevronProgress: function(){
            var self = this;
            _.each(this.defaultSection, function(section){
                var finalReportSection = self.model.get(section);
                if(finalReportSection !== undefined){
                    self.chevronModel.get("configuration").fullAnalysisReport[section] = finalReportSection;
                } else if(typeof self.chevronModel.get("configuration").fullAnalysisReport[section] !== typeof undefined){
                    self.chevronModel.get("configuration").fullAnalysisReport[section].template.included = false;
                }
            });
            self.chevronModel.get("configuration").analysisReport = this.model.attributes;

            if(typeof self.model.get("reportedVariantsSection") !== typeof undefined){
                var selectedAnnotationsSet = [];
                _.each(self.chevronModel.get("configuration").selectedAnnotations, function(selectedAnnotations){
                    _.each(self.chevronModel.get("configuration").analysisReport.reportedVariantsSection.reportedVariants[0].availableAnnotations, function(availableAnnotations){
                        var obj = {};
                        if(availableAnnotations.key.keyName === selectedAnnotations.key) {
                            obj.key = availableAnnotations.key;
                            obj.factoryProvided = availableAnnotations.factoryProvided;
                            selectedAnnotationsSet.push(obj);
                        }
                    });
                });
                self.chevronModel.get("configuration").analysisReport.reportedVariantsSection.selectedAnnotations = selectedAnnotationsSet;
            }
        },

