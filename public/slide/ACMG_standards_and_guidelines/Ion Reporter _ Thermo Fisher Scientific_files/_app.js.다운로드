define('views/cnvbaseline/cnvBaselineTargetRegionsView',['jquery', 'views/ParentView', 'views/targetRegions', 'collections/targetRegions',
        'views/common/baseModalView', 'views/targetRegionFileValidationView',
        'views/common/bannersView', 'views/ampliseqImportView',
        'hb!templates/cnvbaseline/customTargetRegion.html'],
        function($, ParentView, TargetRegionsView, TargetRegionsCollection, BaseModalView, TargetRegionFileValidationView,
                BannerView, AmpliseqImportView, template) {
    

    var self;
    var CNVBaselineTargetRegionsView = ParentView.extend({
        
        events: {
            'click #uploadCustomRegion' : '_displayUploadTargetRegions',
            'click #importFromAmpliseq' : '_importFromAmpliseqHandler'
        },
        
        initialize: function() {
            this.listenTo(this.model, 'change', this.referenceGenomeChanged);
            this._targetRegions = new TargetRegionsCollection({
                baseUrl: this.model.urlRoot
            });
            self = this;
            this._targetRegions.getAllowed(this.model).done(function() {
                if(self.model.get('targetRegion') !== undefined){
                    self.render();
                }
            });

            this._targetRegionsView = new TargetRegionsView({
                collection: this._targetRegions,
                model: this.model
            });

            this._ampliseqImportView = new AmpliseqImportView();

            this.listenTo(this._targetRegions, 'change', this.render);
            this.listenTo(this._ampliseqImportView, 'targetRegionAdded', this._targetRegionAdded);
        },

        render: function() {
            this.$el.html(template);
            this._displayRegions();
            $('#spinnerElem').hide();
            $('#regions').prop('disabled', false);
            return this;
        },
        
        _displayRegions : function() {
            var baselineType = this.model.get('type');
            var disableTargetRegions = baselineType && baselineType.get('name') === this.model.WHOLE_GENOME,
                disableAmpliseqImport = baselineType && baselineType.get('name') === this.model.TARGETSEQ_EXOME;
            this.renderSubView(this._targetRegionsView, "#regionsDiv");
            this._ampliseqImportView.render(this.model.get('referenceGenome'));
            if (disableTargetRegions) {
                this.$('*')
                    .prop('disabled', true)
                    .addClass('disabled');
            }
            else if (disableAmpliseqImport) {
                this.$('#importFromAmpliseq')
                    .prop('disabled', true)
                    .addClass('disabled');
            }
        },

        _displayUploadTargetRegions: function(e) {
            e.preventDefault();
            var self = this;
            BaseModalView.open(function() {
                self._targetRegions.getAllowed(self.model, function() {
                    self._targetRegionsView.setSelected(self.uploadedFile);
                });
                new BannerView({
                    id: 'success-banner',
                    container: $('.main-content>.container-fluid'),
                    style: 'success',
                    title: $.t('targetRegion.file.upload.success')
                }).render();
            }, {
                onUploadSuccess: function(uploadedFile) {
                    self.uploadedFile = uploadedFile;
                },
                model: this.model
            }, TargetRegionFileValidationView);
            
        },

        _targetRegionAdded: function (e) {
            this._targetRegions.add(e.targetRegion);
            this._targetRegionsView.setSelected(e.targetRegion);
            new BannerView({
                id: 'success-banner',
                container: $('.main-content>.container-fluid'),
                style: 'success',
                title: $.t('import.ampliseq.fixedPanel.success')
            }).render();
        },

        _importFromAmpliseqHandler : function(e) {
            e.preventDefault();
            if (this._ampliseqImportView.isModalVisible() === false) {
                this._ampliseqImportView.$el.find('#ajaxerror').hide();
                this._ampliseqImportView.$el.find("#customPanelsListContainer").remove();
                this._ampliseqImportView.showModal();
            }
        },

        referenceGenomeChanged : function() {
            self = this;
            $('#regions').prop('disabled', true);
            $('#spinnerElem').show();
            if(this.model.get('type') !== undefined) {
                this._targetRegions.getAllowed(this.model).done(function() {
                    self.render();
                });
            }
            else {
                this._ampliseqImportView.render(this.model.get('referenceGenome'));
            }
        }

    });

    return CNVBaselineTargetRegionsView;
});
