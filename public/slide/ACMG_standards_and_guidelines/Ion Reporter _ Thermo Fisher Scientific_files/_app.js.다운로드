        _sortSelectedSections: function (){
            this.selectedSections.sort(function(previouse, next){
                return previouse.template.sequence-next.template.sequence;
            });
        },

        _sortAvailableSections: function (){
            var availableSectionIdentifier = this.$el.find(".available-sections");
            var availableSec = this.$el.find('.available-sections > li');
            var self = this;
            availableSec.sort(function(previous, next){
                if(self.model.get($(previous).find('.report-section').attr('id').charAt(0).toLowerCase() + $(previous).find('.report-section').attr('id').slice(1)) !== undefined && self.model.get($(next).find('.report-section').attr('id').charAt(0).toLowerCase() + $(next).find('.report-section').attr('id').slice(1)) !== undefined){
                    return self.model.get($(previous).find('.report-section').attr('id').charAt(0).toLowerCase() + $(previous).find('.report-section').attr('id').slice(1)).template.defaultSequenceId - self.model.get($(next).find('.report-section').attr('id').charAt(0).toLowerCase() + $(next).find('.report-section').attr('id').slice(1)).template.defaultSequenceId;
                }
            });

            _.each(availableSec,function(availableSection){
                availableSectionIdentifier.append(availableSection);
                $(availableSection).find('.report-widget').removeClass('widget-hover');
                $(availableSection).find('.quickview').addClass('hide');
            });

            this._displaySelectedSections();
            this._hideTobeSelectedSections();

        },

