            _saveStateCookie: function () {
                var reportedSections = $('.report-sections > li');
                var email = this.user.email;
                var state = {
                    preferedSections: []

                };
                _.each(reportedSections, function (reportedSection) {
                    if (reportedSection.id === 'header_section') {
                        state.preferedSections.push(
                            {
                                section: reportedSection.id,
                                name: $(reportedSection).find('#inputOrgName').val(),
                                address: $(reportedSection).find('#inputOrgAddress').val(),
                                imageSrc: $('#headersectionlogo-preview-img').attr('src')
                            });
                        $(reportedSection).find('#inputOrgName').text($(reportedSection).find('#inputOrgName').val());
                        $(reportedSection).find('#inputOrgAddress').text($(reportedSection).find('#inputOrgAddress').val());
                    }
                    else if (reportedSection.id === 'signoff_section') {
                        var rowCount = $(reportedSection).find("#authors tr").length;
                        state.preferedSections.push(
                            {
                                section: reportedSection.id,
                                data: rowCount
                            });
                    }
                    else {
                        state.preferedSections.push(
                            {
                                section: reportedSection.id,
                                data: $(reportedSection).find('textarea').val()
                            });
                        $(reportedSection).find('textarea').text($(reportedSection).find('textarea').val());
                    }
                }, this);

                localStorage.setItem(email, JSON.stringify(state));
            },

            _getSavedSections: function () {
                var email = this.user.email;
                if (localStorage.getItem(email) !== null) {
                    var state = JSON.parse(localStorage.getItem(email));
                    var sections = state.preferedSections;
                    return sections;
                }
                else {
                    return "";
                }

            },
