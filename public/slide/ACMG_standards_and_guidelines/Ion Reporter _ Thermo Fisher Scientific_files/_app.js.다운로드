    'jquery',
    'underscore',
    'backbone',
    'models/myVariantDB',
    'collections/workflowMyVariantDBs',
    'hb!templates/workflow/workflow-myVariantDB-select.html',
].concat('bootstrap.select'), function(
    $,
    _,
    Backbone,
    MyVariantDB,
    WorkflowMyVariantDBs,
    selectTemplate
) {

    

    var MyVariantDBSelectView = Backbone.View.extend({

        initialize: function() {
            this.model = this.options.model || null;
            this._myVariantDBs = new WorkflowMyVariantDBs();
        },

        events: {
            'change #myVariantDB-selection': '_selectionChanged'
        },

        render: function() {

            this._myVariantDBs.getAllowed(this.model,
                _.bind(function(model, response) {
                    this._myVariantDBs.set(response);
                    this._renderMyVariantDBSelection();
                }, this)
            );

            return this;
        },

        _renderMyVariantDBSelection: function() {
            this.$el.html(selectTemplate({
                myVariantDBs: this._myVariantDBs.toJSON()
            }));
            this._selectedMyVariantDBs = new WorkflowMyVariantDBs();
            if (this.model && this.model.getMyVariantDBs() !== undefined) {
                this._selectedMyVariantDBs = this.model.getMyVariantDBs();
            }
            if(this._selectedMyVariantDBs.length > 0){
                if(this._selectedMyVariantDBs.models) {
                    this.$('#myVariantDB-selection').val(this._selectedMyVariantDBs.models[0].id);
                } else {
                    this.$('#myVariantDB-selection').val(this._selectedMyVariantDBs[0].id);
                }
            } else {
                this._selectDefaultMyVariantDB();
            }
            this.$('#myVariantDB-selection').selectpicker({ size: 5 });
        },

        _selectionChanged: function(e) {
            var _selectedMyVariantDBId = $(e.currentTarget).val();
            this._selectedMyVariantDB = this._myVariantDBs.find(function(model) {
                return model.get('id') === _selectedMyVariantDBId;
            });
            if(this._selectedMyVariantDB !== null && this._selectedMyVariantDB !== undefined ) {
                this._selectedMyVariantDBs = new WorkflowMyVariantDBs();
                this._selectedMyVariantDBs.add(this._selectedMyVariantDB);
                this.model.setMyVariantDBs(this._selectedMyVariantDBs);
            }

        },

        _selectDefaultMyVariantDB: function() {
            var defaultMyVariantDBName = "";
            if(!_.isUndefined(this.model.get('referenceGenome'))) {
                if(this.model.get('referenceGenome').name === $.t('workflow.referenceGenome.GRCh38.name')) {
                    defaultMyVariantDBName = "MyVariantDefaultDb_GRCh38";
                }else if(this.model.get('referenceGenome').name === $.t('workflow.referenceGenome.hg19.name')) {
                    defaultMyVariantDBName = "MyVariantDefaultDb_hg19";
                }
            }

            var defaultMyVariantDB = this._myVariantDBs.find(function(model) {
                return model.get('name') === defaultMyVariantDBName;
            });

            if(defaultMyVariantDB !== null && defaultMyVariantDB !== undefined ) {
                this.$('#myVariantDB-selection').val(defaultMyVariantDB.id);
                this._selectedMyVariantDBs = new WorkflowMyVariantDBs();
                this._selectedMyVariantDBs.add(defaultMyVariantDB);
                this.model.setMyVariantDBs(this._selectedMyVariantDBs);
            }
        }

    });

    return MyVariantDBSelectView;
});
define('views/createMyVariantDBView',['jquery',
    'underscore',
    'views/formView',
    'models/myVariantDB',
    'views/errorsView',
    'views/validationErrorsView',
    'hb!templates/create-myVariantDB.html']
    .concat('bootstrap'),
    function($, _, FormView, MyVariantDBModel, ErrorsView, ValidationErrorsView, template) {

        

        var CreateMyVariantDBView = FormView.extend({

            el: '#createMyVariantDBModal',
            submitButtonSelector: '#createMyVariantDBSaveButton',

            initialize: function(options) {
                options = options || {};
                this.initializeModel(options);

                this._errorsView = new ErrorsView({
                    model: this.model
                });

            },

            initializeModel: function(options) {
                this.model = this.model || new MyVariantDBModel();
                this.completeAction = options.completeAction;
                this.refGenId = options.refGenId;
            },

            events: {
                'click .btn-secondary': 'closeDialog',
                'keyup input:not(:checkbox)': 'modelChanged'
            },

            render: function() {
                this._renderMyVariantDBForm();
                this.renderSubView(this._errorsView, "#errors");
                return this;
            },

            _renderMyVariantDBForm: function() {
                this.$el.html(template);
                this.$el.modal({
                    backdrop: 'static',
                    attentionAnimation: null,
                    keyboard: false,
                    show : true
                });
                this.validate();
            },

            modelChanged: function(e) {
                var field = $(e.currentTarget);
                this.model.set(field.attr('name'), field.val().trim());
                this.validate();
            },

            save: function() {
                this.$('.control-group.error').removeClass('error').find('i.icon-warning-sign').remove();
                var self = this;
                $.ajax({
                    url: this.model.urlRoot + '/' + this.refGenId,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(this.model.toJSON()),
                    success: function(response) {
                        self._onSaveSuccess(response);
                    },
                    error: function(jqxhr) {
                        self._onSaveError(jqxhr);
                    }
                });
            },

            _onSaveSuccess: function(response) {
                this.closeDialog();
                if (_.isFunction(this.completeAction)) {
                    this.completeAction(response);
                }
            },

            _onSaveError: function(jqxhr) {
                this.disableButton(this.submitButtonSelector);
                $('.icon-loader').hide();
                if (jqxhr.status <= 400) {
                    var clientErrorsDiv = this.$('.modal-body #errors');
                    ValidationErrorsView.show(jqxhr, clientErrorsDiv);
                }
            },

            closeDialog: function() {
                this.$el.modal('hide');
                this.undelegateEvents();
            },

            validate: function() {
                var modelErrors = this.model.validate();
                var nameErrors = this.validateName();
                if (modelErrors || nameErrors) {
                    this.disableButton(this.submitButtonSelector);
                } else {
                    this.enableButton(this.submitButtonSelector);
                }
            },

            validateName: function() {
                var name = this.model.get('name').replace(/\s+/g,' ').trim();
                if(name === 'MyVariantDefaultDb_GRCh38' || name === 'MyVariantDefaultDb_hg19' || name === 'My Variants') {
                    return true;
                } else {
                    return false;
                }
            }
        });

        return CreateMyVariantDBView;
    });

