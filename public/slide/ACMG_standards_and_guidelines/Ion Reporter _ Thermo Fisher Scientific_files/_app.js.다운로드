            if(this.annotationClassification !== "Summary"){

                var self = this;
                var selectColumns = [];
                if(!_.isUndefined($(this.gridEl).data('kendoGrid'))){
                    _.each($(this.gridEl).data('kendoGrid').getOptions().columns, function(column) {
                        if (column.field && column.title && !_.contains(self.staticColumns, column.field)) {
                            selectColumns.push(column);
                        }
                    });
                }

                selectColumns = this.orderSelectColumns(selectColumns);

                this.data.dataSource = selectColumns;
                this.render();
