        _mainTemplateJson: function(model) {
            var self = this,
            modelJson = model.toJSON();
            if (modelJson.analysis.specimenGroup) {
                _.each(modelJson.analysis.specimenGroup.members, function(member) {
                    member.specimen.attributes = _.reject(member.specimen.attributes, function(specAttribute) {
                        return _.contains(self._excludedSpecimenAttributes, specAttribute.attribute.name);
                    });
                });
                _.each(modelJson.analysis.specimenGroup.members, function(member) {
                    member.specimen.attributes.sort(function(a, b){
                        return a.attribute.name.localeCompare(b.attribute.name);
                    });
                });
            }
            if (modelJson.variantDetailsSection && modelJson.variantDetailsSection.reportedVariants) {
                _.each(modelJson.variantDetailsSection.reportedVariants, function(reportedVariant) {
                    _.each(reportedVariant.variantsBySample, function(variantBySample) {
                        variantBySample.isCNV = reportedVariant.isCNV;
                        variantBySample.isFusion = reportedVariant.isFusion;
                        variantBySample.gene = reportedVariant.gene;
                        variantBySample.copyNumber = reportedVariant.copyNumber;
                        variantBySample.locus = reportedVariant.locus;
                    });
                });
            }
            var signOffAuthors = null;
            if(modelJson.signOffSection !== undefined && modelJson.signOffSection.section !== undefined){
                signOffAuthors = modelJson.signOffSection.section.get('authors').toJSON();
            }
            return _.extend(modelJson, this.subTemplates, {
                launchedBy : this._formatName(modelJson.analysis.createdBy),
                analyzedBy : this._formatName(modelJson.analysis.analyzedBy),
                geneDisplayCount : Configuration.getAsInt('report.gene.count.display'),
                references: modelJson.analysis.references && modelJson.analysis.references.length > 0 ? modelJson.analysis.references : null,
                workFlowStatus : modelJson.analysis.isFromLockedWorkflow,
                signOff_authors: signOffAuthors
            });
        },

        _formatName: function(user) {
            if (user) {
                return user.firstName + ' ' + user.lastName;
            }
            return 'undefined';
        },

        _captureComment : function() {
