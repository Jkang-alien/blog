define('views/targetRegions',['jquery',
		'underscore',
		'backbone',
		'events/eventDispatcher',
		'views/common/confirmModalBodyView',
		'hb!templates/workflow-target-region.html',
		'hb!templates/select2DefaultIcon.html',
		'hb!templates/select2FactoryShippedIcon.html'
	].concat(
         'select2'
    ), function($,
				_,
				Backbone,
				dispatcher,
				ConfirmModalBodyView,
				template,
				select2DefaultIcon,
				select2FactoryShippedIcon) {

	

	var TargetRegionsCollectionView = Backbone.View.extend({

		initialize: function() {
			this.model = this.options.model || null;
			this.confirmModal = ConfirmModalBodyView;
		},

		events: {
			'change select#regions': 'selectionChanged'
		},

		render: function() {
			this.$el.html(template({
				regions: this.collection.toJSON()
			}));

			$('#regions').select2({
                templateResult: _.bind(this.format, this),
                minimumResultsForSearch: Infinity,
                dropdownAutoWidth : 'true',
                width: 'resolve',
                theme: 'classic'

            });

			this.selected = this.model && this.model.get('targetRegion') || null;
			if (this.selected) {
				this._resetSelection();
			} else {
				this.$el.find('select#regions').val('').trigger('change.select2');
			}

			return this;
		},

		selectionChanged: function(e) {
			this.setSelected($(e.currentTarget).val());
		},
        setSelected: function(targetRegion) {
			this._confirmAndUpdateSelected(this.collection.get(targetRegion));
        },

		_confirmAndUpdateSelected: function(newTargetRegion) {
			if (this.model.isNew() || this._typesMatch(newTargetRegion)) {
				this._updateSelected(newTargetRegion);
				this.render();
				return;
			}

			var update = _.bind(function() {
				this._updateSelected(newTargetRegion);
			}, this);
			this.confirmModal.open(update, {
				headerKey: $.t('workflow.reference.edit.targetregions.confirm.head'),
				warning: $.t('workflow.reference.edit.targetregions.confirm.warn', {
					targetRegionName: newTargetRegion ? newTargetRegion.get('name') : 'no selection'
				}),
				description: $.t('workflow.reference.edit.targetregions.confirm.desc'),
				cancelClass: 'btn-primary',
				onHide: _.bind(function() {
					this.render();
				}, this)
			});
		},

		_updateSelected: function(newTargetRegion) {
			this.selected = newTargetRegion;
			this.model.set('targetRegionConfigurationChoice', null);
			this.model.set('targetRegion', this.selected);
			dispatcher.trigger('targetRegions:selectionChanged');
		},

		_resetSelection: function () {
			var _id = _.isString(this.selected.id) ? this.selected.id : this.selected.get("id");
			this.$el.find('select#regions').val(_id).trigger('change.select2');
		},

		_typesMatch: function(newTargetRegion) {
			var newTargetRegionType = newTargetRegion && newTargetRegion.get('type');
			var selectedType = this.selected && this.selected.get('type');
			return (selectedType === newTargetRegionType);
		},

		format: function(opt) {
            var option;
            if (!opt.id || !this.getFactoryProvided(opt.id)) {
                var t = select2DefaultIcon({text: opt.text});
                option = $(t);
                return option;
            }
            var temp = select2FactoryShippedIcon({
                text: opt.text
            });
            option = $(temp);
            return option;
        },

        getFactoryProvided: function(region) {
            if(!region) { return false; }
            return this.collection.get(region).get('factoryProvided');
        }

	});

	return TargetRegionsCollectionView;
});
