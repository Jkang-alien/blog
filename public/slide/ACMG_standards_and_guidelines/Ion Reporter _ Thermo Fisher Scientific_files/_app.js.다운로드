    function($,
             _,
             Backbone,
             SummaryTabGridView,
             analysisImmuneRepertoireTabView,
             multiSampleGridView,
             searchView,
             ImmuneRepertoireResultTemplate,
             multiSampleResultTemplate) {

        

        var GridOverview = '#summary-grid';
        var ResultView = '#immuneRepResult';

        var ImmuneRepertoireResultView = Backbone.View.extend({

            template : ImmuneRepertoireResultTemplate,
            initialize: function() {
                this.data = null;
                this.analysisIds = this.options.analysisIds;
                this.urlBase = null;
                this.searchView = new searchView();
                this.searchView.on('search', this._onSearch, this);

            },

            delegateEvents: function() {
                Backbone.View.prototype.delegateEvents.apply(this, arguments);
                this.searchView.on('search', this._onSearch, this);
            },

            undelegateEvents: function() {
                this.searchView.off('search', this._onSearch, this);
                Backbone.View.prototype.undelegateEvents.apply(this, arguments);
            },

            _onGridMultiSelect: function() {
                if (this.gridView.getSelected().length > 1) {
                    $('#compareMultiSample').removeClass('disabled').prop('disabled', false);
                } else {
                    $('#compareMultiSample').addClass('disabled').prop('disabled', true);
                }
            },

            events: {
                "click #view_sample_result": "_view_sample_result",
                "click #compareMultiSample": "_compareMultiSample",
                "click #cloneSummary" : "_cloneSumDown",
                "click #graphs" : "_graphsDown",
                "click #multiCloneSummary" : "_multiCloneSummaryDownload",
                "click #aggregateMetrics" : "_aggregateMetricsDownload",
                "click #multiCountSummary" : "_multiCountSummary",
                "click #BackToSummary" : "_BackToSummary"
            },

            _BackToSummary: function() {
                this.gridView.clearFilter('q');
                this.render();
            },

            _cloneSumDown: function(e) {
                var selectedid = e.currentTarget.getAttribute("data-id");
                var url = "/ir/secure/analyses/"+ selectedid + "/immunerepertoire";
                window.location = url + "/txt";
            },

            _graphsDown: function(e) {
                var selectedid = e.currentTarget.getAttribute("data-id");
                var url = "/ir/secure/analyses/"+ selectedid + "/immunerepertoire";
                window.location = url + "/png";
            },

            _multiCloneSummaryDownload: function() {
                window.location = this.urlBase + "/multiCloneSummaryDownload?ids=" + encodeURIComponent(this.analysisIDS);
            },

            _aggregateMetricsDownload: function() {
                window.location = this.urlBase + "/aggregateMetricsDownload?ids=" + encodeURIComponent(this.analysisIDS);
            },

            _multiCountSummary: function() {
                window.location = this.urlBase + "/count?ids=" + encodeURIComponent(this.analysisIDS);
            },
            render: function() {
                this.urlBase = '/ir/secure/analyses/' + this.analysisIds[0] + '/immunerepertoire';
                this.$el.html(this.template({
                    pathList: this.data,
                    baseUrl: this.urlBase
                }));
                $('#ana').html(' <h1><i class="img img-dash-analysis half-size"></i>&nbsp;Immune Repertoire Results</h1>');
                $('#BackToSummary').hide();
                $('#analysisOverviewSwitchToBtn').hide();
                $('#compareMultiSample').addClass('disabled').prop('disabled', true);

                this.searchView.setElement(this.$('#query-form')).render();
                this._renderSummaryTab();
                return this;
            },

            setData: function(url, data) {
                this.data = data;
                this.urlBase = url;
                return this;
            },

            _renderSummaryTab: function(){
                var urlGrid = '/ir/secure/analyses/' + encodeURIComponent(this.analysisIds) + '/immunerepertoire?ids=' + encodeURIComponent(this.analysisIds) + "&";

                this.gridView = new SummaryTabGridView({
                    urlBase : urlGrid,
                });
                this.gridView.on('multiSelect', this._onGridMultiSelect, this);

                this.gridView.setElement(this.$(GridOverview)).render();

            },

            _onSearch: function(query) {
                if (_.isEmpty(query)) {
                    this.gridView.clearFilter('q');
                } else {
                    this.gridView.addFilter('q', query);
                }
            },

            _view_sample_result: function(e){
                var selectedid = e.currentTarget.getAttribute("data-id");
                var url = "/ir/secure/analyses/"+ selectedid + "/immunerepertoire";
                this.analysisImmuneRepertoireTabView = new analysisImmuneRepertoireTabView({
                    analysisId : selectedid,
                    urlBase : url
                });
                this.analysisImmuneRepertoireTabView.setElement(this.$(ResultView)).render();
            },

            _compareMultiSample: function() {
                $('#BackToSummary').show();
                $('#analysisOverviewSwitchToBtn').hide();
                var selectedSamples = this.gridView.getSelected().models;
                var analysisIDS = [];
                this.analysisIDS = analysisIDS;
                var self = this;
                _.each(selectedSamples, function(sample){
                    self.analysisIDS.push(sample.get('id'));
                });
                this.$('#immuneRepResult').html("");
                this.$('#immuneRepResult').html(multiSampleResultTemplate);
                $('#formview').show();
                this.searchView.setElement($('#queryform')).render();

                $.ajax({
                    url: '/ir/secure/api/v40/analyses/immunerepertoire/sampleslist?ids=' + encodeURIComponent(this.analysisIDS),
                    type: 'GET',
                    success: function(response) {
                        self.gridView = new multiSampleGridView({
                            analysisIds:self.analysisIDS,
                            samples: response
                        });
                        self.gridView.setElement(self.$('#multiSampleGrid')).render();
                    }
                });



            }
        });

        return ImmuneRepertoireResultView;
    }
);
define('views/analysis/mutationalLoad/analysisMutationalLoadResultView',[ 'jquery',
         'underscore',
         'backbone',
         'utils/asyncDownloader',
         'hb!templates/analysis/mutationalLoadResult.html'].concat('bootstrap.select'),
    function($,
             _,
             Backbone,
             AsyncDownloader,
             MutationalLoadResultTemplate) {

        

        var MutationalLoadResultView = Backbone.View.extend({

            template : MutationalLoadResultTemplate,

            events: {
                'optionChanged.bs.select #compare-ss-views': '_viewOptionChanged',
                'click #download-variant-details': '_downloadVariantDetails',
                'click #download-pdf': '_downloadPDF'
            },
            render: function() {
                this.$el.html(this.template(this.data));
                this.$(".selectpicker").selectpicker();
                this._loadImage();
                return this;
            },

            _viewOptionChanged: function(e,option) {
                var selectedImagePath = option.option.data('path');
                var targetId = option.option.data('id');
                var targetIdList = targetId.split(',');
                var selectedImagePaths = selectedImagePath.split(',');
                this.$('#ss-image-section>div').addClass('hide');
                var self = this;
                _.each(targetIdList, function(targetImage, i){
                    if(self.$("#"+targetImage).attr("src") === undefined || self.$("#"+targetImage).attr("src") === ""){
                        if(!_.isUndefined(selectedImagePaths) && !_.isUndefined(selectedImagePaths[i])){
                            self._loadImage(selectedImagePaths[i], targetImage);
                        }
                    } else {
                        self.$('#ss-image-section .'+targetImage).removeClass('hide');
                    }
                });
            },

            _loadImage: function(selectedImagePath, targetId){
                if(_.isUndefined(selectedImagePath)){
                    selectedImagePath = this.$("#compare-ss-views option[data-id='ss1-graph']").attr('data-path');
                    targetId = "ss1-graph";
                }
                this.$('#ss-image-section .'+targetId).removeClass('hide');
                var self = this;
                $.ajax({
                    url: '/ir/secure/analyses/'+this.data.analysisId+'/fileResource',
                    data:{filePath: selectedImagePath},
                    type: 'POST',
                    success: function(data) {
                        self.$("#"+targetId).attr("src","data:image/png;base64,"+data);
                    }
                });
            },

            setData: function(data) {
                this.data = data;
            },

            _downloadVariantDetails: function (e) {
                e.preventDefault();
                this._downloadData("/ir/secure/analyses/"+this.data.analysisId+"/mutationalload/download/variantdetails", 'sample.auditlog.export.processing');
            },

            _downloadPDF: function (e) {
                e.preventDefault();
                this._downloadData("/ir/secure/analyses/"+this.data.analysisId+"/mutationalload/download/pdf", 'sample.auditlog.export.processing');
            },

            _downloadData: function(url, loadingViewKey) {
                var asyncDownloader = new AsyncDownloader();
                asyncDownloader.download(url, loadingViewKey);
            }

        });

        return MutationalLoadResultView;
    }
);

