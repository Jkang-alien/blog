define('views/common/grid/analysisColumnsSelectView',['jquery', 'underscore', 'backbone','models/analysis/analysisModel','views/kendoTreeView', 'views/formView', 'events/eventDispatcher', 'hb!templates/grid/analysis-columns-select-modal.html', 'hb!templates/grid/grid-column-values.html', 'hb!templates/grid/grid-column-date.html', 'hb!templates/grid/grid-column-metadata-date.html', 'hb!templates/grid/grid-column-icon-header.html', 'views/loadingView'],
    function($, _, Backbone, Analysis, KendoTreeView, FormView, dispatcher, template, gridColumnValuesTemplate, gridColumnDateTemplate, gridColumnMetadataDateTemplate, iconHeaderTemplate, LoadingView) {
        

        var DATE_COLUMNS = [
            'createdOn',
            'analyzedOn',
            'reportPublishedOn',
            'specimenGroup.specimen.createdOn'
        ];

        var AnalysisColumnsSelectView = FormView.extend({

            submitButtonSelector: '#analysis-column-btn-apply',

            _defaultAttributes: ['name', 'specimenGroup.specimen.projects', 'createdOn'],

            initialize : function() {
            },

            events : {
                'click #analysis-columns input': '_onColumnCheck',
                'click #analysis-columns label': '_onLabelClick'
            },

            render : function(options) {
                options = options || {};
                var self = this;
                self.defaultColumns = options.defaultColumns;
                self.loadingView = new LoadingView({
                    bodyKey: 'analysis.fetch.columns'   //changed from samples
                });
                self.loadingView.render();
                var allGridColumns = [];
                _.each(options.allAvailableColumns, function (attributeColumn) {
                        if (!_.contains(_.pluck(allGridColumns, 'field'), attributeColumn.name)) {
                            allGridColumns.push({
                                title: attributeColumn.name,
                                hidden: true,
                                field: attributeColumn.id,
                                factoryProvided: attributeColumn.factoryProvided
                            });
                        }
                    });

                self._renderModel(allGridColumns, options.summaryColumnDetails);
                return this;
            },

            _renderModel: function (allGridColumns, summaryColumnDetails) {
                var allColumns = [];

                var selectedColumns = _.reject(summaryColumnDetails, function (column) {
                    return column.hidden === true;
                });
                _.chain(allGridColumns)
                .sortBy(function (column) {
                    return column.title.toLowerCase();
                })
                .each(function (column) {
                    if(_.contains(_.pluck(summaryColumnDetails, 'field'), column.field)){
                        column.hidden = false;
                    }
                    allColumns.push(column);
                }).value();

                var t = {
                    allColumns: allColumns,
                    summaryColumns: selectedColumns
                };

                this.$el.html(template(t));

                this.$el.modal({
                    backdrop: 'static',
                    attentionAnimation: null,
                    keyboard: false,
                    show : true
                });
                this.disableButton(this.submitButtonSelector);
                this.analysisColumnsInSummary = $('#analysis-columns-in-summary');
                this.loadingView.hide();
            },

            _onLabelClick: function(e) {
                e.stopPropagation();
            },

            _onColumnCheck: function(e) {
                e.stopPropagation();
                if ($('#analysis-columns input:checkbox').is(':checked')) {
                    this.enableButton(this.submitButtonSelector);
                } else {
                    this.disableButton(this.submitButtonSelector);
                }
                var target = $(e.target);

                if (target.is(':checked')) {
                    this.analysisColumnsInSummary.append('<li>'+($(target).data('factoryprovided') ? '<i style="vertical-align:super;" class="ion-factory-shipped" title="Ion factory shipped"></i>' : '')+'<label data-displaystring="'+ $(target).data('displaystring') +'" data-field="' + $(target).data('field') +'" data-title="'+target.val()+'" data-factoryProvided="' + $(target).data('factoryprovided') + '" style="display:inline-block">'+ target.val() +'</label></li>');
                } else {
                    this.analysisColumnsInSummary.find('label[data-field="' + $(target).data('field') + '"]').parent('li').remove();
                }
            },

            save: function() {
                var newSummaryColumns = this.analysisColumnsInSummary.find('li > label');
                var selectedOptions = [];
                var self = this;
                _.each(newSummaryColumns, function (column) {
                    var fieldVal = $(column).data('field').toString();
                    var selectedColumn = _.find(self.defaultColumns, function(temp){
                                            if(fieldVal === temp.field){
                                                return true;
                                            }
                                        });

                    selectedColumn = selectedColumn || {title: $(column).html(),field: fieldVal};

                    if(_.contains(DATE_COLUMNS, selectedColumn.field) && _.isUndefined(selectedColumn.template)) {
                        selectedColumn.template = gridColumnDateTemplate.forField(selectedColumn.field);
                    } else if( (selectedColumn.field.indexOf('workflow.') === 0 ||
                          selectedColumn.field.indexOf('specimenGroup.') === 0 ||
                          selectedColumn.field.indexOf('plugins') === 0 ||
                          selectedColumn.field.indexOf('fullName') > -1) &&
                          _.isUndefined(selectedColumn.template) ) {

                        if(selectedColumn.field.indexOf('plugins') === 0){
                            selectedColumn.template = gridColumnValuesTemplate.withFilter(function(ctx) {
                                var plugins = ctx.toJSON().plugins;
                                var pluginNames = [];
                                if(null !== plugins && !_.isUndefined(plugins)) {
                                    _.each(plugins, function(pl) {
                                            if(null !== pl && !_.isUndefined(pl.name)) {
                                                pluginNames.push({'name':pl.name});
                                            }
                                        });
                                }
                                return {
                                    'names': pluginNames
                                };
                            });

                        } else if(selectedColumn.field === 'specimenGroup.specimen.metadata.Run Date') {
                            selectedColumn.template = gridColumnMetadataDateTemplate.withFilter(function(ctx) {
                                return {'date': new Analysis(ctx.toJSON()).getAttribute(selectedColumn.field, 1)};
                            });
                        } else{
                            selectedColumn.template = gridColumnValuesTemplate.withFilter(function(ctx) {
                                return {
                                    names: new Analysis(ctx.toJSON()).getAttribute(selectedColumn.field,1)
                                };
                            });
                        }
                    }
                    selectedColumn.name = $(column).data('title');
                    selectedColumn.factoryProvided = $(column).data('factoryprovided') || false;
                    selectedColumn.headerTemplate = !selectedColumn.factoryProvided ? iconHeaderTemplate({
                        icon: 'icon-asterisk',
                        title: 'Custom',
                        headerName:selectedColumn.title
                    }) : undefined;
                    selectedColumn.attributes = {'class': 'vertical-align-top'};
                    selectedOptions.push(selectedColumn);
                });

                dispatcher.trigger('grid:applycolumns', selectedOptions);
                this.$el.modal('hide');
            }
        });

        return AnalysisColumnsSelectView;
    });
define('views/common/grid/autoPageTransport',[
    'underscore',
    'views/common/grid/transport'
],  function(_, Transport){

    

    return Transport.extend({
            page: 1,
            pageSize: 500,
            items : [],
            fetchPage: function(page){
                this.options.data.page = page;
                this.options.data.take = this.pageSize;
                this.options.success =  _.bind(this.onFetch, this);
                Transport.prototype.read.call(this, this.options);
            },
            onFetch: function(data){
                this.items = this.items.concat(data.content);
                if(data.last){
                    data.content = this.items;
                    this.onLastPage.call(this, data);
                } else {
                    this.page += 1;
                    this.fetchPage(this.page);
                }
            },
            read: function(options) {
                this.options = options;
                this.onLastPage = this.options.success;
                this.fetchPage(this.page);
            }
        });
});

