                this.sequences.push({
                    name : defline,
                    sequence : sequence
                });
            },
            _appendToCurrentFastaEntry : function(seq) {
                var currentFastaEntry = this.sequences[this.sequences.length - 1];
                if (currentFastaEntry.sequence) {
                    currentFastaEntry.sequence += seq;
                } else {
