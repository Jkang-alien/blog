define('views/variants/analysesVariantsTabsView',['jquery',
        'underscore',
        'views/templateView',
        'events/eventDispatcher',
        'hb!templates/variants/analyses-variants-tabs.html'],
        function($,
                _,
                TemplateView,
                dispatcher,
                analysesVariantsTabsTemplate) {

    

    var AnalysesVariantsTabsView = TemplateView.extend({

        _template: analysesVariantsTabsTemplate,
        _selectedHash: '#variants',
        _previousSelectedHash: '#variants',
        _heatMapsHash: ['#gene', '#annotation', '#fusion', '#igvlight'],

        initialize: function(opts) {
            var options = opts || {};
            this._variantsOverviewPageView = options.variantsOverviewPageView;
            this._applicationTypes = this._variantsOverviewPageView.applicationTypes;
        },

        events: {
            'click li a[href][data-toggle="tab"]': '_renderClickedTab',
        },

        delegateEvents: function() {
            TemplateView.prototype.delegateEvents.apply(this, arguments);
            dispatcher.on('filterChain:getFilterMetrics', _.bind(this._onFilterSelectionChanged, this));
        },

        undelegateEvents: function() {
            dispatcher.off('filterChain:getFilterMetrics');
            TemplateView.prototype.undelegateEvents.apply(this, arguments);
        },

        render: function() {
            var isBrca = this._isBRCAWorkflow();
            var isOnlyPlugin = false;

            for(var i=0; i<this._applicationTypes.length; i++) {
                if(this._applicationTypes[i] === "RUN_TS_PLUGIN") {
                    isOnlyPlugin = true;
                } else {
                    isOnlyPlugin = false;
                    break;
                }
            }

            this._areAllAnalysisAneuploidyType = this._areAllAnalysisAneuploidyType();

            this._activeClass = {
                variantsClass: '',
                irgvClass: '',
                brcaClass: ''
            };

            if(isOnlyPlugin) {
                this._tabsEnabled = {
                    plugin: (this.options.hosted !== undefined) && !this.options.hosted && this._isPluginEnabled(),
                };
            } else {
                this._tabsEnabled = {
                    variants: !isBrca,
                    geneffects: !this._areAllAnalysisAneuploidyType && !isBrca,
                    fusion: this._isAnyAnalysisFusionsType() && !isBrca,
                    cnv: this._isCNVModuleAvailable() && !isBrca,
                    irgv: this._isIGVTabEnaledForNonAneuploidy(),
                    plugin: (this.options.hosted !== undefined) && !this.options.hosted && this._isPluginEnabled(),
                    brca: isBrca
                };
            }

            if (this._areAllAnalysisAneuploidyType) {
                this._activeClass.irgvClass = 'active';
                this._selectedHash = "#igvlight";
                this._previousSelectedHash = "#igvlight";
            } else if (isBrca) {
                this._activeClass.brcaClass = 'active';
                this._selectedHash = '#brca';
                this._previousSelectedHash = '#brca';
            } else if (isOnlyPlugin) {
                this._activeClass.pluginClass = 'active';
                this._selectedHash = '#pluginResults';
                this._previousSelectedHash = '#pluginResults';
            } else {
                this._activeClass.variantsClass = 'active';
                this._selectedHash = '#variants';
                this._previousSelectedHash = '#variants';
            }
            this.$el.html(this._template({
                activeClass: this._activeClass,
                enabledTabs: this._tabsEnabled
            }));
            return this;
        },

        renderCurrentTab: function() {
            this._renderTab(this._selectedHash);
        },

        _renderClickedTab: function(e) {
            e.preventDefault();
            this._previousSelectedHash = this._selectedHash;
            this._selectedHash = e.currentTarget.hash;
            if(this._selectedHash !== '#igvlight') {
                window.igvlight_stopped = true;
            }
            dispatcher.trigger('pluginTabChanged', this._previousSelectedHash.substring(1), this._selectedHash.substring(1));
        },

        _renderTab: function(hash) {
            switch (hash) {
            case '#variants':
                this._variantsOverviewPageView.renderVariantsGrid();
                break;
            case '#geneffects':
                this._variantsOverviewPageView.renderGeneffectsPlugin();
                break;
            case '#cnv':
                this._variantsOverviewPageView.renderCnvPlugin();
                break;
            case '#fusion':
                this._variantsOverviewPageView.renderFusionPlugin();
                break;
            case '#igvlight':
                this._variantsOverviewPageView.renderIgvLightPlugin();
                break;
            case '#brca':
                this._variantsOverviewPageView.renderBRCAReport();
                break;
            case '#pluginResults':
                this._variantsOverviewPageView.renderPluginResultsView();
                break;
            }
        },

        _onFilterSelectionChanged: function() {
            if (_.indexOf(this._heatMapsHash, this._selectedHash) > -1) {
                dispatcher.trigger('variantsgrid:OnAfterParse');
            }
        },

        _isAnyAnalysisFusionsType: function() {
            var isAnyFusionType = false;
            _.each(this._applicationTypes, function (applicationType) {
                if(_.isEqual(applicationType, "RNA") || _.isEqual(applicationType, "DNA_RNA") ) {
                    isAnyFusionType = isAnyFusionType || true;
                }
            });
            return isAnyFusionType;
        },

        _areAllAnalysisAneuploidyType: function() {
            var areAllAneuploidyType = true;
            _.each(this._applicationTypes, function (applicationType) {
                if(!_.isEqual(applicationType, "ANEUPLOIDY")) {
                    areAllAneuploidyType = areAllAneuploidyType && false;
                }
            });
            return areAllAneuploidyType;
        },

        _isIGVTabEnaledForNonAneuploidy : function() {
            var enableIGVTab = false;
            this.showIGVTabForNonAneuploidy = $.t('isIGVTabEnaledForNonAneuploidy');
            if(this._areAllAnalysisAneuploidyType || (this.showIGVTabForNonAneuploidy === 'true'))
            {
                if(this._areAllAnalysisAneuploidyType)
                {
                    this._selectedHash = "#igvlight";
                }
                enableIGVTab = true;

            }
            else
            {
                this._selectedHash = "#variants";
            }

            return enableIGVTab;
        },

        _isCNVModuleAvailable: function() {
            var metaPropertiesJSON = {
                properties: ["MODULES"]
            };

            var idParams = this._getIdParams(this._variantsOverviewPageView._model.models);
            var isCNVModulePresent = false;
            $.ajax({
                url: '/ir/secure/api/v40/analyses/custom?analysisIds='+idParams ,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(metaPropertiesJSON),
                async: false,
                success: function(response) {
                    _.each(response, function(analysis){
                        _.each(analysis.modules, function(module) {
                            if(module.name === 'CNV Finding'){
                                isCNVModulePresent = isCNVModulePresent || true;
                            }
                        });
                    });
                }
            });
            return isCNVModulePresent;
        },

        _isBRCAWorkflow: function() {
            var isBRCAWorkflow = false;
            var analysesIds = [];
            if(this._variantsOverviewPageView.options !== undefined && this._variantsOverviewPageView.options.analysisIds) {
                analysesIds = _.map(this._variantsOverviewPageView.options.analysisIds, function(analysisId){
                    return analysisId;
                });
            }
            $.ajax({
                url: '/ir/secure/api/v40/analysis/isBrca',
                type: 'POST',
                async: false,
                contentType: 'application/json',
                data: JSON.stringify(analysesIds),
                success: function(data) {
                    isBRCAWorkflow = data;
                }
            });
            return isBRCAWorkflow;
        },

        _isPluginEnabled: function() {
            var isPluginEnabled = false;
            var analysesIds = [];
            if(this._variantsOverviewPageView.options !== undefined && this._variantsOverviewPageView.options.allAnalysisIds) {
                analysesIds = _.map(this._variantsOverviewPageView.options.allAnalysisIds, function(analysisId){
                    return analysisId;
                });
            }
            $.ajax({
                url: '/ir/secure/api/v40/analysis/pluginResultsExists',
                type: 'POST',
                async: false,
                contentType: 'application/json',
                data: JSON.stringify(analysesIds),
                success: function(data) {
                    isPluginEnabled = data;
                }
            });
            return isPluginEnabled;
        },

        _getIdParams: function(models) {
            return _.map(models,
                function(objWithId) {
                    return objWithId.id;
                }).join(',');
        }
    });

    return AnalysesVariantsTabsView;
});
define('views/variants/analysesVizPluginAdapter',['jquery'], function($) {

    

    var AnalysesVizPluginAdapter = function() {
        this.plugins = {};
    };

    AnalysesVizPluginAdapter.prototype.getPlugin = function(plugin) {
        return this._initPlugin(plugin);
    };

    AnalysesVizPluginAdapter.prototype._initPlugin = function(plugin) {

        var deferred = $.Deferred();
        var self = this;
        self.plugin = plugin;
        if (!self._init) {
            require([
                'fusion/fusion',
                'geneffects/geneffects',
                'cnv/cnv',
                'igvlight/igvlight',
                'pluginHelper'
            ], function(Fusion, Geneffects, Cnv, IgvLight, PluginHelper) {
                var fusionPlugin = {'plugin':Fusion, 'container':{'main':'#container-fusion', 'control':'#container-fusion-control','message':'message-container-fusion'}, 'status':'NOT_LOADED'};
                var geneeffectsPlugin = {'plugin':Geneffects, 'container':{'main':'#container-geneffects', 'control':'#container-geneffects-control','message':'message-container-geneffects'}, 'status':'NOT_LOADED'};
                var cnvPlugin = {'plugin':Cnv, 'container':{'main':'#container-cnv', 'control':'#container-cnv-control','message':'message-container-cnv'}, 'status':'NOT_LOADED'};
                var igvLightPlugin = {'plugin':IgvLight, 'container':{'main':'#container-igvlight', 'control':'#container-igvlight-control','message':'message-container-igvlight'}, 'status':'NOT_LOADED'};
                self.plugins.fusion = fusionPlugin;
                self.plugins.geneffects = geneeffectsPlugin;
                self.plugins.cnv = cnvPlugin;
                self.plugins.igvlight = igvLightPlugin;
                self._init = true;
                PluginHelper.init(self.plugins[self.plugin].container.message);
                deferred.resolve(self.plugins[self.plugin]);
            });
        } else {
            deferred.resolve(self.plugins[self.plugin]);
        }

        return deferred.promise();
    };

    return AnalysesVizPluginAdapter;
});
