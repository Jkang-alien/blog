            _removeBanner: function() {
                this.$(".control-group.error").removeClass("error").find("i.icon-warning-sign").remove();
                this.$(".modal-body").children(".alert.alert-error").remove();
            },

            _json: function() {
                return {
                    headerKey: this.analysis.get("name"),
