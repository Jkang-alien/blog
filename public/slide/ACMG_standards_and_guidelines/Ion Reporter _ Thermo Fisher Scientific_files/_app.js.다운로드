        _updateAllVariantNoteFlags : function(checkBoxElementsFromDom, flag) {
            var self = this;
            $.each(checkBoxElementsFromDom, function(index){
                if(typeof( $(checkBoxElementsFromDom[index]).attr('data-variant-annotation-id') ) === 'undefined' ) {
                    $(checkBoxElementsFromDom[index]).prop('checked', flag);
                    self._updateVariantNoteValue(checkBoxElementsFromDom[index]);
                }
            });
        },

        _updateVariantAnnotationValue : function(element) {
            var target = $(element),
                isIncluded = target.is(':checked'),
                variantId = target.data('variantId'),
                annotationId = target.data('variantAnnotationId');
            if((variantId !== undefined && variantId!== null && variantId!== "") && (annotationId !== undefined && annotationId!== null && annotationId!== "") && (isIncluded !== undefined && isIncluded!== null && isIncluded!== "")) {
                this.model.setIncludedFlagForVariantAnnotation(variantId, annotationId, isIncluded);
            }
        },

        _updateVariantNoteValue : function(element) {
            var target = $(element),
                isIncluded = target.is(':checked'),
                variantId = target.data('variantId'),
                commentId = target.data('variantCommentId');
            if((variantId !== undefined && variantId!== null && variantId!== "") && (commentId !== undefined && commentId!== null && commentId!== "") && (isIncluded !== undefined && isIncluded!== null && isIncluded!== "")) {
                this.model.setIncludedFlagForVariantComment(variantId, commentId, isIncluded);
            }
        },

        _captureManualElementSelect : function(e) {
            var currentVariantId = $(e.currentTarget).attr('data-variant-id');
            if($(e.currentTarget).attr('data-variant-annotation-id') !== "" && $(e.currentTarget).attr('data-variant-comment-id') !== "") {
                if(typeof($(e.currentTarget).attr('data-variant-comment-id') ) === 'undefined') {
                    if($(e.currentTarget).prop('checked') === false) {
                        $($('table').find('.annotationTableSelectAll[data-variant-id="' + currentVariantId + '"]')).prop('checked', false);
