define('views/variants/analysesVariantsSampleFilterView',['jquery',
    'underscore',
    'views/templateView',
    'hb!templates/variants/analyses-variants-sample-display.html',
    'hb!templates/variants/analyses-variants-sample-venn2.html',
    'hb!templates/variants/analyses-variants-sample-venn3.html'
], function($,
    _,
    TemplateView,
    SampleDisplayTemplate,
    SampleVenn2Template,
    SampleVenn3Template
    ) {

    

    var AnalysesSampleFilterView = TemplateView.extend({

        initialize: function(options) {
            this._venn = {};
            this._variantsSearchContext = options && options.variantsSearchContext || {};
            this._checked = [];
        },

        events: {
            'click #clear-selection'     : '_clearSelection',
            'click #save-filter-changes' : '_saveFilterChanges',
            'change [type="checkbox"]'    : '_clickCheckbox'
        },

        render: function() {

            this.intersections = this.specimenVariantIntersections || [];

            if (this.intersections.length === 3) {
                this.$el.html(SampleVenn2Template(this._makeDuoModel()));
                this._prepareVenn();
            } else if (this.intersections.length === 7) {
                this.$el.html(SampleVenn3Template(this._makeTriModel()));
                this._prepareVenn();
            } else {
                return this.renderGroups();
            }

            this.$('#venn > a[data-toggle=tooltip]').tooltip();
            this.$('#venn-learn-more a[data-toggle=popover]').popover({html:true, placement:'left'});
            return this;
        },

        renderGroups: function() {
            this.$el.html(SampleDisplayTemplate(this._makeViewModel()));
            return this;
        },

        _makeDuoModel: function() {

            var singleSamples = this._getSingleSamples();
            var doubleSamples = this._getDoubleSamples();

            this._venn.a = singleSamples[0];
            this._venn.b = singleSamples[1];
            this._venn.ab = doubleSamples[0];

            return {
                sample_a: this._getComponentName(this._venn.a.intersectingVariomes[0]),
                sample_b: this._getComponentName(this._venn.b.intersectingVariomes[0]),
                analysis_a: this._venn.a.intersectingVariomes[0].analysis.name,
                analysis_b: this._venn.b.intersectingVariomes[0].analysis.name,
                count_a: this._venn.a.numIntersectingVariants,
                count_b: this._venn.b.numIntersectingVariants,
                count_ab: this._venn.ab.numIntersectingVariants
            };
        },

        _makeTriModel: function() {

            var singleSamples = this._getSingleSamples();
            var doubleSamples = this._getDoubleSamples();

            this._venn.a = singleSamples[0];
            this._venn.b = singleSamples[1];
            this._venn.c = singleSamples[2];

            var self = this;
            this._venn.ab = _.filter(doubleSamples, function(intersection) {
                var ids = _.pluck(intersection.intersectingVariomes, 'id');
                return (_.contains(ids, self._venn.a.intersectingVariomes[0].id) &&
                        _.contains(ids, self._venn.b.intersectingVariomes[0].id));
            })[0];

            this._venn.bc = _.filter(doubleSamples, function(intersection) {
                var ids = _.pluck(intersection.intersectingVariomes, 'id');
                return (_.contains(ids, self._venn.b.intersectingVariomes[0].id) &&
                        _.contains(ids, self._venn.c.intersectingVariomes[0].id));
            })[0];

            this._venn.ac = _.filter(doubleSamples, function(intersection) {
                var ids = _.pluck(intersection.intersectingVariomes, 'id');
                return (_.contains(ids, self._venn.a.intersectingVariomes[0].id) &&
                        _.contains(ids, self._venn.c.intersectingVariomes[0].id));
            })[0];

            this._venn.abc = _.filter(this.intersections, function(intersection) {
                return (intersection.intersectingVariomes.length === 3);
            })[0];

            return {
                sample_a: this._getComponentName(this._venn.a.intersectingVariomes[0]),
                sample_b: this._getComponentName(this._venn.b.intersectingVariomes[0]),
                sample_c: this._getComponentName(this._venn.c.intersectingVariomes[0]),
                analysis_a: this._venn.a.intersectingVariomes[0].analysis.name,
                analysis_b: this._venn.b.intersectingVariomes[0].analysis.name,
                analysis_c: this._venn.c.intersectingVariomes[0].analysis.name,
                count_a: this._venn.a.numIntersectingVariants,
                count_b: this._venn.b.numIntersectingVariants,
                count_c: this._venn.c.numIntersectingVariants,
                count_ab: this._venn.ab.numIntersectingVariants,
                count_bc: this._venn.bc.numIntersectingVariants,
                count_ac: this._venn.ac.numIntersectingVariants,
                count_abc: this._venn.abc.numIntersectingVariants
            };
        },
        _getComponentName: function(intersectingVariome) {
            var group = _.findWhere(this.analysesSpecimenGroups, {analysisId: intersectingVariome.analysis.id});
            return (group && group.name) || intersectingVariome.specimen.name;
        },

        _getSingleSamples: function() {
            return _.filter(this.intersections, function(intersection) {
                return (intersection.intersectingVariomes.length === 1);
            }).sort(function(a, b) {
                var a_id = a.intersectingVariomes[0].id;
                var b_id = b.intersectingVariomes[0].id;
                var sort_disposition = (a_id < b_id) ? -1 : (a_id > b_id) ? 1 : 0;
                return sort_disposition;
            });
        },

        _getDoubleSamples: function() {
            return _.filter(this.intersections, function(intersection) {
                return (intersection.intersectingVariomes.length === 2);
            });
        },

        _makeViewModel: function() {
            return {
                analyses: _.map(this.analysesSpecimenGroups, function(analysis) {
                    return {
                        analysisName: analysis.analysisName,
                        specimenGroup: analysis.specimenGroupMembers
                    };
                })
            };
        },

        _clearSelection: function() {
            this.trigger('resetPluginStatus');
            this.$('input.label_check').prop('checked', false);
            this.$('#clear-selection').attr('disabled', true);
            this._saveFilterChanges();
        },

        _saveFilterChanges: function() {
            this.trigger('resetPluginStatus');
            this.$('#save-filter-changes').attr('disabled', true);
            this._variantsSearchContext.setVariantIntersections(this._getSelectedVennComponents());
        },

        _getSelectedVennComponents: function() {
            var selectedVennComponents = [];
            this._checked = [];
            var self = this;
            _.each(this.$('input.label_check'), function(vennCheckbox) {
                if (vennCheckbox.checked) {
                    selectedVennComponents.push(self._venn[vennCheckbox.value]);
                    self._checked.push(vennCheckbox.value);
                }
            });
            return selectedVennComponents;
        },

        _prepareVenn: function() {
            var self = this;
            _.each(this._checked, function(checkboxValue) {
                self.$('input.label_check[value=' + checkboxValue+ ']').prop('checked', true);
            });

            if (this._checked.length === 0) {
                this.$('#clear-selection').attr('disabled', true);
            }
            this.$('#save-filter-changes').attr('disabled', true);
        },

        _clickCheckbox: function() {
            this.$('#clear-selection').removeAttr('disabled');
            this.$('#save-filter-changes').removeAttr('disabled');
        }

    });

    return AnalysesSampleFilterView;
});
