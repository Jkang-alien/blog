    function($, _, kendo, TemplateView, template, providedColumnTemplate, GridColumnStatusTemplate, Modules,
        ModuleParametersPreview, LoadingView, WorkflowModel) {
        

        var CNVBaselineDetailView = TemplateView.extend({

            template: template,

            _subTemplates: {
                provided: providedColumnTemplate,
                status: GridColumnStatusTemplate
            },

            events: {
                'click a#view-parameters-link': '_onViewParameters'
            },


            render: function() {
                var viewModel = _.extend(this._modelToJSON(), {sub: this._subTemplates});
                this.$el.html(this.template(viewModel));

            },

            _modelToJSON: function() {
                var json = this.model.toJSON(), specimenNames, normalSampleNames, workflow, augmentedBaseline;
