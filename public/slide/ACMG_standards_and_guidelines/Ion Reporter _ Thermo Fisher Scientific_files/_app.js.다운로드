                } else {
                    var reportedSection = this.$el.find('.report-sections > li');
                    if(_.contains(_.pluck(reportedSection, "id"),"signoff_section")) {
                        title = this._validateAuthors() ? "": "Please enter author name before proceeding";
                    }
                }

                if(title === ""){
                    return true;
                } else {
                    $('#igverror').empty();
                    BannerView.show({
                        container: $('#igverror'),
                        style: 'error',
                        titleKey: title,
                    });
                    return false;
                }
            },

            _validateAuthors: function() {
                var authors = this.$el.find("#authors").find('input[name="name"]');
                var areAuthorsValid = true;
                _.each(authors, function(author){
                    if(author.value === "" || author.value.length < 1) {
                        areAuthorsValid = false;
                    }
                });
                return areAuthorsValid;

            },

            _onAddAuthor: function (e) {
                e.preventDefault();
                var name = this.$('#name-text').val().trim(),
                    qualification = this.$('#qualification-text').val().trim();
                if (name.length && qualification.length) {
                    this.$el.find('#authors tbody').append(this._addAuthorRow(name, qualification));
                    this.$('#name-text').val('');
                    this.$('#qualification-text').val('');
                }
            },
            
            _addBlankAuthors: function(total) {
                for (var i=0; i<total; i++) {
                    this.$el.find('#authors tbody').append(this._addAuthorRow('',''));
                }
            },
            
            _addAuthorRow: function(name, qualification) {
                var row;
                row += '<tr><td><input placeholder="Required" name="name" type="text" class="input-large" value="'+name+'"/>';
                row += '<input name="qualification" type="text" class="input-large" value="'+qualification+'"/></td>';
                row += '<td class="author-actions">';
                row += '<i class="icon-arrow-up move-author-up" title="Move this author up"></i>';
                row += '<i class="icon-arrow-down move-author-down" title="Move this author down"></i>';
                row += '<i class="icon-remove remove-author" title="Remove this author"></i></td>';                

                return row;
            },
            
            _onMoveAuthorUp: function (e) {
                e.preventDefault();
                var parent = $(e.currentTarget).parents(":eq(1)");
                if (parent.not(":first")) {
                    parent.insertBefore(parent.prev());
                }
            },

            _onMoveAuthorDown: function (e) {
                e.preventDefault();
                var parent = $(e.currentTarget).parents(":eq(1)");
                if (parent.not(":last")) {
                    parent.insertAfter(parent.next());
                }
            },            
            
            _onDeleteAuthor: function(e) {
                e.preventDefault();
                var parent = $(e.currentTarget).parents(":eq(1)");
                parent.remove();
            },            

            _openInputType: function () {
                this.$el.find('#upload').click();
            },

            _orderAnalyses: function () {
                var order = this.options.sections.wholeGenomeView.analyses;
                var tempAnalyses = this.analyses;
                this.analyses = [];
                _.each(order, function (analysis) {
                    var name = analysis.name.split(',')[1].trim();
                    _.each(tempAnalyses, function (tempAnalysis) {
                        var tempName = "Analysis " + tempAnalysis.name;
                        if (tempName === name) {
                            this.analyses.push(tempAnalysis);
                        }

                    }, this);
                }, this);
                _.each(tempAnalyses, function (tempAnalysis) {
                    var present = false;
                    _.each(this.analyses, function (analysis) {
                        if (analysis.id === tempAnalysis.id) {
                            present = true;
                        }
                    }, this);
                    if (!present) {
                        this.analyses.push(tempAnalysis);
                    }
                }, this);
            },

            _beforeReportIsGenerated: function () {
                this.$el.find('.report-section-header').addClass('unbreakableHeader');
                this.$el.find('.report-section-body > textarea').addClass('hidden');
                this.$el.find('.report-section-body > p').removeClass('hidden');
                this.$el.find('#background_section').find('.report-section-body').find('p').text(this.$el.find('#background_section').find('.report-section-body').find('textarea').val());
                this.$el.find('#disclaimer_section').find('.report-section-body').find('p').text(this.$el.find('#disclaimer_section').find('.report-section-body').find('textarea').val());
                this.$el.find('#comments_section').find('.report-section-body').find('p').text(this.$el.find('#comments_section').find('.report-section-body').find('textarea').val());
                var signoffDisplay = this.$el.find('#signoffSection_display');
                signoffDisplay.find('div').remove();
                var authors = this.$el.find('#authors tbody');
                var newDisplay = '<div><br/><div class="row-fluid">';
                authors.find('tr').each(function(i, row){
                    var $row = $(row),
                    name = $row.find('input[name="name"]').val(),
                    qualification = $row.find('input[name="qualification"]').val();
                    
                    newDisplay += '<div class="span4" style="border-top:1px solid #000;padding:5px 0 20px;"><p><b>'+name+'</b><br/>'+qualification+'</p></div>';
                    if ((i+1)%3 === 0) {
                        newDisplay += '</div><div class="row-fluid">';
                    }
                });
                newDisplay += '</div></div>';
                signoffDisplay.append(newDisplay);                
            }

        });
    });

