define('views/samples/define/manual/bamFileValidationView',['jquery', 'underscore', 'views/common/baseModalView', 'global', 'events/eventDispatcher', 'hb!templates/upload-bam-specimen-file.html'],
    function($, _, BaseModalView, Global, dispatcher, uploadBamFileTemplate) {

        

        var BamFileValidationView = BaseModalView.extend({

            initialize: function(options) {
                options = options || {};
                this.setSelectedPath = options.setSelectedPath;
                this.checkUrl = '/ir/secure/api/v40/upload/check';
            },

            events: {
                'click #removeFile': 'onRemove',
                'click #close': 'onHide',
                'click #cancelFileUpload': 'onHide'
            },

            render: function() {
                BaseModalView.prototype.render.apply(this, arguments);
                var self = this, chunkNumber = 1;
                var maxChunkSize = parseInt($.t('bam.upload.chunkSize'), 10);

                var irFileId, totalChunks, fileSize;
                this.$el.html(uploadBamFileTemplate());

                this.$('#fileupload').fileupload({
                    url: '/ir/secure/api/v40/samples/upload/bam',   // The URL for upload
                    fileInput: this.$('input:file'),                // The file element
                    dataType: 'json',                               // Type of data expected from server
                    autoUpload: false,                              // Do not start upload immediately after selection
                    acceptFileTypes: /(\.|\/)(bam)$/i,              // Accept only bam files
                    formAcceptCharset: 'utf-8',                     // Set accept charset to utf-8
                    add: function(e, data) {
                        fileSize = data.files[0].size;
                        if (fileSize > maxChunkSize) {
                            data.maxChunkSize = maxChunkSize;
                        }

                        totalChunks = Math.ceil(fileSize / maxChunkSize);
                        self.$('#upload').unbind().click(function (e) {
                            e.preventDefault();
                            self.$('.btn-file').hide();
                            self.$('#upload').hide();
                            self.$('#removeFile').hide();
                            self.$('#cancelFileUpload').hide();
                            self.$('#progress').show().addClass('progress-striped active');
                            if(!_.isUndefined(self.checkUrl)) {
                                self.startUpload(data);
                            }
                            else{
                                data.submit();
                            }
                        });
                    },
                    send: function(e, data) {
                        data.headers = _.extend(data.headers || {}, {
                            'X-First-Chunk': chunkNumber === 1,
                            'X-Last-Chunk': chunkNumber === totalChunks,
                            'X-File-Size': fileSize
                        });
                    },
                    chunksend: function(e, data) {
                        if (!_.isUndefined(irFileId)) {
                            data.headers = _.extend(data.headers || {}, { 'X-IRFile-Id': irFileId });
                        }
                        data.headers = _.extend(data.headers || {}, {
                            'X-First-Chunk': chunkNumber === 1,
                            'X-Last-Chunk': chunkNumber === totalChunks,
                            'X-File-Size': fileSize
                        });
                    },
                    chunkdone: function(e, data) {
                        irFileId = data.result.id;
                        chunkNumber++;
                    },
                    progressall: _.bind(this.progressall, this),
                    chunkfail: _.bind(this.chunkfail, this),
                    done: _.bind(this.done, this)
                });
            },

            startUpload : function(data) {
                var self = this;
                $(window).on('beforeunload', function(e) {
                    e.returnValue = "If you leave, your upload will be cancelled";
                    return e.returnValue;
                });
                $(window).on('unload', _.bind(this.clearExistingUpload, this));
                $.ajax({
                    url: self.checkUrl,
                    type: 'GET',
                    success: function() {
                        data.submit();
                    },
                    error: function() {
                        self.chunkfail();
                    }
                });
            },

            clearExistingUpload: function() {
                var self = this;
                $.ajax({
                    url: '/ir/secure/api/v40/upload/cancelCurrentUpload',
                    type: 'GET',
                    async: false,
                    success: function() {
                        self.$el.modal('hide');
                    },
                    error: function() {
                        self.$el.modal('hide');
                        dispatcher.trigger('errorCancelingUpload');
                    }
                });
                setTimeout(function() {}, 5000);
            },

            progressall: function(e, data) {
                var progress = parseInt(data.loaded / data.total * 100, 10);
                this.$('#progress .bar').css('width', progress + '%');
            },

            chunkfail: function() {
                this.$('#progress').removeClass('progress-striped active').addClass('progress-danger');
                this.$('#progress .bar').css('width', '100%');
                this.$('#close').show();
                return false;   // Stop the upload
            },

            done: function(e, data) {
                var self = this;
                this.$('#progress').removeClass('progress-striped active').addClass('progress-success');
                this.$('#upload-message').text($.t('bam.upload.success'));
                this.$('#close').show();
                this.setSelectedPath(_.pluck(data.result.path, 'name'));
                $(window).off('beforeunload');
                $(window).off('unload');
                this.$('#close').click(function() {
                    self.trigger('confirm');
                });
            },

            onHide: function(e) {
                e.preventDefault();
                $(window).off('beforeunload');
                $(window).off('unload');
                this.$el.modal('hide');
            }
        });

        return BamFileValidationView;
    });

