                case "role":
                case "relationship":
                    return 'annotations.png';
                case "chip barcode":
                case "bar code":
                    return 'barcode.png';
                case "chip type":
                case "chip id":
                    return 'three_chip_icon.png';
                case "library preparation":
                    return 'library.png';
                case "device id":
                    return 'pgm.png';
                case "ion reporter version":
                    return 'reporter.png';
                case "library preparation method":
                    return 'library.png';
                case "fusion metric file path":
                    return 'filepath.png';
                case "sample id":
                    return 'reporter.png';
