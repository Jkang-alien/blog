define('views/cnvbaseline/cnvBaselineAlgorithmTypeView',['jquery', 'views/ParentView', 'views/common/bannersView', 'views/common/baseModalView',
        'hb!templates/cnvbaseline/cnvAlgorithmType.html', 'collections/modules', 'views/loadingView',
        'models/workflow/workflowModel', 'hb!templates/cnvbaseline/cnvbaseline-select.html',
         'views/cnvbaseline/baselineParametersModalView'],
        function($, ParentView, BannerView, BaseModalView, template,
            Modules, LoadingView, Workflow, baselineSelectTemplate, BaselineParametersModalView) {
    

    var CNVBaselineAlgorithmTypeView = ParentView.extend({

        initialize: function() {
            this.model = this.options.model || null;
        },

        events: {
            'click input[name="algorithmType"]' : '_algorithmTypeChangeHandler',
            'click a#view-parameters-btn' : '_displayWorkflowParameters',
            'click .action' : 'toggle',
            'click #addToExistingBaseline' : '_addToExistingCheckboxClicked',
            'change #selected-cnv-baseline' : '_setSelectedCnvBaseline'
        },

        render: function() {
            this.model.get('specimens').reset();
            if(this.model.get('normalSampleCount') !== undefined){
                this.model.set('normalSampleCount', null);
            }
            this.$el.html(template({
                algorithmType: this.model.get('algorithmType')
            }));
            if(this.model.get('algorithmType') === 'CNV_VC_INFORMATICS_BASELINE'){
                if(this.model.get('baseCNVBaselineId')){
                    $('#addToExistingBaseline').prop('checked', true);
                }
                this._renderBaselineSelect();
            }
            this._showHideParametersButton();
            return this;
        },

        toggle: function(e) {
            $(".action").removeClass('active');
            $(e.currentTarget).addClass('active');
            var algorithmType = $(e.currentTarget).data('value');
            this.model.set('algorithmType', algorithmType);
            this._showHideParametersButton();
        },

        _renderBaselineSelect: function() {
            var loadingView = new LoadingView({
                bodyKey: 'loading.wait'
            });
            var self = this;
            var params = {
                targetRegion: self.model.get('targetRegion')
            };
            loadingView.render();
            $.ajax({
                url: 'api/v40/cnvbaseline/allowedBaselines',
                type: 'POST',
                contentType: 'application/json',
                dataType: 'json',
                data: JSON.stringify(params.targetRegion)
            }).done(function(response) {
                self.$el.find('#baselineSelect').html(baselineSelectTemplate({
                    cnvBaselines: response
                }));
                $('#selected-cnv-baseline').val(self.model.get('baseCNVBaselineId'));
                loadingView.hide();
            });
        },

        _fetchWorkflow: function() {
            var loadingView = new LoadingView({
                bodyKey: 'loading.wait'
            });
            var self = this;
            loadingView.render();
            $.ajax({
                url: 'api/v40/workflows/cnvvcibWorkflow',
                type: 'GET',
                contentType: 'application/json'
            }).done(function(response) {
                var workflow = new Workflow(response);
                var modules = new Modules();
                modules.getAllowed(workflow).done(function() {
                    workflow.set('modules', modules);
                    self.model.set('workflow', workflow);
                });
                loadingView.hide();
            });
        },

        _showHideParametersButton: function() {
            if(this.model.get('algorithmType') === 'CNV_INFORMATICS_BASELINE'){
                this.$el.find('#baselineProperties').hide();
            } else {
                this.$el.find('#baselineProperties').show();
                this._renderBaselineSelect();
                if(!this.model.get('workflow')){
                    this._fetchWorkflow();
                }
            }
        },

        _displayWorkflowParameters: function() {
            BaseModalView.open($.noop, {model : this.model.get('workflow')}, BaselineParametersModalView);
        },

        _addToExistingCheckboxClicked: function(e) {
            var checkbox = $(e.currentTarget);
            if(checkbox.is(':checked')) {
                this.model.set('baseCNVBaselineId', this.$('#selected-cnv-baseline').val());
            } else {
                this.model.unset('baseCNVBaselineId');
            }
        },

        _setSelectedCnvBaseline: function() {
            var checkbox = $('#addToExistingBaseline');
            if(checkbox.is(':checked')) {
                var selectedCnvBaselineId = this.$('#selected-cnv-baseline').val();
                this.model.set('baseCNVBaselineId', selectedCnvBaselineId);
            }
        }

    });

    return CNVBaselineAlgorithmTypeView;
});
