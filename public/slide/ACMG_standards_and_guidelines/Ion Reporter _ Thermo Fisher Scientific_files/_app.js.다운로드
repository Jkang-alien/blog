                analyses: this._model
            });

            this._downloadMenuView = new DownloadMenuView({
                analyses: this._model,
                variantsSearchContext: this._variantsSearchContext
            });

            this._analysesVizPluginAdapter = new AnalysesVizPluginAdapter();

            this.loadingView = new LoadingView({
                bodyKey: "analysis.report.prepare"
            });

            this._variantsSummariesView = new VariantsSummariesView({
                variantsSearchContext: this._variantsSearchContext,
                hidePassedCounts: true
            });

            this._pluginsResultsView = new PluginsResultsView({
                allAnalysisIds: options.allAnalysisIds,
                analysesNames: this._analysesNames
            });

            this._analysisBRCAReportView = new AnalysisBRCAReportView({
                analyses: this._model
            });
        },

        events: {
            'click #report-settings-sidebar-expand': '_expandSidebar',
            'click #report-settings-sidebar-collapse': '_collapseSidebar',
            'click #generate-report-btn': '_onGenerateReport'
        },

        delegateEvents: function () {
            TemplateView.prototype.delegateEvents.apply(this, arguments);
            this.listenTo(this._variantsSearchContext, 'refreshVariantsGrid', this._onMainRefresh, this);
            this.listenTo(this._variantsSearchContext, 'resetPluginStatus', this._resetPluginStatus, this);
            this.listenTo(this._sampleFilterView, 'resetPluginStatus', this._resetPluginStatus, this);
            this.listenTo(this._variantsGridView, 'retrievedSampleFilterData', this._onLoadSampleFilterView, this);
            this.listenTo(this._variantsSummariesView, 'retrievedSampleFilterDataIGV', this._onLoadSampleFilterView, this);
            this.listenTo(
                this._variantsFilteringView,
                AnalysesVariantsFilteringView.Event.FILTER_CHAIN_SELECTED,
                this._onFilterChainSelected);
            dispatcher.on('pluginStatusChanged', this.pluginStatusChanged, this);
            dispatcher.on('pluginTabChanged', this.pluginTabChanged, this);
        },

        undelegateEvents: function () {
            dispatcher.off('pluginTabChanged');
            dispatcher.off('pluginStatusChanged');
            this.stopListening(this._variantsGridView, 'retrievedSampleFilterData', this._onLoadSampleFilterView, this);
            this.stopListening(this._variantsSearchContext, 'refreshVariantsGrid', this._onMainRefresh, this);
            this.stopListening(this._variantsSearchContext, 'resetPluginStatus', this._resetPluginStatus, this);
            this.stopListening(this._sampleFilterView, 'resetPluginStatus', this._resetPluginStatus, this);
            this.stopListening(this._variantsSummariesView, 'retrievedSampleFilterDataIGV', this._onLoadSampleFilterView, this);
            this.stopListening(this._variantsFilteringView);
            TemplateView.prototype.undelegateEvents.apply(this, arguments);
        },

        render: function () {
            this.$el.html(this._template({
                hasAnalysisRole: this._hasAnalysisRole
            }));

            this.renderSubView(this._tabsView, '#analyses-variants-tabs');
            this.renderSubView(this._selectedAnalysisView, '#selected-analyses-container');
            if (this._hasAnalysisRole) {
                this.renderSubView(this._downloadMenuView, '#download-menu');
            }
            this.renderSubView(this._chromosomesFilterView, '#chromosomes-container');
            this.renderSubView(this._searchView, '#variant-query-form');
            this.renderSubView(this._variantsGroupFiltersView, '#variants-group-filters');
            this.renderSubView(this._variantsFilteringView, '#filter-chains-container');
            this.renderSubView(this._sampleFilterView, '#samples-container');
            this._selectedAnalysisView.populate();
        },

        renderPlugin: function () {
            this.refreshView();
            this._pluginModel = new this.plugin.plugin.Plugin();
            var self = this;
            require(['pluginHelper'], function(PluginHelper) {
                PluginHelper.init(self._pluginModel.attributes.plugin_message_container, self._pluginModel.attributes.plugin_container);
                self._pluginStatus[self._pluginModel.attributes.plugin_name].status = 'LOADING';
                self._pluginModel.set('plugin_container', self._pluginModel.attributes.plugin_container);
                self._pluginModel.set('plugin_control_container', self._pluginModel.attributes.plugin_control_container);
                self._pluginModel.set('plugin_message_container', self._pluginModel.attributes.plugin_message_container);
                self.showContainer();
                self._pluginModel.setAnalysisIds(self._model.getIds());
                self._pluginModel.onPluginLoad = _.bind(self._onIGVLoad, self);
                self.refreshControls(self._pluginModel.attributes.plugin_name);
                if(self._pluginModel.attributes.plugin_name !== 'igvlight') {
                    self._loadFilters();
                }

                self._pluginView = new self.plugin.plugin.PluginView({model: self._pluginModel});
                self._pluginStatus[self._pluginModel.attributes.plugin_name].pluginView = self._pluginView;
                self._pluginStatus[self._pluginModel.attributes.plugin_name].pluginModel = self._pluginModel;
            });
        },

        _loadFilters: function() {
            this._searchView.$el.toggle(false);
            this.$('#chart-options').toggle(true);
            this.$('#variantsSummary').toggle(false);
            var chromosome = this._variantsSearchContext.getChromosome();
            if (chromosome && chromosome.trim() !== 'All') {
                this._pluginModel.setChromosomeFilter(chromosome);
            }
            var filterChain = this._variantsSearchContext.getFilterChain();
            if (filterChain && filterChain.id) {
                this._pluginModel.setFilterId(filterChain.id);
            }
            var variantIntersections = this._variantsSearchContext.getVariantIntersections();
            if (variantIntersections) {
                this._pluginModel.setSampleBitset(variantIntersections);
            } else {
                this._pluginModel.setSampleBitset([]);
            }
            this._variantsFilteringView._variantsSummariesView._getFilterMetrics();
        },

        _clearPlugin: function () {
            if (this._pluginModel) {
                this._pluginModel.destroy();
            }
            if (this._pluginView && this._pluginView.remove) {
                this._pluginView.remove();
            }
        },

        _reloadPlugin: function(pluginName) {
            var self = this;
            this._pluginModel = this._pluginStatus[pluginName].pluginModel;
            if(!_.isUndefined(this._pluginModel) && this._pluginModel !== null){
                require(['pluginHelper'], function(PluginHelper) {
                    PluginHelper.init(self._pluginModel.attributes.plugin_message_container, self._pluginModel.attributes.plugin_container);
                    if(pluginName !== 'igvlight') {
                        self._pluginStatus[pluginName].currentView.render();
                    }
                    self.showLoadedPlugin(pluginName);
                });
            }
        },

        renderFusionPlugin: function () {
            $('#loadingSpinner').fadeIn();
            if(this._pluginStatus.fusion.status === 'LOADED') {
                this._reloadPlugin('fusion');
            } else {
                this._pluginStatus.fusion.status = 'LOADING';
                this.renderVizPlugin('fusion');
            }
            this._sampleFilterView.render();
        },

        renderGeneffectsPlugin: function () {
            $('#loadingSpinner').fadeIn();
            if(this._pluginStatus.geneffects.status === 'LOADED') {
                this._reloadPlugin('geneffects');
            } else {
                this._pluginStatus.geneffects.status = 'LOADING';
                this.renderVizPlugin('geneffects');
            }
            this._sampleFilterView.render();
        },

        renderCnvPlugin: function () {
            $('#loadingSpinner').fadeIn();
            if(this._pluginStatus.cnv.status === 'LOADED') {
                this._reloadPlugin('cnv');
            } else {
                this._pluginStatus.cnv.status = 'LOADING';
                this.renderVizPlugin('cnv');
            }
            this._sampleFilterView.render();
        },

        renderIgvLightPlugin: function () {
            $('#loadingSpinner').fadeIn();
            if(this._pluginStatus.igvlight.status === 'LOADED') {
                this._reloadPlugin('igvlight');
            } else {
                this._pluginStatus.igvlight.status = 'LOADING';
                this.renderVizPlugin('igvlight');
            }
        },

        renderPluginResultsView: function() {
            if(this._pluginStatus.pluginResults.status === 'LOADED') {
                this.showLoadedPlugin('pluginResults');
            }
            else {
                this._pluginStatus.pluginResults.status = 'LOADING';
                window._pluginStatus = this._pluginStatus;
                this.refreshView();
                this.renderOtherTabControls('pluginResults');
                this._pluginModel =  {'attributes':{'plugin_container':'container-plugin-results','plugin_control_container':'', 'plugin_name':'pluginResults'}};
                this.showContainer();
                this._pluginStatus.pluginResults.pluginModel = this._pluginModel;
                this._pluginsResultsView.analysisIndex = 0;
                this.renderSubView(this._pluginsResultsView, '#container-plugin-results');
                this.pluginStatusChanged({'plugin_name':'pluginResults', 'status':'LOADED', 'currentView':null});
            }
        },

        renderVizPlugin: function (plugin) {
            var self = this;
            if(plugin !== 'igvlight') {
                $('#generate-report-btn').addClass('disabled');
            }
            this._analysesVizPluginAdapter.getPlugin(plugin).then(function (plugin) {
                self.plugin = plugin;
                self.renderPlugin();
            });
        },

        showLoadedPlugin: function(pluginName) {
            this.refreshView();
            this._pluginModel = this._pluginStatus[pluginName].pluginModel;
            this.showContainer();
            $('#report-settings-sidebar-column-igv').hide();
            $('#report-settings-sidebar-column').show();
            if(this._pluginStatus.igvlight.status === 'LOADED') {
                $('#generate-report-btn').removeClass('disabled');
            }
            this.refreshControls(pluginName);
            $('#loadingSpinner').fadeOut();
        },

        refreshControls: function(pluginName) {
            $('#download-menu-button').removeClass('disabled');
            if(pluginName === 'variants') {
                this._searchView.$el.toggle(true);
                this.$('#chart-options').toggle(false);
                this.$('#variantsSummary').toggle(true);

                $('#report-settings-sidebar-column-igv').hide();
                $('#report-settings-sidebar-column').show();
                $('#generate-report-btn').addClass('disabled');

                $("#exportFilteredVariants").show();
                $("#exportCurrentResultsTSV").show();

            } else if (_.contains(this._otherTabs, pluginName)){
                this.renderOtherTabControls(pluginName);
            } else if(pluginName !== 'igvlight') {
                $('#report-settings-sidebar-column-igv').hide();
                $('#report-settings-sidebar-column').show();
                $('#generate-report-btn').addClass('disabled');

                $("#exportFilteredVariants").show();
                $("#exportCurrentResultsTSV").show();

                this._searchView.$el.toggle(false);
                this.$('#chart-options').toggle(true);
                this.$('#variantsSummary').toggle(false);

            } else if(pluginName === 'igvlight') {
                $('#report-settings-sidebar-column-igv').show();
                $('#report-settings-sidebar-column').hide();

                $("#exportFilteredVariants").hide();
                $("#exportCurrentResultsTSV").hide();

                this._searchView.$el.toggle(false);
                this.$('#chart-options').toggle(true);
                this.$('#variantsSummary').toggle(false);
            }
        },

        renderVariantsGrid: function () {
            if(this._pluginStatus.variants.status === 'LOADED') {
                this.showLoadedPlugin('variants');
            }
            else {
                this._pluginStatus.variants.status = 'LOADING';
                window._pluginStatus = this._pluginStatus;
                this.refreshView();
                this._pluginModel =  {attributes:{plugin_container:'analyses-variants-main',plugin_control_container:'analyses-variants-control',plugin_message_container:'message-container-variants'}};
                this._pluginStatus.variants.pluginModel = this._pluginModel;
                this.showContainer();
                this._searchView.$el.toggle(true);
                this.$('#chart-options').toggle(false);
                this.$('#variantsSummary').toggle(true);
                if (this._variantsGridView) {
                    this._variantsGridView.destroy();
                    this._variantsGridView.reset();
                }
                this.renderSubView(this._variantsGridView, '#analyses-variants-main');
                $('#generate-report-btn').addClass('disabled');
                this.pluginStatusChanged({'plugin_name':'variants', 'status':'LOADED'});
            }
            this._sampleFilterView.render();
        },

        renderBRCAReport: function () {
            $('#loadingSpinner').fadeIn();
            if(this._pluginStatus.brca.status === 'LOADED') {
                this.showLoadedPlugin('brca');
            }
            else {
                this._pluginStatus.brca.status = 'LOADING';
                $('#analyses-variants-tabs li').removeClass('active');
                $('#brca').parent().addClass('active');
                window._pluginStatus = this._pluginStatus;
                this.refreshView();
                this.renderOtherTabControls('brca');
                this._pluginModel =  {'attributes':{'plugin_container':'container-brca','plugin_control_container':'','plugin_message_container':'message-container-brca','plugin_name':'brca'}};
                this.showContainer();
                this._pluginStatus.brca.pluginModel = this._pluginModel;
                this._analysisBRCAReportView._setAnalysesList(this.analysesList);
                this.renderSubView(this._analysisBRCAReportView, '#container-brca');
                this.pluginStatusChanged({'plugin_name':'brca', 'status':'LOADED', 'currentView':null});
            }
            $('#loadingSpinner').fadeOut();
        },

        renderOtherTabControls: function(pluginName) {
            $('#report-main-column').removeClass('span9');
            $('#report-main-column').addClass('span12');
            this._searchView.$el.toggle(false);
            $('#report-settings-sidebar-column-igv').hide();
            $('#report-settings-sidebar-column').hide();
            $('#generate-report-btn').addClass('disabled');
            $("#exportFilteredVariants").hide();
            $("#exportCurrentResultsTSV").hide();
            if(pluginName === 'pluginResults') {
                $('#download-menu-button').addClass('disabled');
            }
        },

        _onMainRefresh: function () {
            this._tabsView.renderCurrentTab();
        },

        refreshView: function() {
            $('.plugin_main_container').hide();
            $('.plugin_control_container').hide();
            $('.plugin_message').hide();
            $('#report-settings-sidebar-column-igv').hide();
            $('#report-settings-sidebar-column').show();
            $('#report-main-column').removeClass('span12');
            $('#report-main-column').addClass('span9');
        },

        showContainer: function() {
            $('#'+this._pluginModel.attributes.plugin_container).show();
            $('#'+this._pluginModel.attributes.plugin_control_container).show();
            $('#'+this._pluginModel.attributes.plugin_message_container).show();
            if(this._pluginModel && this._pluginModel.attributes && this._pluginModel.attributes.plugin_name !== 'brca' && this._pluginModel.attributes.plugin_name !== 'pluginResults') {
                $('#report-main-column').removeClass('span12');
                $('#report-main-column').addClass('span9');
            }
        },

        pluginStatusChanged: function(pluginDetails) {
            this._pluginStatus[pluginDetails.plugin_name].status = pluginDetails.status;
            this._pluginStatus[pluginDetails.plugin_name].currentView = pluginDetails.currentView;
        },

        pluginTabChanged: function(previousPlugin, currentPlugin) {
            switch (currentPlugin) {
            case 'variants':
                this.renderVariantsGrid();
                break;
            case 'geneffects':
                this.renderGeneffectsPlugin();
                break;
            case 'cnv':
                this.renderCnvPlugin();
                break;
            case 'fusion':
                this.renderFusionPlugin();
                break;
            case 'igvlight':
                this.renderIgvLightPlugin();
                break;
            case 'pluginResults':
                this.renderPluginResultsView();
                break;
            case 'brca':
                this.renderBRCAReport();
                break;
            }
            if (!_.contains(this._otherTabs, currentPlugin)) {
                this.refreshControls(currentPlugin);
            }
        },
        _onLoadSampleFilterView: function (options) {
            this._sampleFilterView.analysesSpecimenGroups = this._addGroupName(options.analysisSpecimenGroups);
            this._sampleFilterView.specimenVariantIntersections = options.specimenVariantIntersections;
            this._selectedAnalysisView.analysesNames = {
                analysesNames: _.pluck(options.analysisSpecimenGroups, 'analysisName')
            };
            if(this._tabsView._selectedHash === '#variants') {
                this._sampleFilterView.render();
            }
            this._selectedAnalysisView.populate();
        },

        _addGroupName: function (groups) {
            _.each(groups, function (group) {
                group.name = '';

                var member = _.findWhere(group.specimenGroupMembers, {"role": "DNA_FUSION"});
                if (member) {
                    group.name = member.specimen.name;
                }
                member = _.findWhere(group.specimenGroupMembers, {"role": "RNA_FUSION"});
                if (member) {
                    group.name = group.name + ' ' + member.specimen.name;
                } else {
                    group.name = '';
                }
            });

            return groups;
        },

        _expandSidebar: function (e) {
            var mainReportColumnEl = this.$('#report-main-column'),
                sidebarColumnEl = this.$('#report-settings-sidebar-column');
            e.preventDefault();
            mainReportColumnEl.addClass("span9")
                .removeClass("span12 span-almost12");
            sidebarColumnEl.addClass("summary-section report-settings-sidebar-open span3")
                .removeClass("report-settings-sidebar-closed collapsed-tab");
        },

        _collapseSidebar: function (e) {
            var mainReportColumnEl = this.$('#report-main-column'),
                sidebarColumnEl = this.$('#report-settings-sidebar-column');
            e.preventDefault();
            mainReportColumnEl.removeClass("span9")
                .addClass("span12 span-almost12");
            sidebarColumnEl.removeClass("summary-section report-settings-sidebar-open span3")
                .addClass("report-settings-sidebar-closed collapsed-tab");
        },

        _resetPluginStatus: function(){
            _.each(this._pluginStatus, function(plugin) {
                if(plugin.plugin_name !== 'igvlight') {
                    plugin.status = 'REFRESH';
                }
            });
            window._pluginStatus = this._pluginStatus;
        },
        _onFilterChainSelected: function (filterChain) {
            this._downloadMenuView.setCurrentFilterChain(filterChain);
        },

        _onIGVLoad: function () {
            $('#generate-report-btn').removeClass('disabled');
            $('#loadingSpinner').fadeOut();
        },

        _onGenerateReport: function () {
            if ($('#generate-report-btn').hasClass('disabled')) {
                return false;
            }
            this.$el.hide();
            this.loadingView.render();
            var self = this;
            setTimeout(function () {
                self._createPreview();
            }, 1000);
            if(this.isTFCloudIntegrationEnabled) {
                Metrics.metrics("event", "Generate_Report", $('#workflowApplicationName').text(), this.applicationTypes.toString(), $('#workflowApplicationVersion').text(), this._analysesNames.toString(), "IonReporter > Analyses > Visualization", this.startTime);
            }
        },

        _createPreview: function () {

            this._reportPreview = new AnalysisVisualizationReportView({
                sections: window.Plugin.getSections(),
                user: this.options.user,
                allAnalyses: this._model,
                onGenerateReport: _.bind(this._generatePDFReport, this),
                onCancelReport: _.bind(this._closeReportPreview, this),
                isTFCloudIntegrationEnabled: this.options.isTFCloudIntegrationEnabled,
                startTime: this.options.startTime
            });
            this._reportPreview.render(_.bind(this._insertReportPreview, this));

        },

        _insertReportPreview: function () {
            $('#analysis-visualization-report').append(this._reportPreview.el);
            this._reportPreview.postRender();
            this.loadingView.hide();
        },

        _generatePDFReport: function (reportData) {
            this._downloadPDF('/ir/secure/api/v40/pdf/visualizationReport',
                'sample.auditlog.export.processing',reportData);
        },

        _replaceLineBreaks: function (str) {
            return str.replace(/(\r\n|\n|\r)/gm, "<br/>");
        },

        _closeReportPreview: function () {
            this._reportPreview.remove();
            this.$el.show();
        },

        _downloadPDF: function (url, loadingViewKey, postData) {
            var asyncDownloader = new AsyncDownloader();
            asyncDownloader.download(url, loadingViewKey, postData);
        },

        _getAnalyses: function (analysesModel) {
            var names = [];
            var workflowApplicationNames = [];
            var workflowApplicationVersions = [];
            var metaPropertiesJSON = {
                properties: []
            };

            var idParams = this._getIdParams(analysesModel.models);
            var self = this;
            $.ajax({
                url: '/ir/secure/api/v40/analyses/custom?analysisIds='+idParams ,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(metaPropertiesJSON),
                async: false,
                success: function(response) {
                    self.analysesList = response;
                    _.each(response, function(analysis){
                        names.push(analysis.name);
                        workflowApplicationNames.push(analysis.workflow.name);
                        workflowApplicationVersions.push(analysis.workflow.applicationVersion.name);
                    });
                }
            });

            $('#workflowApplicationName').text(workflowApplicationNames.toString());
            $('#workflowApplicationVersion').text(workflowApplicationVersions.toString());

            return names;

        },

        _getIdParams: function(models) {
            return _.map(models,
                function(objWithId) {
                    return objWithId.id;
                }).join(',');
        }

    });

    return AnalysesVariantsOverviewPage;
});

