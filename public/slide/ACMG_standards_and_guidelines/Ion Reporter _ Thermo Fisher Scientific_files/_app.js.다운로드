    function($, _, Backbone, template, kendo) {
        

        var PaymentHistoryDetails = Backbone.View.extend({
            template : template,

            initialize: function(options) {
                options = options || {};
                this.purchasedItem = options.purchasedItems;
            },

            render : function() {
                var vm = this._makeViewModel(this.purchasedItem);
                this.$el.html(this.template(vm));
                this.$('.has-popover').popover();
                return this;
            },
            
            setPurchasedItem: function(purchasedItem) {
                this.purchasedItem = purchasedItem;
