    'hb!templates/options.html'].concat('bootstrap.select'),
    function($,
            _,
            TemplateView,
            CloneSummaryGridView,
            Template,
            qcResult,
            OptionsTemplate) {
    

    var QcResultTabView = TemplateView.extend({

        initialize: function(options) {
            this.samples = options.samples || null;
            this.urlBase = null;
            this.listPngFiles = options.listPngFiles;
            this.views = [
                {
                    asDisplayableString : "Read classification",
                    name : this.listPngFiles.read_classification
                },
                {
                    asDisplayableString : "Proportion of full length, quality trimmed and reads lacking P1key, by read classification",
                    name : this.listPngFiles.p1_and_qtrim
                },
                {
                    asDisplayableString : "Base composition of overcalled and undercalled homopolymers",
                    name : this.listPngFiles.corrected_bases
                },
                {
                    asDisplayableString : "QC metrics",
                    name : "QC metrics"
                }

            ];
        },

        render: function() {
            this.$el.html(Template());
            this.$('#view-filter').selectpicker();
            this.$('#view-filter').append(
                OptionsTemplate(this.views));
            this.$('#view-filter')
                .selectpicker('refresh')
                .on('change', _.bind(this._updateResult, this));
            this._updateResult();
        },

        _updateResult: function() {
            this._clearAllDiv();
            var view = this.$('#view-filter').selectpicker('val');
            var urlElement = this.urlBase + "/" + view;
            if(view !== 'QC metrics'){
                $(function() {
                    $('<img id="result-img" src="'+ urlElement +'">').load(function() {
                        $('#result-img').html($(this));
                    });
                });
                $('#result-img').show();
            } else {
                this._createQCSummary();
            }

        },

        _createQCSummary : function() {
            $.ajax({
                url: this.urlBase + "/" + "qcResultSummary",
                type: 'GET',
                success: function(response) {
                    $('#result-img').html(qcResult(response));
                }
            });
            $('#result-img').show();

        },

        _clearAllDiv: function() {
            $('#formview').hide();
            $('#spectratypingGrp').hide();
            $('#echart').hide();
            $('#result-img').hide();
            $('#vgeneusagetoggle').hide();
            $('#clone-sum-grid').hide();
        },

        setSamples: function(data, urlBase) {
            this.samples = data;
            this.urlBase = urlBase;
        }

    });
    return QcResultTabView;
});
