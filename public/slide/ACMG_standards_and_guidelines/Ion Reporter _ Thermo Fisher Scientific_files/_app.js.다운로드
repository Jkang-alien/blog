define('views/analysis/ampliconFilteringView',[
    'jquery',
    'underscore',
    'backbone',
    'views/templateView',
    'views/common/bannersView',
    'hb!templates/analysis/amplicon-filtering.html'

], function(
    $,
    _,
    Backbone,
    TemplateView,
    BannerView,
    template
) {
    

    var AmpliconFilteringView = TemplateView.extend({

        initialize: function(options) {
            this._searchContext = options.ampliconSearchContext;
            this._analysis = options.analysis;
            this._filteredIn = 0;
            this._filteredOut = 0;
            this._bedCoveragePercent = 0;
            this._pcAmpliconsEndToEnd = 0;

        },

        events: {
            'click .filter-btn': '_onFilterButtonClicked',
            'click .save-threshold-btn': '_onThresholdSaveButtonClicked',
            'keyup input#threshold-filter': 'enableDisableFilterButton',
        },

        render: function() {
            this.$el.html(template({
                filteredIn: this._filteredIn,
                filteredOut: this._filteredOut
            }));
        },

        _onFilterButtonClicked: function() {
            var thresholdValue = this.$('#threshold-filter').val();
            this._searchContext.set('threshold', thresholdValue);
            this._searchContext.trigger('refreshAmpliconCoverageGrid');
        },

        updateFilterView: function(response) {
            this._pcAmpliconsEndToEnd = ((response.totalCount - response.totalFilteredCount)*100)/response.totalCount;
            this._bedCoveragePercent = response.bedCoveragePercent;
            this.$el.html(template({
                filteredIn: response.totalFilteredCount,
                filteredOut: response.totalCount - response.totalFilteredCount,
                threshold: response.defaultThreshold
            }));
        },

        _isThresholdValid: function() {
            var thresholdValue = this.$('#threshold-filter').val().trim();
            if( (thresholdValue.indexOf(".") !== -1) ) {
                return false;
            }
            if(thresholdValue === ""){
                return false;
            }
            if(!this._valueIsInteger(thresholdValue)) {
                return false;
            } else {
                if(thresholdValue < 0){
                    return false;
                }
            }
            return true;
        },

        _valueIsInteger: function(value) {
            return value % 1 === 0;
        },

        enableDisableFilterButton: function() {
            var $filterButton = this.$el.find('.filter-btn');
            var $saveButton = this.$el.find('.save-threshold-btn');
            var thresholdTextBox = this.$('#threshold-filter');
            if (this._isThresholdValid()) {
                $filterButton.removeClass("disabled").removeProp('disabled');
                $saveButton.removeClass("disabled").removeProp('disabled');
                thresholdTextBox.removeClass("error");
            } else {
                $filterButton.addClass("disabled").prop('disabled', true);
                $saveButton.addClass("disabled").prop('disabled', true);
                thresholdTextBox.addClass("error");
            }
        },

        _onThresholdSaveButtonClicked: function() {
            var data = {
                coverageThreshold: this.$('#threshold-filter').val(),
                bedCoveragePercent: this._bedCoveragePercent,
                coverageEndToEndPercent: this._pcAmpliconsEndToEnd
            };
            var self = this;
            $.ajax({
                url: '/ir/secure/api/v40/analysis/' + this._analysis.id + '/coverageThreshold',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function() {
                    self._searchContext.set('threshold', self.$('#threshold-filter').val());
                    self._searchContext.trigger('refreshAmpliconCoverageGrid');
                    BannerView.show({
                        id: 'success-banner',
                        container: $('.main-content>.container-fluid'),
                        style: 'success',
                        title: $.t('amplicon.threshold.save.success')
                    });
                },
                error: function() {
                    BannerView.show({
                        id: 'error-banner',
                        container: $('.main-content>.container-fluid'),
                        style: 'error',
                        title: $.t('amplicon.threshold.save.error')
                    });
                }
            });
        }
    });

    return AmpliconFilteringView;

});
