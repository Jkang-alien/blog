define('views/samples/presets/vocabTermsView',[
    'jquery',
    'underscore',
    'backbone',
    'views/samples/presets/vocabTermView',
    'utils/draggable',
    'utils/droptarget',
    'hb!templates/sample/presets/vocab-terms.html'
], function(
    $,
    _,
    Backbone,
    VocabTermView,
    Draggable,
    DropTarget,
    template
) {
    

    var VocabTermsView = Backbone.View.extend({

        _template: template,

        delegateEvents: function() {
            Backbone.View.prototype.delegateEvents.apply(this, arguments);
            this.collection.on('add', this.render, this);
            this.collection.on('remove', this.render, this);
        },

        undelegateEvents: function() {
            this.collection.off('remove', this.render, this);
            this.collection.off('add', this.render, this);
            Backbone.View.prototype.undelegateEvents.apply(this, arguments);
        },

        render: function() {
            var self = this;
            this.$el.html(this._template({
                isEmpty: this.collection.isEmpty()
            }));
            this.collection.each(function(term, index) {
                self.$('tbody')
                    .append($('<tr><td class="drag-handle"><i class="icon-th"></i></td></tr>')
                        .data('index', index)
                        .append($('<td></td>')
                            .append(new VocabTermView({model: term}).render().$el)));
            });

            var table = this.$('table');
            new Draggable({
                el: this.$('.drag-handle'),
                axis: 'y',
                container: table.find('tbody'),
                hint: function(target) {
                    var row = target.parents('tr');
                    return $('<table class="table drag-hint"></table>')
                        .append(row.clone())
                        .css({
                            width: row.innerWidth()
                        });
                }
            });
            new DropTarget({
                el: this.$('tbody > tr'),
                onDragEnter: function(dropTarget) {
                    dropTarget.find('td:eq(1)').addClass('drag-hover');
                },
                onDragLeave: function(dropTarget) {
                    dropTarget.find('td:eq(1)').removeClass('drag-hover');
                },
                onDrop: function(dropTarget, dragTarget) {
                    var dragged = dragTarget.parents('tr'),
                        removalPoint = dragged.data('index'),
                        insertionPoint = dropTarget.data('index'),
                        termToMove = self.collection.at(removalPoint);
                    if (termToMove) {
                        self.collection.models.splice(removalPoint, 1);
                        if (removalPoint < insertionPoint) {
                            insertionPoint--;
                        }
                        self.collection.models.splice(insertionPoint, 0, termToMove);
                        self.collection.each(function(term, index) {
                            term.set('fieldOrder', index);
                        });
                        self.render();
                    }
                }
            });

            return this;
        }

    });

    return VocabTermsView;
});

