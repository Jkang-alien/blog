define('views/filterChains/filterEditTypeThresholdView',['jquery', 'backbone', 'hb!templates/filterChain/filter-edit-type-threshold.html' ],
function($, Backbone, template) {
    var FilterEditTypeThresholdView = Backbone.View.extend({

        initialize: function() {
            this.filter = this.options.filter;
        },

        render: function(isGroup) {
            this.$el.html(template({
                filter: this.filter,
                isGroup: isGroup
            }));
            return this;
        },

        prepareFilterForAdd: function() {
            var filter = this.filter;
            filter.set("configuredInclusive", this.$el.find('input#thresholdFilter-inclusive').prop('checked'));
            filter.set("configuredIncludeMissing", this.$el.find('input#thresholdFilter-includeUnannotated').prop('checked'));

            if (this.isInGroup()) {
                this.filter.set("enabled", this.isEnabled());
            }

            var threshold = this.$el.find('input#filter-threshold').val();
            if (filter.isDoubleThresholdFilter()){
                if (threshold.indexOf(".") === -1) {
                    threshold = threshold.concat(".0");
                }
            }
            filter.set("configuredThreshold", threshold);
        },

        isValidFilter: function() {
            var filter = this.filter;
            var threshold = this.$el.find('input#filter-threshold').val();
            if(filter.isDoubleThresholdFilter()){
                if(!this._floatOrFalse(threshold)){
                    if(this._floatOrFalse(threshold) !== 0){
                        return false;
                    }
                }
            }
            if (filter.isIntegerThresholdFilter()) {
                if (!this._valueIsInteger(threshold)) {
                    if(this._valueIsInteger(threshold) !== 0){
                        return false;
                    }
                }
            }
            return true;
        },

        isInGroup: function() {
            var $enabledCheckbox = this._getEnabledCheckbox();
            return $enabledCheckbox && $enabledCheckbox.length > 0;
        },

        _floatOrFalse: function(n) {
            var floatValue = parseFloat(n);
            if (!isNaN(floatValue) && isFinite(n)) {
                return floatValue;
            } else {
                return false;
            }
        },

        isEnabled: function() {
            return this._getEnabledCheckbox().prop('checked');
        },

        _getEnabledCheckbox: function() {
            return this.$el.find('input#filter-threshold-enabled');
        },

        _valueIsInteger: function(value) {
            return value % 1 === 0;
        }

    });

    return FilterEditTypeThresholdView;
});
