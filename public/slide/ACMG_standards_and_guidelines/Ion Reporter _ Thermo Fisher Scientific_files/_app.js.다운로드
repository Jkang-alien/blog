            reportData.previewFinalReport = _.contains(modelJson.actions, "PREVIEW_FINAL_REPORT");
            reportData.hasCoverageReport = _.contains(modelJson.actions, "VIEW_COVERAGE_REPORT");
            reportData.readyOnly = this.readOnly;
            reportData = this._prepareReportData(reportData, analysisData);
            reportData = this._prepareSpecimensData(reportData, specimenList);
            this.reportData = reportData;
            return reportData;
        },

        _prepareReportData: function(reportData, analysisData) {
            reportData.analysis = {
                id: analysisData.id,
                name: analysisData.name,
                importedby: analysisData.createdBy &&
                            analysisData.createdBy.firstName + ' ' + analysisData.createdBy.lastName,
                analyzedby: analysisData.analyzedBy &&
                            analysisData.analyzedBy.firstName + ' ' + analysisData.analyzedBy.lastName,
                date_imported: analysisData.createdOn &&
                               kendo.toString(new Date(Date.parse(analysisData.createdOn)),
                                   "MMMM d, yyyy hh:mm tt"),
                date_analyzed: analysisData.lastModifiedOn &&
                               kendo.toString(new Date(Date.parse(analysisData.lastModifiedOn)),
                                   "MMMM d, yyyy hh:mm tt"),
                workflow: analysisData.workflow,
                workflowRevision : analysisData.workflow.revision,
                annotations: analysisData.annotationSet,
                baseline: analysisData.baseline,
                references: analysisData.references && analysisData.references.length > 0 ?
                            analysisData.references : null,
                stage: analysisData.stage,
            };
            return reportData;
        },

        _prepareSpecimensData: function(reportData, specimenList) {
            var self = this;
            for (var i = 0; i < specimenList.length; i++) {
                var specimen = specimenList[i].specimen;
                var attributeMap = specimen.attributeValueMap;
                _.extend(specimen, {
                    gender: attributeMap.Gender,
                    relationship: specimenList[i].role && $.t('specimen.role.' + specimenList[i].role),
                    barcode: specimen.metadata && specimen.metadata['Bar Code'],
                    chiptype: specimen.metadata && specimen.metadata['Chip Type'],
                    chipid: specimen.metadata && specimen.metadata['Chip ID'],
                    libraryPreparation: specimen.metadata && specimen.metadata['Library Preparation'],
                    deviceid: specimen.metadata && specimen.metadata['Device ID']
                });

                reportData.specimens[i] = specimen;
            }
            _.each(reportData.specimens, function(specimen) {
                specimen.attributes = _.reject(specimen.attributes, function(specimenAttribute) {
                    return _.contains(self._excludedSampleAttributes, specimenAttribute.attribute.name);
                }, self);
                specimen.attributes.sort(function(a, b){
                    return a.attribute.name.localeCompare(b.attribute.name);
                });
            });
            return reportData;
        },

        _initializePopovers: function() {
            var reportData = this.reportData;
            if (reportData.analysis.annotations && reportData.analysis.annotations.sources) {
                this.$('#annotation-details').data('content',
                    annotationPopoverTemplate(reportData.analysis.annotations)).popover({
                        html: true,
                        trigger: 'hover'
                    });
            }
            if (reportData.analysis.workflow) {
                var workflowData = this._prepareWorkflowData();
                this.$('#workflow-details').data('content',
                    workflowPopoverTemplate(workflowData)).popover({
                        html: true,
                        trigger: 'hover'
                    });
            }
            if (reportData.analysis.baseline) {
                this.$('#cnvBaseline').data('content',
                    baselinePopoverTemplate(reportData.analysis.baseline)).popover({
                        html: true,
                        trigger: 'hover'
                    });
            }
        },

        _prepareWorkflowData: function() {
            var reportData = this.reportData;
            var workflowData = {};
            workflowData.reportData = reportData;

            workflowData.createdOn = kendo.toString(new Date(Date.parse(reportData.analysis.workflow.createdOn)),
                                     "MMMM d, yyyy hh:mm tt");
            workflowData.lastModifiedOn = kendo.toString(new Date(Date.parse(reportData.analysis.workflow.lastModifiedOn)),
                                     "MMMM d, yyyy hh:mm tt");
            return workflowData;
        },

        _goToVisualize: function() {
            var analysisId = this.model.get('id');
            var applicationTypes = this.model.get('applicationType');
            window.location = '/ir/secure/analyses/visualization.html?ids=' + encodeURIComponent(analysisId) + '&appTypes=' + encodeURIComponent(applicationTypes);
        },

        _sendBackToAnalyze: function(e) {
            if (this._isDisabled(e)) {
                return;
            }

            var self = this;

            MessageView
                .open({
                    title: $.t('dialog.analysis.sendBackToAnalyze.title'),
                    message: $.t('analysis.sendBack.confirm.text'),
                    buttons: {
                        confirm: {
                            label: 'confirm.yes'
                        },
                        close: {
                            label: 'confirm.no',
                            cls: 'primary'
                        }
                    }
                })
                .confirm(function() {
                    MessageView.close();
                    window.location = '/ir/secure/analyses/' + self.model.get('id') + '/send_back_to_variant_review';
                });
        },

        _sendToReportRole: function (e) {
            if (this._isDisabled(e)) {
                return;
            }

            AnalysisSendToReportView.open({
                model: this.model
            });
        },


        _previewFinalReport: function (e) {
            if (this._isDisabled(e)) {
                return;
            }
            var variants = this._variantsGridView.getSelected();
            if (this._isDefaultFilter()) {
                var workflow = this.model.get('workflow');
                if(workflow !== undefined && workflow !== null){
                    var finalReportTemplate = workflow.get('reportTemplate');
                    if(finalReportTemplate === undefined || finalReportTemplate === null){
                        this._openFinalReprotTemplateModal();
                    }else{
                        var selectedVariantColumns = this._getSelectedVariantColumns().toString();
                        this._submitPreviewFinalReport(variants.models, null, selectedVariantColumns);
                    }
                }
            }
            if(this.isTFCloudIntegrationEnabled) {
                Metrics.metrics("event", 'Generate_Report', $('#workflowApplicationName').text(), $('#workflowApplicationType').text(), $('#workflowApplicationVersion').text(), $('#analysisNameId').text(), 'IonReporter > Analyses > Edit_Variants', this.startTime);
            }
        },

        _openFinalReprotTemplateModal : function() {
            new selectFinalReportTemplateModelView({
                workflow : this.model.get('workflow'),
                el: $('#selectReportTemplateModal')
            }).render();
        },

        _submitPreviewFinalReportCallback: function (selectedFinalReportTemplated){
                var variants = this._variantsGridView.getSelected();
                var selectedVariantColumns = this._getSelectedVariantColumns().toString();
                this._submitPreviewFinalReport(variants.models, selectedFinalReportTemplated, selectedVariantColumns);
            },

        _submitPreviewFinalReport: function(variantModels, selectedFinalReportTemplated, selectedVariantColumns) {
            var $form = this._createPreviewFinalReportForm(variantModels, selectedFinalReportTemplated, selectedVariantColumns);
            $form.appendTo(this.$el);
            $form[0].submit();
        },

        _createPreviewFinalReportForm : function(variantModels, selectedFinalReportTemplated, selectedVariantColumns) {
            var $form = $("<form />", { action : '/ir/secure/analyses/' + this.model.id + '/preview_final_report.html',
                            method : 'post', hidden : true});

            _.each(variantModels, function(variant) {
                $form.append($("<input />", { type : 'hidden', name : 'selectedVariantIds', value : variant.id }));
            });
            if(null!== selectedFinalReportTemplated){
                $form.append($("<input />", {type : 'hidden', name : 'finalReportTemplateId', value : selectedFinalReportTemplated.id }));
            }
            $form.append($("<input />", {type : 'hidden', name : 'X-IonReporter-CSRF-Token', value : global.csrfToken }));

            if(null!== selectedVariantColumns){
                $form.append($("<input />", {type : 'hidden', name : 'selectedVariantColumns', value : selectedVariantColumns }));
            }
            return $form;

        },

        _getSelectedVariantColumns: function(){
            var gridTheme = this._variantsGridView._loadedPlugins.variantGridActions._gridTheme;
            var variantColumns = [];
            if(!_.isUndefined(gridTheme) && gridTheme !== null){
                var summaryGridThemeColumns;
                var classificationCategory = "Summary";
                if(this.model.get('workflow').get('applicationType') === "RNA"){
                    classificationCategory = "Fusions";
                }
                _.each(gridTheme.get("gridThemeData"), function(gridThemeData){
                    if(gridThemeData.annotationClassification.name === classificationCategory){
                        summaryGridThemeColumns = (JSON.parse(gridThemeData.themeData)).columns;
                    }
                });
                if(!_.isUndefined(summaryGridThemeColumns)){
                    _.each(summaryGridThemeColumns, function(column){
                        if(!_.isUndefined(column.field)){
                            if(!column.hidden){
                                variantColumns.push(column.field);
                            }
                        }
                    });
                }
            }
            return variantColumns;
        },

        _renderVariantsGrid: function() {
            if (!this._variantsGridView.rendered) {
                this.renderSubView(this._variantsGridView, '#analysis-variants-grid');
            } else {
                this._variantsGridView.clearSelection();
                this._variantsGridView.reset();
            }
        },

        _hideVariant: function() {
            this._variantsGridView.hideCheckedVariants();
        },

        _unhideVariant: function() {
            this._variantsGridView.unhideCheckedVariants();
        },

        _addToMyVariants: function() {
            var self = this;

            MyVariantsModal.open(function(dialog) {
                var variants = self._variantsGridView.getSelected();
                var selectedMyVariantsList = dialog.selectedValue;

                variants = variants.map(function(variant) {
                    return {
                        id: variant.id,
                        myVariantsState: selectedMyVariantsList
                    };
                });

                $.ajax({
                    url: '/ir/secure/api/v40/variant/setMyVariantsStates',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(variants),
                    success: function() {
                        self._clearVariantSelection();
                        self._variantsGridView.refresh();
                        self._checkVariantSelection();
                    }
                });

            }, {
                myVariantsStates: self.options.myVariantsStates
            });
        },

        _toggleHideActions: function() {
            if (this._variantsSearchContext.isFilteredInGroup() &&
                    this.model.isSuccessful() &&
                    !this.model.isReportPublished() &&
                    this._hasAnalysisRole) {
                this.$('#selected-variants-hide').show();
                this.$('#selected-variants-unhide').hide();
            }
            else if(this._variantsSearchContext.isHiddenGroup() &&
                    this.model.isSuccessful() &&
                    !this.model.isReportPublished() &&
                    this._hasAnalysisRole) {
                this.$('#selected-variants-hide').hide();
                this.$('#selected-variants-unhide').show();
            }
            else {
                this.$('#selected-variants-hide').hide();
                this.$('#selected-variants-unhide').hide();
            }
        },

        _classifyVariants: function() {
            var self = this;

            ClassifyVariantsModal.open(function(dialog) {

                var variants = self._variantsGridView.getSelected();
                var selectedClassification = dialog.$('select[name="classification"]').val();


                variants = variants.map(function(variant) {
                    return {
                        id: variant.id,
                        classification: selectedClassification
                    };
                });

                $.ajax({
                    url: '/ir/secure/api/v40/variant/classifyvariants',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(variants),
                    success: function() {
                        self._clearVariantSelection();
                        self._variantsGridView.refresh();
                        self._checkVariantSelection();
                        self._disableSendToReportButton();
                    }
                });

            }, {
                classifications: self.options.variantClassifications,
                actions: self._selectedVariantsActionsView.actions
            });
        },

        _orderTaqman: function() {
            this._initiateOrder('/ir/secure/api/v40/variant/ordertaqman');
        },

        _orderCE: function() {
            this._initiateOrder('/ir/secure/api/v40/variant/orderce');
        },

        _initiateOrder: function(orderInfoUrl) {
            var self = this;
            var variants = self._variantsGridView.getSelected();
            $.ajax({
                url: orderInfoUrl,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(variants),
                success: function(response) {
                    self._openOrderPage(response);
                }
            });
        },

        _openOrderPage: function(params) {
            var orderUrl = params.launchUri;
            orderUrl += '?' + $.param(params.urlVariables);
            var win = window.open(orderUrl, 'order');
            $(win).focus();
        },

        _disableSendToReportButton : function() {
            if (!this.readOnly) {
                this.$('#sendToReportRoleBtn').addClass('disabled');
            }
        },

        _expandSidebar: function(e) {
            var mainReportColumnEl = this.$('#report-main-column'),
                sidebarColumnEl = this.$('#report-settings-sidebar-column');
            e.preventDefault();
            mainReportColumnEl.addClass("span9")
                .removeClass("span12 span-almost12");
            sidebarColumnEl.addClass("summary-section report-settings-sidebar-open span3")
                .removeClass("report-settings-sidebar-closed collapsed-tab");
        },

        _collapseSidebar: function(e) {
            var mainReportColumnEl = this.$('#report-main-column'),
                sidebarColumnEl = this.$('#report-settings-sidebar-column');
            e.preventDefault();
            mainReportColumnEl.removeClass("span9")
                .addClass("span12 span-almost12");
            sidebarColumnEl.removeClass("summary-section report-settings-sidebar-open span3")
                .addClass("report-settings-sidebar-closed collapsed-tab");
        },

        _onPluginSelected: function(plugin) {
            var launchURL = '/ir/secure/plugins/' + plugin.id + '/launch/' + this.model.id;
            this._launchPlugin(launchURL, plugin);
        },

        _launchPlugin: function(launchURL, plugin) {
            var self = this;
            if (launchURL) {
                var eulaFile = new EULAFile(null, {
                    plugin: plugin,
                    analysis: this.model
                });
                eulaFile.fetch({
                    success: function() {
                        eulaFile.accept(function() {
                            var pluginView = new VariantsIngenuityView({
                                el: '#plugin-pane',
                                launchUrl: launchURL,
                                plugin: plugin,
                                analysis: self.model
                            });
                            pluginView.render();

                            self.$('#variant-pane').addClass('hide');
                            pluginView.$el.removeClass('hide');
                            $('#topBackLinkId').addClass('hide');
                            $('#topHideLinkId').removeClass('hide');
                        });
                    }
                });
            }
        },

        _displayCheckedOutBanner: function(model) {
            var checkedOutBy = model.get('checkedOutBy');
            if (this.readOnly && checkedOutBy) {
                this._displayBanner('alert', $.t('analysis.checkedOutBy.alert',
                        { checkedOutByFirst: checkedOutBy.firstName, checkedOutByLast: checkedOutBy.lastName}), true);
            }
        },

        _displaySharedBanner: function() {
            if (this.model.isShared()) {
                var sharedBy = this.model.get('sharedBy');
                this._displayBanner('alert', $.t('analysis.shared.alert', {
                    name: sharedBy.firstName + ' ' + sharedBy.lastName,
                    organization: sharedBy.organization.name
                }), true);
            }
        },

        _displayBanner: function(style, title, stable) {
                new BannerView({
                    id: "alert-banner",
                    container: $('#variants-overview .row-fluid:first'),
                    style: style,
                    title: title,
                    static: stable
                }).render();
            },

        _checkVariantSelection: function() {

            if (this._variantsGridView.getSelected().length > 0) {
                var self = this,
                    variantsActions = new VariantsActions();
                var variants = self._variantsGridView.getSelected();
                variantsActions.getActionsForVariants(variants, function(model, response) {
                    if (response && response.length > 0) {
                        if(self.model.isShared()){
                            _.each(response, function(val, i) {
                                if(val === "ADD_TO_VARIANT_KB") // delete Action ADD_TO_VARIANT_KB for Shared analysis
                                {
                                    response.splice(i, 1);
                                }
                            });
                        }
                        self._selectedVariantsActionsView.setActions(response).render();
                    }
                });
            } else {
                this._selectedVariantsActionsView.setActions(null).render();
            }

            this.$('#previewFinalReportBtn').toggleClass('disabled', (this.readOnly || !this._isDefaultFilter()));

        },


        _clearVariantSelection: function() {
            this._variantsGridView.clearSelection();
        },

        _checkInCurrentAnalysis: function() {
            this._checkInErrorMessage = undefined; // the should be set by the error callback;
            this.model.synchronousCheckIn(_.bind(this._checkInFailure, this));
            return this._checkInErrorMessage;
        },

        _checkInFailure: function() {
            this._checkInErrorMessage = $.t('analysis.checkIn.error');
            this._displayBanner('error', this._checkInErrorMessage , true);
        },

        _isDefaultFilter: function() {
            return this._variantsSearchContext.get('group') === 'DEFAULT';
        },

        _isDisabled: function(event) {
            if ($(event.currentTarget).hasClass('disabled')) {
                return true;
            }
            return false;
        },

        _exportAllVariants: function() {
            this._exportVariants('/ir/secure/analyses/' + this.model.id + '/download_unfiltered_data');
        },

        _exportFilteredVariants: function() {
            this._exportVariants('/ir/secure/analyses/' + this.model.id + '/download_filtered_data');
        },

        _exportCurrentResults: function() {
            this._exportVariants('/ir/secure/analysis/variants/export-current-results',
                this._variantsSearchContext.toSlimJSON());
        },

        _exportVariants: function(url, postData) {
            var asyncDownloader = new AsyncDownloader();
            asyncDownloader.submitRequestForProcessing(url, 'analysis.export.processing', postData);
        },

        _preventDefaultButtonLinkBehavior: function(e) {
            e.preventDefault();
        },

        _onClassificationSelected: function(name) {
            this._variantsGridView.updateColumnsForClassification(name);
        },

        _onSentForReportGeneration: function(analysis) {
            sessionStorage.setItem('flashMessage', i18n.t('analysis.sendToReport.success', {
                analysis: {
                    name: analysis.get('name')
                }
            }));
            window.location = '/ir/secure/analyses.html';
        },

        _onSearchKeyUp: function() {
            var query = this._searchView.$queryField.val().trim();
            if(this._searchView.valid.test(query) && (!this._isChromosomeRangeNegative(query)) ){
                this.$('.control-group').removeClass('error');
            }else {
                this.$('.control-group').addClass('error');
            }
        },

        _onSearch: function(e) {
            e.preventDefault();
            var query = this._searchView.$queryField.val().trim();
            if (this._searchView.valid.test(query) && (!this._isChromosomeRangeNegative(query)) ){
                this.trigger('search', this._searchView.valid.exec(query)[0]);
            }
        },

        _isChromosomeRangeNegative: function(searchText) {
            if(searchText.indexOf('chr') === 0){
                var indexOfColon = searchText.indexOf(':');
                if( (indexOfColon >= 3) && (searchText.length > indexOfColon + 2) ){
                    if(searchText.charAt(indexOfColon + 1) === '-'){
                        return true;
                    }
                }
            }
            return false;
        }
        
    });

    return VariantsOverviewPage;
});

