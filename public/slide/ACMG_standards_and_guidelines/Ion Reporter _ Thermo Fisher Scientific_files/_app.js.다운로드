                    self._disableSendToReportButton();
                });
            }
        },
        _onTooltipMouseenter: function(e) {
            var target = $(e.currentTarget),
                offset = target.width()/2,
                left = parseInt($('.tooltip.in').css('left'),10);
            if (target.position().left > 100) {
                $('.tooltip.in').css('left', left - offset + 'px');
            } else {
                $('.tooltip.in').css('left', left + offset + 'px');
            }
        },

        _disableSendToReportButton : function() {
            dispatcher.trigger('disable:SendToReportButton');
        },

        hideCheckedVariants: function() {
            this._updateHidden(true);
        },

        unhideCheckedVariants: function() {
            this._updateHidden(false);
        },

        _updateHidden: function(hide) {
            var self = this,
                selectedItems = this.getSelected();
            if (selectedItems.length) {
                this.indicateLoading(true);
                $.ajax({
                    url : (hide ?
                           '/ir/secure/api/v40/variant/hide/' :
                           '/ir/secure/api/v40/variant/unhide/') + self._analysis.get('id'),
                    type : 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(selectedItems.map(function(selectedItem) {
                        return {id: selectedItem.id};
                    })),
                    success: function() {
                        self.clearSelection();
                        self.refresh();
                        self.indicateLoading(true);
                    }
                });
            }
        },

        _removeGridSpinner: function() {
            mainGridReference._grid.indicateLoading(false);
        }

    });

    return VariantsGridView;
});
