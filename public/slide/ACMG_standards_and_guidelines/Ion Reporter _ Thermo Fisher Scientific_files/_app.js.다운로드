define('views/samples/presets/create/createLOVAttributeView',[
    'jquery',
    'underscore',
    'views/samples/presets/create/createAttributeView',
    'views/samples/presets/vocabTermsView',
    'views/common/bannersView',
    'hb!templates/sample/presets/create/create-lov-attribute.html'
], function(
    $,
    _,
    CreateAttributeView,
    VocabTermsView,
    BannerView,
    template
) {
    

    var CreateLOVAttributeView = CreateAttributeView.extend({

        _template: template,

        _termsEl: '#vocab-terms',

        events: _.extend({}, CreateAttributeView.prototype.events, {
            'click #btn-add-term': '_onAddTerm',
            'click .icon-trash': '_onDeleteTerm',
            'key input': '_onFieldChanged'
        }),

        initialize: function(options) {
            CreateAttributeView.prototype.initialize.call(this, _.extend(options || {}, {
                type: 'LOV'
            }));
            this.termsView = new VocabTermsView({
                collection: this.model.get('controlledVocabulary').get('terms')
            });
        },

        _postRender: function() {
            this.disableButton('#btn-add-term');
            this.termsView.setElement(this.$(this._termsEl)).render();
        },

        save: function() {
            var terms = this.model.get('controlledVocabulary').get('terms');
            _.each(this.$('tbody input[type=text]'), function(input, index) {
                terms.at(index).set('fieldValue', $(input).val().trim());
            });
            return CreateAttributeView.prototype.save.apply(this, arguments);
        },

        _onFieldChanged: function(e) {
            var fieldName = $(e.target).attr('name');
            var termField = this.$("#term-text").val();
            $(e.target).parents('.control-group').removeClass('error');
            if (termField) {
                this.enableButton("#btn-add-term");
            } else {
                this.disableButton('#btn-add-term');
            }

            this.model.set(
                fieldName,
                this._state()[fieldName],
                {
                    include: fieldName,
                    validate: true
                });
            var terms = this.model.get('controlledVocabulary').get('terms');
            if(!_.isEmpty(terms.models) && this.$('#name-text').val()) {
                this.enableButton("#btn-confirm");
            }
        },

        _onAddTerm: function(e) {
            e.preventDefault();
            var terms = this.model.get('controlledVocabulary').get('terms'),
                value = this.$('#term-text').val().trim();

            if (value.length) {
                if (this._containsTerm(terms, value)) {
                    BannerView.show({
                        container: $('.modal-body'),
                        style: 'error',
                        title: $.t('sample.preset.vocab.unique')
                    });
                } else {
                    terms.add({
                        fieldValue: value,
                        fieldType: 'STRING',
                        fieldOrder: terms.length
                    });
                    this.$('#term-text').val('');
                    this.model.trigger('change');
                    this.disableButton('#btn-add-term');
                }
            }
            var nameField = this.$("#name-text").val();
            if (!_.isEmpty(terms.models && nameField) ) {
                this.enableButton("#btn-confirm");
            }
        },

        _containsTerm: function(terms, term) {
            return _.any(terms.models, function(model) {
                return model.attributes.fieldValue === term;
            });
        },

        _onDeleteTerm: function(e) {
            e.preventDefault();
            var terms = this.model.get('controlledVocabulary').get('terms'),
                cid = $(e.currentTarget).data('cid'),
                term = terms.get(cid);
            if (term) {
                terms.remove(term);
                terms.each(function(term, index) {
                    term.set('fieldOrder', index);
                });
                this.model.trigger('change');
            }
            if (_.isEmpty(terms.models)) {
                this.disableButton("#btn-confirm");
            } else {
                this.enableButton("#btn-confirm");
            }
        }
    });

    return CreateLOVAttributeView;
});

